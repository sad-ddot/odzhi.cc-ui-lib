local function SaveConfig(configName)
    local data = {}
    for key, value in pairs(ConfigState) do
        if typeof(value) == "Color3" then
            data[key] = {T = "C3", R = value.R, G = value.G, B = value.B}
        elseif typeof(value) == "EnumItem" then
            data[key] = {T = "EI", V = tostring(value)}
        elseif type(value) == "table" then
            data[key] = {T = "TBL", V = value}
        else
            data[key] = value
        end
    end
    if not isfolder(ConfigFolder) then
        makefolder(ConfigFolder)
    end
    writefile(ConfigFolder .. "/" .. configName .. ".json", HttpService:JSONEncode(data))
end

local function LoadConfig(configName)
    local path = ConfigFolder .. "/" .. configName .. ".json"
    if not isfile(path) then
        return false
    end
    local data = HttpService:JSONDecode(readfile(path))
    for key, value in pairs(data) do
        if type(value) == "table" then
            if value.T == "C3" then
                ConfigState[key] = Color3.new(value.R, value.G, value.B)
            elseif value.T == "TBL" then
                ConfigState[key] = value.V
            else
                ConfigState[key] = value
            end
        else
            ConfigState[key] = value
        end
        if ConfigCallbacks[key] then
            ConfigCallbacks[key](ConfigState[key])
        end
    end
    return true
end

local function ColorToHex(color)
    return string.format(
        "#%02X%02X%02X",
        math.floor(color.R * 255 + 0.5),
        math.floor(color.G * 255 + 0.5),
        math.floor(color.B * 255 + 0.5)
    )
end

local function HexToColor(hex)
    hex = hex:gsub("#", "")
    if #hex ~= 6 then
        return nil
    end
    local r = tonumber(hex:sub(1, 2), 16)
    local g = tonumber(hex:sub(3, 4), 16)
    local b = tonumber(hex:sub(5, 6), 16)
    if r and g and b then
        return Color3.fromRGB(r, g, b)
    end
    return nil
end

