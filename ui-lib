        Position = UDim2.new(0, 2, 0.5, -8),
        BackgroundColor3 = Color3.new(1, 1, 1),
        BorderSizePixel = 0,
        Parent = Switch,
    }, { Util.Corner(8) })

    local currentKey = key
    local listening = false
    local active = false

    local function restyle()
        Switch.BackgroundColor3 = active and Library.Theme.ToggleOn or Library.Theme.ToggleOff
    end
    restyle()
    Library:_Register(restyle)

    local function setActive(v)
        if active == v then return end
        active = v
        Util.Tween(Switch, { BackgroundColor3 = active and Library.Theme.ToggleOn or Library.Theme.ToggleOff }, 0.15)
        Util.Tween(Knob, {
            Position = active and UDim2.new(1, -18, 0.5, -8) or UDim2.new(0, 2, 0.5, -8),
        }, 0.15)
        local ok, err = pcall(callback, active)
        if not ok then warn("[UILib] HoldToggle callback error: " .. tostring(err)) end
    end

    KeyChip.MouseButton1Click:Connect(function()
        listening = true
        KeyChip.Text = "..."
    end)

    UserInputService.InputBegan:Connect(function(input, gpe)
        if listening and input.UserInputType == Enum.UserInputType.Keyboard then
            currentKey = input.KeyCode
            KeyChip.Text = currentKey.Name
            listening = false
            if flag then Library.Flags[flag] = currentKey end
            return
        end
        if not gpe and currentKey ~= Enum.KeyCode.Unknown and input.KeyCode == currentKey then
            setActive(true)
        end
    end)

    UserInputService.InputEnded:Connect(function(input)
        if currentKey ~= Enum.KeyCode.Unknown and input.KeyCode == currentKey then
            setActive(false)
        end
    end)

    local function setKey(v)
        currentKey = v
        KeyChip.Text = v.Name
        if flag then Library.Flags[flag] = currentKey end
    end

    if flag then
        Library.FlagObjects[flag] = { Set = setKey }
        Library.Flags[flag] = currentKey
    end

    return { Get = function() return active end, SetKey = setKey, GetKey = function() return currentKey end }
end

function Section:AddSlider(cfg)
    cfg = cfg or {}
    local min = cfg.Min or 0
    local max = cfg.Max or 100
    local default = math.clamp(cfg.Default or min, min, max)
    local flag = cfg.Flag
    local suffix = cfg.Suffix or ""
    local callback = cfg.Callback or function() end

    local Holder = Util.Create("Frame", {
        Size = UDim2.new(1, 0, 0, 40),
        BackgroundTransparency = 1,
        Parent = self.ElementsHolder,
    })

    local Label = Util.Create("TextLabel", {
        Text = cfg.Text or "Slider",
        Font = Library.Font,
        TextSize = 13,
        BackgroundTransparency = 1,
        Size = UDim2.new(1, -50, 0, 18),
        TextXAlignment = Enum.TextXAlignment.Left,
        Parent = Holder,
    })
    Library:_Bind(Label, "TextColor3", "Text")

    local ValueLabel = Util.Create("TextLabel", {
        Text = tostring(default) .. suffix,
        Font = Library.Font,
        TextSize = 13,
        BackgroundTransparency = 1,
        Size = UDim2.new(0, 50, 0, 18),
        Position = UDim2.new(1, -50, 0, 0),
        TextXAlignment = Enum.TextXAlignment.Right,
        Parent = Holder,
    })
    Library:_Bind(ValueLabel, "TextColor3", "SubText")

    local Track = Util.Create("Frame", {
        Size = UDim2.new(1, 0, 0, 6),
        Position = UDim2.new(0, 0, 0, 27),
        BorderSizePixel = 0,
        Parent = Holder,
    }, { Util.Corner(3) })
    Library:_Bind(Track, "BackgroundColor3", "Field")
    local trackStroke = Util.Stroke()
    trackStroke.Parent = Track
    Library:_Bind(trackStroke, "Color", "Border")

    local Fill = Util.Create("Frame", {
        Size = UDim2.new((default - min) / (max - min), 0, 1, 0),
        BorderSizePixel = 0,
        Parent = Track,
    }, { Util.Corner(3) })
    Library:_Bind(Fill, "BackgroundColor3", "Accent")

    local Knob = Util.Create("Frame", {
        Size = UDim2.new(0, 12, 0, 12),
        AnchorPoint = Vector2.new(0.5, 0.5),
        Position = UDim2.new((default - min) / (max - min), 0, 0.5, 0),
        BackgroundColor3 = Color3.new(1, 1, 1),
        BorderSizePixel = 0,
        ZIndex = 2,
        Parent = Track,
    }, { Util.Corner(6) })

    local dragging = false
    local value = default

    local function setFromAlpha(alpha)
        alpha = math.clamp(alpha, 0, 1)
        value = math.floor(min + (max - min) * alpha + 0.5)
        local realAlpha = (value - min) / (max - min)
        Fill.Size = UDim2.new(realAlpha, 0, 1, 0)
        Knob.Position = UDim2.new(realAlpha, 0, 0.5, 0)
        ValueLabel.Text = tostring(value) .. suffix
        local ok, err = pcall(callback, value)
        if not ok then warn("[UILib] Slider callback error: " .. tostring(err)) end
        if flag then Library.Flags[flag] = value end
    end

    Track.InputBegan:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1
            or input.UserInputType == Enum.UserInputType.Touch then
            dragging = true
            local alpha = (input.Position.X - Track.AbsolutePosition.X) / Track.AbsoluteSize.X
            setFromAlpha(alpha)
        end
    end)

    UserInputService.InputChanged:Connect(function(input)
        if dragging and (input.UserInputType == Enum.UserInputType.MouseMovement
            or input.UserInputType == Enum.UserInputType.Touch) then
            local alpha = (input.Position.X - Track.AbsolutePosition.X) / Track.AbsoluteSize.X
            setFromAlpha(alpha)
        end
    end)

    UserInputService.InputEnded:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1
            or input.UserInputType == Enum.UserInputType.Touch then
            dragging = false
        end
    end)

    local function setValue(v)
        v = math.clamp(v, min, max)
        setFromAlpha((v - min) / (max - min))
    end

    if flag then
        Library.FlagObjects[flag] = { Set = setValue }
        Library.Flags[flag] = default
    end

    return { Set = setValue, Get = function() return value end }
end

