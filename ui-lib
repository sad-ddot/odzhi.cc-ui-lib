            function S:AddToggle(o) S.EC = S.EC + 1 local nm = o.Name or "Toggle" local def = o.Default or false local fl = o.Flag or nm local cb = o.Callback or function() end local showBind = o.ShowBind or false local defBind = o.DefaultBind or Enum.KeyCode.Unknown local tog = def local bindKey = defBind local bListen = false ConfigState[fl] = tog
                local f = Create("Frame", {Parent = sCont, BackgroundTransparency = 1, Size = UDim2.new(1, 0, 0, 15), LayoutOrder = S.EC})
