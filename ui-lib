                Cr("UIGradient", {Parent=dInner, Rotation=90, Color=ColorSequence.new(C.DropBgGradTop, C.DropBgGradBot)})

                local function gdt()
                    if multi then
                        local s = {}
                        for _, it in ipairs(items) do if sel[it] then table.insert(s,it) end end
                        return #s==0 and "-" or table.concat(s,", ")
                    end
                    return tostring(sel)
                end

                local sLbl = Cr("TextLabel", {Parent=dInner, BackgroundTransparency=1, Position=UDim2.new(0,5,0,0), Size=UDim2.new(1,-18,1,0), Font=Enum.Font.SourceSans, Text=gdt(), TextColor3=C.TextDim, TextSize=12, TextXAlignment=Enum.TextXAlignment.Left, ZIndex=2, ClipsDescendants=true})
                Cr("TextLabel", {Parent=dInner, BackgroundTransparency=1, Position=UDim2.new(1,-13,0,0), Size=UDim2.new(0,10,1,0), Font=Enum.Font.SourceSans, Text="v", TextColor3=C.TextDark, TextSize=10, ZIndex=2})

                local dList = Cr("Frame", {Parent=ScreenGui, BackgroundColor3=C.DropOuter, BorderSizePixel=0, Size=UDim2.new(0,100,0,0), Visible=false, ZIndex=120, ClipsDescendants=true})
                local dListInner = Cr("Frame", {Parent=dList, BackgroundColor3=C.DropBg, BorderSizePixel=0, Position=UDim2.new(0,1,0,1), Size=UDim2.new(1,-2,1,-2), ZIndex=121, ClipsDescendants=true})
                Cr("UIListLayout", {Parent=dListInner, SortOrder=Enum.SortOrder.LayoutOrder})

                local function refresh()
                    for _, c in pairs(dListInner:GetChildren()) do if c:IsA("TextButton") then c:Destroy() end end
                    for idx, it in ipairs(items) do
                        local isSel = multi and (sel[it]==true) or (sel==it)
                        local ib = Cr("TextButton", {
                            Parent=dListInner, BackgroundColor3=C.DropBg, BorderSizePixel=0,
                            Size=UDim2.new(1,0,0,16), Font=Enum.Font.SourceSans,
                            Text="  "..it, TextColor3=isSel and C.Accent or C.TextDim,
                            TextSize=12, TextXAlignment=Enum.TextXAlignment.Left,
                            AutoButtonColor=false, ZIndex=122, LayoutOrder=idx,
                        })
                        ib.MouseEnter:Connect(function() ib.BackgroundColor3=C.DropItemHover end)
                        ib.MouseLeave:Connect(function() ib.BackgroundColor3=C.DropBg end)
                        ib.MouseButton1Click:Connect(function()
                            if multi then
                                sel[it] = not sel[it] or nil
                                if sel[it]==false then sel[it]=nil end
                                ConfigState[fl]=sel sLbl.Text=gdt()
                                ib.TextColor3=sel[it] and C.Accent or C.TextDim
                                cb(sel)
                            else
                                sel=it ConfigState[fl]=sel sLbl.Text=gdt()
                                isOpen=false dList.Visible=false ActiveDrop=nil
                                cb(sel)
                            end
                        end)
                    end
                end

                dInner.MouseButton1Click:Connect(function()
                    if ActiveDrop and ActiveDrop~=dList then ActiveDrop.Visible=false end
                    isOpen = not isOpen
                    if isOpen then
                        refresh()
                        local ap = dOuter.AbsolutePosition
                        local as = dOuter.AbsoluteSize
                        dList.Position = UDim2.new(0,ap.X,0,ap.Y+as.Y)
                        dList.Size = UDim2.new(0,as.X,0,math.min(#items*16+2,200))
                        dList.Visible = true
                        ActiveDrop = dList
                    else
                        dList.Visible=false ActiveDrop=nil
                    end
                end)

                sLbl.Text = gdt()
                cb(sel)
                ConfigCallbacks[fl] = function(v) sel=v sLbl.Text=gdt() cb(v) end

                local obj = {}
                function obj:Set(v) sel=v ConfigState[fl]=v sLbl.Text=gdt() cb(v) end
                function obj:Get() return sel end
                function obj:UpdateItems(ni) items=ni if isOpen then refresh() end end
                return obj
            end

