    })

    local thHpBg = Create("Frame", {
        Parent = thHpOuter,
        BackgroundColor3 = C.GroupBg,
        BorderSizePixel = 0,
        Position = UDim2.new(0, 1, 0, 1),
        Size = UDim2.new(1, -2, 1, -2),
