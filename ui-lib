                local brightMult = SparkCfg.BRIGHTNESS_MULT or 1
                local randomLifetime = math.random(SparkCfg.LIFETIME_MIN * 10, SparkCfg.LIFETIME_MAX * 10) / 10 * lifetimeMult
                emitter.Lifetime = NumberRange.new(randomLifetime)
                emitter.Speed = NumberRange.new(0.1, 0.25)
                emitter.RotSpeed = NumberRange.new(20, 55)
                emitter.Drag = 0.1
                emitter.Acceleration = Vector3.new(0, 0.03, 0)
                emitter.LockedToPart = true
                emitter.LightEmission = 1
                emitter.LightInfluence = 0
                emitter.Size = NumberSequence.new({
                    NumberSequenceKeypoint.new(0, 0),
                    NumberSequenceKeypoint.new(0.15, SparkCfg.BASE_SIZE * sizeMult),
                    NumberSequenceKeypoint.new(0.85, SparkCfg.BASE_SIZE * sizeMult),
                    NumberSequenceKeypoint.new(1, 0)
                })
                emitter.Color = ColorSequence.new(sparks_color)
                pcall(function() emitter.ClipOnLimits = false end)
                emitter.Transparency = NumberSequence.new({
                    NumberSequenceKeypoint.new(0, 1),
                    NumberSequenceKeypoint.new(0.12, 0.0),
                    NumberSequenceKeypoint.new(0.65, 0.1),
                    NumberSequenceKeypoint.new(0.88, 0.5),
                    NumberSequenceKeypoint.new(1, 1)
                })
                emitter.Parent = sparkPart
                emitter:Emit(1)
                light.Brightness = SparkCfg.LIGHT_BRIGHTNESS * brightMult
                local entry = {part = sparkPart, emitter = emitter, light = light}
                table.insert(active_sparks, entry)
                local lightTime = 0
                local pulseAngle = math.random(0, 360)
                local light_conn
                light_conn = RunService.Heartbeat:Connect(function(frameDt)
                    if not sparkPart or not sparkPart.Parent or not light or not emitter then
                        light_conn:Disconnect()
                        return
                    end
                    lightTime = lightTime + frameDt
                    local progress = lightTime / randomLifetime
                    if progress >= 1 then
                        light_conn:Disconnect()
                        return
                    end
                    pulseAngle = pulseAngle + (frameDt * SparkCfg.PULSE_SPEED)
                    local wave = math.sin(pulseAngle)
                    local currentSize = SparkCfg.BASE_SIZE + (SparkCfg.PULSE_AMPLITUDE * wave)
                    emitter.Size = NumberSequence.new({
                        NumberSequenceKeypoint.new(0, 0),
                        NumberSequenceKeypoint.new(0.15, currentSize),
                        NumberSequenceKeypoint.new(0.85, currentSize),
                        NumberSequenceKeypoint.new(1, 0)
                    })
                    local breatheModifier = 1 + (wave * 0.25)
                    local baseFade = 1
                    if progress < 0.12 then
                        baseFade = progress / 0.12
                    elseif progress > 0.65 then
                        baseFade = 1 - ((progress - 0.65) / 0.35)
                    end
                    light.Brightness = SparkCfg.LIGHT_BRIGHTNESS * baseFade * breatheModifier
                end)
                task.delay(randomLifetime + 0.2, function()
