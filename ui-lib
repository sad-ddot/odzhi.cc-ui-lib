local function nuke_muzzle_descendant(v)
    pcall(function()
        local n = v.Name
        local pn = v.Parent and v.Parent.Name or ""
        local matches = n:find("flash") or n:find("muzzle") or n:find("Flash") or n:find("Muzzle")
            or n:find("smoke") or n:find("Smoke") or n:find("spark") or n:find("Spark")
            or pn:find("muzzle") or pn:find("aimpart") or pn:find("AimPart")
        if matches then
            if v:IsA("Light") or v:IsA("ParticleEmitter") then v.Enabled = false
            elseif v:IsA("BasePart") then v.Transparency = 1
            elseif v:IsA("Smoke") or v:IsA("Fire") then v.Enabled = false
            end
        end
    end)
end
