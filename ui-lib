                local sName = sliderOptions.Name or "Slider"
                local sMin = sliderOptions.Min or 0
                local sMax = sliderOptions.Max or 100
                local sDefault = sliderOptions.Default or sMin
                local sFlag = sliderOptions.Flag or sName
                local sCallback = sliderOptions.Callback or function() end
                local sSuffix = sliderOptions.Suffix or ""
                local sIncrement = sliderOptions.Increment or 1

                Sector.ElementCount = Sector.ElementCount + 1
                local currentValue = sDefault

                ConfigState[sFlag] = currentValue

                local SliderFrame = Create("Frame", {
                    Name = "Slider_" .. sName,
