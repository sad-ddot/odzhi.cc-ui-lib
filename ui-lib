                Cr("TextLabel", {Parent=f, BackgroundTransparency=1, Size=UDim2.new(1,0,0,13), Font=Enum.Font.SourceSans, Text=nm, TextColor3=C.TextDim, TextSize=13, TextXAlignment=Enum.TextXAlignment.Left})
                local tOuter = Cr("Frame", {Parent=f, BackgroundColor3=C.InputOuter, BorderSizePixel=0, Position=UDim2.new(0,0,0,14), Size=UDim2.new(1,0,0,16)})
                local tBox = Cr("TextBox", {Parent=tOuter, BackgroundColor3=C.InputBg, BorderSizePixel=0, Position=UDim2.new(0,1,0,1), Size=UDim2.new(1,-2,1,-2), Font=Enum.Font.SourceSans, Text=cur, PlaceholderText=ph, PlaceholderColor3=C.TextDark, TextColor3=C.TextDim, TextSize=12, TextXAlignment=Enum.TextXAlignment.Left, ClearTextOnFocus=false, ClipsDescendants=true})
                Cr("UIPadding", {Parent=tBox, PaddingLeft=UDim.new(0,4)})

                tBox.FocusLost:Connect(function(e) cur=tBox.Text ConfigState[fl]=cur cb(cur,e) end)
                ConfigCallbacks[fl] = function(v) cur=v tBox.Text=v cb(v) end

                local obj = {}
                function obj:Set(v) cur=v tBox.Text=v ConfigState[fl]=v cb(v) end
                function obj:Get() return cur end
                return obj
            end

            function S:AddMultibox(o)
                S.EC = S.EC + 1
                local nm=o.Name or "Multibox" local def=o.Default or "" local ph=o.Placeholder or ""
                local fl=o.Flag or nm local cb=o.Callback or function()end local lines=o.Lines or 4
                local cur=def ConfigState[fl]=cur
                local bH=lines*14+4

                local f = Cr("Frame", {Parent=sContent, BackgroundTransparency=1, Size=UDim2.new(1,0,0,14+bH), LayoutOrder=S.EC})
                Cr("TextLabel", {Parent=f, BackgroundTransparency=1, Size=UDim2.new(1,0,0,13), Font=Enum.Font.SourceSans, Text=nm, TextColor3=C.TextDim, TextSize=13, TextXAlignment=Enum.TextXAlignment.Left})
                local mOuter = Cr("Frame", {Parent=f, BackgroundColor3=C.InputOuter, BorderSizePixel=0, Position=UDim2.new(0,0,0,14), Size=UDim2.new(1,0,0,bH)})
                local mBox = Cr("TextBox", {Parent=mOuter, BackgroundColor3=C.InputBg, BorderSizePixel=0, Position=UDim2.new(0,1,0,1), Size=UDim2.new(1,-2,1,-2), Font=Enum.Font.SourceSans, Text=cur, PlaceholderText=ph, PlaceholderColor3=C.TextDark, TextColor3=C.TextDim, TextSize=12, TextXAlignment=Enum.TextXAlignment.Left, TextYAlignment=Enum.TextYAlignment.Top, MultiLine=true, ClearTextOnFocus=false, ClipsDescendants=true, TextWrapped=true})
                Cr("UIPadding", {Parent=mBox, PaddingLeft=UDim.new(0,4), PaddingTop=UDim.new(0,3)})

                mBox.FocusLost:Connect(function(e) cur=mBox.Text ConfigState[fl]=cur cb(cur,e) end)
                ConfigCallbacks[fl] = function(v) cur=v mBox.Text=v cb(v) end

                local obj = {}
                function obj:Set(v) cur=v mBox.Text=v ConfigState[fl]=v cb(v) end
                function obj:Get() return cur end
                return obj
            end

            function S:AddLabel(o)
                S.EC = S.EC + 1
                local txt = o.Text or ""
                local f = Cr("Frame", {Parent=sContent, BackgroundTransparency=1, Size=UDim2.new(1,0,0,13), LayoutOrder=S.EC})
                local l = Cr("TextLabel", {Parent=f, BackgroundTransparency=1, Size=UDim2.new(1,0,1,0), Font=Enum.Font.SourceSans, Text=txt, TextColor3=C.TextDark, TextSize=13, TextXAlignment=Enum.TextXAlignment.Left})
                local obj = {}
                function obj:SetText(t) l.Text=t end
                return obj
            end

            function S:AddSeparator()
                S.EC = S.EC + 1
                Cr("Frame", {Parent=sContent, BackgroundColor3=C.GroupBorderInner, BorderSizePixel=0, Size=UDim2.new(1,0,0,1), LayoutOrder=S.EC})
            end

            return S
        end

        return T
    end

    UserInputService.InputBegan:Connect(function(inp)
        if inp.UserInputType==Enum.UserInputType.MouseButton1 and ActiveDrop and ActiveDrop.Visible then
            local ap,as=ActiveDrop.AbsolutePosition,ActiveDrop.AbsoluteSize
            local mp=UserInputService:GetMouseLocation()
            if mp.X<ap.X or mp.X>ap.X+as.X or mp.Y<ap.Y or mp.Y>ap.Y+as.Y then
                ActiveDrop.Visible=false ActiveDrop=nil
            end
        end
    end)

    return W
end

return GamesenseLib
