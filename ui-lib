                tbInput.Focused:Connect(function() Tween(tbOuter, {BackgroundColor3 = C.InpFocus}, 0.1) end)
                tbInput.FocusLost:Connect(function(e) Tween(tbOuter, {BackgroundColor3 = C.InpOuter}, 0.1) currentText = tbInput.Text ConfigState[tbFlag] = currentText tbCallback(currentText, e) end)
                ConfigCallbacks[tbFlag] = function(v) currentText = v tbInput.Text = v tbCallback(v) end
                local tbObj = {}
                function tbObj:Set(v) currentText = v tbInput.Text = v ConfigState[tbFlag] = v tbCallback(v) end
                function tbObj:Get() return currentText end
                return tbObj
            end

            function Sector:AddMultibox(mbOpts)
                Sector.ElementCount = Sector.ElementCount + 1
                local mbName = mbOpts.Name or "Multibox"
                local mbDefault = mbOpts.Default or ""
                local mbPlaceholder = mbOpts.Placeholder or ""
                local mbFlag = mbOpts.Flag or mbName
                local mbCallback = mbOpts.Callback or function() end
                local mbLines = mbOpts.Lines or 4
                local currentText = mbDefault
                ConfigState[mbFlag] = currentText
                local boxHeight = mbLines * 14 + 6

                local mbFrame = Create("Frame", {Parent = sectorContent, BackgroundTransparency = 1, Size = UDim2.new(1, 0, 0, 16 + boxHeight), LayoutOrder = Sector.ElementCount})
                Create("TextLabel", {Parent = mbFrame, BackgroundTransparency = 1, Size = UDim2.new(1, 0, 0, 14), Font = Enum.Font.SourceSans, Text = mbName, TextColor3 = C.TextDim, TextSize = 13, TextXAlignment = Enum.TextXAlignment.Left})
                local mbOuter = Create("Frame", {Parent = mbFrame, BackgroundColor3 = C.InpOuter, BorderSizePixel = 0, Position = UDim2.new(0, 0, 0, 16), Size = UDim2.new(1, 0, 0, boxHeight)})
                local mbInput = Create("TextBox", {Parent = mbOuter, BackgroundColor3 = C.InpBg, BorderSizePixel = 0, Position = UDim2.new(0, 1, 0, 1), Size = UDim2.new(1, -2, 1, -2), Font = Enum.Font.SourceSans, Text = currentText, PlaceholderText = mbPlaceholder, PlaceholderColor3 = C.TextDark, TextColor3 = C.TextDim, TextSize = 12, TextXAlignment = Enum.TextXAlignment.Left, TextYAlignment = Enum.TextYAlignment.Top, MultiLine = true, ClearTextOnFocus = false, ClipsDescendants = true, TextWrapped = true})
                Create("UIPadding", {Parent = mbInput, PaddingLeft = UDim.new(0, 5), PaddingTop = UDim.new(0, 3)})
                mbInput.Focused:Connect(function() Tween(mbOuter, {BackgroundColor3 = C.InpFocus}, 0.1) end)
                mbInput.FocusLost:Connect(function(e) Tween(mbOuter, {BackgroundColor3 = C.InpOuter}, 0.1) currentText = mbInput.Text ConfigState[mbFlag] = currentText mbCallback(currentText, e) end)
                ConfigCallbacks[mbFlag] = function(v) currentText = v mbInput.Text = v mbCallback(v) end
                local mbObj = {}
                function mbObj:Set(v) currentText = v mbInput.Text = v ConfigState[mbFlag] = v mbCallback(v) end
                function mbObj:Get() return currentText end
                return mbObj
            end

            function Sector:AddPlayerList(plOpts)
                Sector.ElementCount = Sector.ElementCount + 1
                local plName = plOpts.Name or "Players"
                local plCallback = plOpts.Callback or function() end
                local plHeight = plOpts.Height or 100
                local selectedPlayers = {}

                local plFrame = Create("Frame", {Parent = sectorContent, BackgroundTransparency = 1, Size = UDim2.new(1, 0, 0, 16 + plHeight), LayoutOrder = Sector.ElementCount})
                Create("TextLabel", {Parent = plFrame, BackgroundTransparency = 1, Size = UDim2.new(1, 0, 0, 14), Font = Enum.Font.SourceSans, Text = plName, TextColor3 = C.TextDim, TextSize = 13, TextXAlignment = Enum.TextXAlignment.Left})
                local plOuter = Create("Frame", {Parent = plFrame, BackgroundColor3 = C.InpOuter, BorderSizePixel = 0, Position = UDim2.new(0, 0, 0, 16), Size = UDim2.new(1, 0, 0, plHeight)})
                local plScroll = Create("ScrollingFrame", {Parent = plOuter, BackgroundColor3 = C.InpBg, BorderSizePixel = 0, Position = UDim2.new(0, 1, 0, 1), Size = UDim2.new(1, -2, 1, -2), ScrollBarThickness = 2, ScrollBarImageColor3 = C.GroupInner, AutomaticCanvasSize = Enum.AutomaticSize.Y, ScrollingDirection = Enum.ScrollingDirection.Y, ClipsDescendants = true})
                Create("UIListLayout", {Parent = plScroll, SortOrder = Enum.SortOrder.LayoutOrder})

                local function refreshPlayerList()
                    for _, c in pairs(plScroll:GetChildren()) do if c:IsA("TextButton") then c:Destroy() end end
                    for i, p in ipairs(Players:GetPlayers()) do
                        if p ~= LocalPlayer then
                            local isSel = selectedPlayers[p.Name] == true
                            local pb = Create("TextButton", {Parent = plScroll, BackgroundColor3 = C.InpBg, BorderSizePixel = 0, Size = UDim2.new(1, 0, 0, 18), Font = Enum.Font.SourceSans, Text = "  " .. p.Name, TextColor3 = isSel and C.Accent or C.TextDim, TextSize = 12, TextXAlignment = Enum.TextXAlignment.Left, AutoButtonColor = false, LayoutOrder = i})
                            pb.MouseEnter:Connect(function() pb.BackgroundColor3 = C.DrpHover end)
                            pb.MouseLeave:Connect(function() pb.BackgroundColor3 = C.InpBg end)
                            pb.MouseButton1Click:Connect(function()
                                if selectedPlayers[p.Name] then selectedPlayers[p.Name] = nil else selectedPlayers[p.Name] = true end
                                pb.TextColor3 = selectedPlayers[p.Name] and C.Accent or C.TextDim
                                plCallback(selectedPlayers)
                            end)
                        end
                    end
                end

                refreshPlayerList()
                Players.PlayerAdded:Connect(function() task.wait(0.5) refreshPlayerList() end)
                Players.PlayerRemoving:Connect(function(p) selectedPlayers[p.Name] = nil task.wait(0.1) refreshPlayerList() end)

                local plObj = {}
                function plObj:Get() return selectedPlayers end
                function plObj:Refresh() refreshPlayerList() end
                return plObj
            end

            function Sector:AddLabel(labelOpts)
                Sector.ElementCount = Sector.ElementCount + 1
                local labelText = labelOpts.Text or ""
                local labelFrame = Create("Frame", {Parent = sectorContent, BackgroundTransparency = 1, Size = UDim2.new(1, 0, 0, 14), LayoutOrder = Sector.ElementCount})
                local labelElement = Create("TextLabel", {Parent = labelFrame, BackgroundTransparency = 1, Size = UDim2.new(1, 0, 1, 0), Font = Enum.Font.SourceSans, Text = labelText, TextColor3 = C.TextDark, TextSize = 13, TextXAlignment = Enum.TextXAlignment.Left})
                local labelObj = {}
                function labelObj:SetText(newText) labelElement.Text = newText end
                return labelObj
            end

            function Sector:AddSeparator()
                Sector.ElementCount = Sector.ElementCount + 1
                Create("Frame", {Parent = sectorContent, BackgroundColor3 = C.GroupInner, BorderSizePixel = 0, Size = UDim2.new(1, 0, 0, 1), LayoutOrder = Sector.ElementCount})
            end

            return Sector
        end

        return Tab
    end

    UserInputService.InputBegan:Connect(function(input, gameProcessed)
        if input.UserInputType == Enum.UserInputType.Keyboard and input.KeyCode == Enum.KeyCode.Insert and not gameProcessed then
            Window:Toggle()
            return
        end

        if input.UserInputType == Enum.UserInputType.MouseButton1 then
            task.defer(function()
                local mousePosition = UserInputService:GetMouseLocation()

                if ActiveDropdown and ActiveDropdown.Visible then
                    local ddAbsPos = ActiveDropdown.AbsolutePosition
                    local ddAbsSize = ActiveDropdown.AbsoluteSize
                    if mousePosition.X < ddAbsPos.X or mousePosition.X > ddAbsPos.X + ddAbsSize.X or mousePosition.Y < ddAbsPos.Y or mousePosition.Y > ddAbsPos.Y + ddAbsSize.Y then
                        ActiveDropdown.Visible = false
                        ActiveDropdown = nil
                    end
                end

                for _, cpEntry in pairs(AllColorPickers) do
                    if cpEntry.IsOpen and cpEntry.Panel and cpEntry.Panel.Visible then
                        local cpAbsPos = cpEntry.Panel.AbsolutePosition
                        local cpAbsSize = cpEntry.Panel.AbsoluteSize
                        if mousePosition.X < cpAbsPos.X or mousePosition.X > cpAbsPos.X + cpAbsSize.X or mousePosition.Y < cpAbsPos.Y or mousePosition.Y > cpAbsPos.Y + cpAbsSize.Y then
                            cpEntry.Panel.Visible = false
                            cpEntry.IsOpen = false
                        end
                    end
                end
            end)
        end
    end)

    return Window
end

return GamesenseLib
