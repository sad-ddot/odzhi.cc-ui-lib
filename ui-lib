    local CHAIN_NUM_POINTS = 24

    local function chain_build_data(root)
        local model = Instance.new("Model")
        model.Name = "TargetChainEffect"
        model.Parent = root
        local b1_atts, b1_beams, b2_atts, b2_beams = {}, {}, {}, {}
        local function build_branch(atts, beams)
            for i = 1, CHAIN_NUM_POINTS + 1 do
                local att = Instance.new("Attachment")
                att.Name = "ChainNode"
                att.Parent = root
                table.insert(atts, {Att = att, AngleOffset = (i / CHAIN_NUM_POINTS) * math.pi * 2})
            end
            for i = 1, CHAIN_NUM_POINTS do
                local beam = Instance.new("Beam")
                beam.Attachment0 = atts[i].Att
                beam.Attachment1 = atts[i+1].Att
                beam.Texture = chain_texture_id
                beam.TextureMode = Enum.TextureMode.Wrap
                beam.TextureLength = 1.4
                beam.Width0 = 1.5
                beam.Width1 = 1.5
                beam.LightEmission = 0
                beam.Transparency = NumberSequence.new(0)
                beam.FaceCamera = true
                beam.Color = ColorSequence.new(chain_color)
                beam.Parent = model
                table.insert(beams, beam)
            end
        end
        build_branch(b1_atts, b1_beams)
        build_branch(b2_atts, b2_beams)
        return {model = model, b1_atts = b1_atts, b1_beams = b1_beams, b2_atts = b2_atts, b2_beams = b2_beams}
    end

    local function chain_step(root, b1_atts, b2_atts, b1_beams, b2_beams, dt, rot, pulse_t, spd, dw, dt2)
        local rcf = root.CFrame
        local ps = math.sin(pulse_t)
        local dr = 1.9 + (ps * 0.12)
        local dtr = math.clamp(0.0 + (ps * -0.15), 0, 0.4)
        for i = 1, #b1_atts do
            local d1 = b1_atts[i]
            local a1 = rot + d1.AngleOffset
            local x1 = math.cos(a1) * dr
            local z1 = math.sin(a1) * dr
            local y1 = -0.25 + (math.sin(a1 * 2) * 0.55)
            local wp1 = rcf * Vector3.new(x1, y1, z1)
            d1.Att.Position = rcf:PointToObjectSpace(wp1)
            local d2 = b2_atts[i]
            local a2 = rot + d2.AngleOffset
            local x2 = math.cos(a2) * dr
            local z2 = math.sin(a2) * dr
            local y2 = -0.25 + (-math.sin(a2 * 2) * 0.55)
            local wp2 = rcf * Vector3.new(x2, y2, z2)
            d2.Att.Position = rcf:PointToObjectSpace(wp2)
        end
        for i = 1, #b1_beams do
            local b1 = b1_beams[i]
            local b2 = b2_beams[i]
            b1.Width0 = dw; b1.Width1 = dw
            b1.Transparency = NumberSequence.new(dtr)
            b1.TextureSpeed = spd * 0.15
            b1.Color = ColorSequence.new(chain_color)
            b2.Width0 = dw; b2.Width1 = dw
            b2.Transparency = NumberSequence.new(dtr)
            b2.TextureSpeed = spd * 0.15
            b2.Color = ColorSequence.new(chain_color)
        end
    end

