                local dI = Create("TextButton", {Parent = dO, BorderSizePixel = 0, Position = UDim2.new(0, 1, 0, 1), Size = UDim2.new(1, -2, 1, -2), Text = "", AutoButtonColor = false, ClipsDescendants = true})
                Create("UIGradient", {Parent = dI, Rotation = 90, Color = ColorSequence.new(C.DrpGradT, C.DrpGradB)})
                local sL = Create("TextLabel", {Parent = dI, BackgroundTransparency = 1, Position = UDim2.new(0, 6, 0, 0), Size = UDim2.new(1, -22, 1, 0), Font = Enum.Font.SourceSans, Text = tostring(sel), TextColor3 = C.TextDim, TextSize = 12, TextXAlignment = Enum.TextXAlignment.Left, ZIndex = 2, ClipsDescendants = true})
                Create("TextLabel", {Parent = dI, BackgroundTransparency = 1, Position = UDim2.new(1, -16, 0, 0), Size = UDim2.new(0, 14, 1, 0), Font = Enum.Font.SourceSans, Text = "v", TextColor3 = C.TextDark, TextSize = 11, ZIndex = 2})
                local dList = Create("Frame", {Parent = ScreenGui, BackgroundColor3 = C.DrpOuter, BorderSizePixel = 0, Visible = false, ZIndex = 150, ClipsDescendants = true})
                local dScroll = Create("ScrollingFrame", {Parent = dList, BackgroundColor3 = C.DrpBg, BorderSizePixel = 0, Position = UDim2.new(0, 1, 0, 1), Size = UDim2.new(1, -2, 1, -2), ZIndex = 151, ClipsDescendants = true, ScrollBarThickness = 2, ScrollBarImageColor3 = C.GroupInner, AutomaticCanvasSize = Enum.AutomaticSize.Y, ScrollingDirection = Enum.ScrollingDirection.Y})
