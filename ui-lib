                local dropOuterBox = Create("Frame", {Parent = dropFrame, BackgroundColor3 = C.DrpOuter, BorderSizePixel = 0, Position = UDim2.new(0, 0, 0, 15), Size = UDim2.new(1, 0, 0, 18)})
