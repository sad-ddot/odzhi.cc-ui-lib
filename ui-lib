        Font = Library.Font,
        TextSize = 13,
        BackgroundTransparency = 1,
        Size = UDim2.new(1, -90, 1, 0),
        TextXAlignment = Enum.TextXAlignment.Left,
        Parent = Holder,
    })
    Library:_Bind(Label, "TextColor3", "Text")

    local KeyBtn = Util.Create("TextButton", {
        Text = default.Name,
        Font = Library.Font,
        TextSize = 12,
        BorderSizePixel = 0,
        Size = UDim2.new(0, 80, 0, 24),
        Position = UDim2.new(1, -80, 0.5, -12),
        AutoButtonColor = false,
        Parent = Holder,
    }, { Util.Corner(5) })
    Library:_Bind(KeyBtn, "BackgroundColor3", "Field")
    Library:_Bind(KeyBtn, "TextColor3", "Text")
    local keyStroke = Util.Stroke()
    keyStroke.Parent = KeyBtn
    Library:_Bind(keyStroke, "Color", "Border")
    Util.Hover(KeyBtn, function() return Library.Theme.Field end, function() return Library.Theme.PanelHover end)

    local currentKey = default
    local listening = false

    KeyBtn.MouseButton1Click:Connect(function()
        listening = true
        KeyBtn.Text = "..."
    end)

    UserInputService.InputBegan:Connect(function(input, gpe)
        if listening and input.UserInputType == Enum.UserInputType.Keyboard then
            currentKey = input.KeyCode
            KeyBtn.Text = currentKey.Name
            listening = false
            if flag then Library.Flags[flag] = currentKey end
            if onBind then pcall(onBind, currentKey) end
            return
        end
        if not gpe and input.KeyCode == currentKey and currentKey ~= Enum.KeyCode.Unknown then
            local ok, err = pcall(callback)
            if not ok then warn("[UILib] Keybind callback error: " .. tostring(err)) end
        end
    end)

    local function setKey(v)
        currentKey = v
        KeyBtn.Text = v.Name
        if flag then Library.Flags[flag] = currentKey end
    end

    if flag then
        Library.FlagObjects[flag] = { Set = setKey }
        Library.Flags[flag] = default
    end

    return { Set = setKey, Get = function() return currentKey end }
end

