local function Cr(cls, p)
    local i = Instance.new(cls)
    for k,v in pairs(p) do if k ~= "Parent" then i[k]=v end end
    if p.Parent then i.Parent=p.Parent end
    return i
end

local function Tw(o,p,d)
    local t = TweenService:Create(o,TweenInfo.new(d or 0.12,Enum.EasingStyle.Quad,Enum.EasingDirection.Out),p)
    t:Play() return t
end

local function SaveCfg(n)
    local d={}
    for k,v in pairs(ConfigState) do
        if typeof(v)=="Color3" then d[k]={T="C3",R=v.R,G=v.G,B=v.B}
        elseif typeof(v)=="EnumItem" then d[k]={T="EI",V=tostring(v)}
        else d[k]=v end
    end
    if not isfolder(ConfigFolder) then makefolder(ConfigFolder) end
    writefile(ConfigFolder.."/"..n..".json",HttpService:JSONEncode(d))
end

local function LoadCfg(n)
    local p=ConfigFolder.."/"..n..".json"
    if not isfile(p) then return false end
    local d=HttpService:JSONDecode(readfile(p))
    for k,v in pairs(d) do
        if type(v)=="table" and v.T=="C3" then ConfigState[k]=Color3.new(v.R,v.G,v.B)
        else ConfigState[k]=v end
        if ConfigCallbacks[k] then ConfigCallbacks[k](ConfigState[k]) end
    end
    return true
end

local function CloseAllColorPickers()
    for _,cp in pairs(AllColorPickers) do
        if cp.Panel and cp.Panel.Visible then
            cp.Panel.Visible = false
            cp.Open = false
        end
    end
end

local function UpdateKeybindList()
    if not KeybindListBg then return end
    for _,c in pairs(KeybindListBg:GetChildren()) do
        if c:IsA("Frame") and c.Name ~= "Header" then c:Destroy() end
    end
    local count = 0
    for name, data in pairs(ActiveKeybinds) do
        if data.Active then
            count = count + 1
            local row = Cr("Frame",{Name="KB_"..name, Parent=KeybindListBg, BackgroundTransparency=1, Size=UDim2.new(1,0,0,14), LayoutOrder=count+1})
            Cr("TextLabel",{Parent=row, BackgroundTransparency=1, Position=UDim2.new(0,6,0,0), Size=UDim2.new(0.6,-6,1,0), Font=Enum.Font.SourceSans, Text=name, TextColor3=C.TextDim, TextSize=12, TextXAlignment=Enum.TextXAlignment.Left})
            Cr("TextLabel",{Parent=row, BackgroundTransparency=1, Position=UDim2.new(0.6,0,0,0), Size=UDim2.new(0.4,-4,1,0), Font=Enum.Font.SourceSans, Text="["..data.Mode.."]", TextColor3=C.TextDark, TextSize=11, TextXAlignment=Enum.TextXAlignment.Right})
        end
    end
    local totalH = 18 + count * 14
    if count == 0 then totalH = 18 end
    KeybindListFrame.Size = UDim2.new(0,160,0,totalH+4)
end

local function MakeDraggable(frame, handle)
    local dragging, dragStart, startPos = false, nil, nil
    handle.InputBegan:Connect(function(inp)
        if inp.UserInputType==Enum.UserInputType.MouseButton1 then
            dragging=true dragStart=inp.Position startPos=frame.Position
            inp.Changed:Connect(function() if inp.UserInputState==Enum.UserInputState.End then dragging=false end end)
        end
    end)
    UserInputService.InputChanged:Connect(function(inp)
        if dragging and inp.UserInputType==Enum.UserInputType.MouseMovement then
            local d=inp.Position-dragStart
            frame.Position=UDim2.new(startPos.X.Scale,startPos.X.Offset+d.X,startPos.Y.Scale,startPos.Y.Offset+d.Y)
        end
    end)
end

function GamesenseLib:Notify(opts)
    if not ScreenGui then return end
    local txt=opts.Text or "" local dur=opts.Duration or 3

    local nc = ScreenGui:FindFirstChild("NotifContainer")
    if not nc then
        nc = Cr("Frame",{Name="NotifContainer",Parent=ScreenGui,BackgroundTransparency=1,Position=UDim2.new(1,-310,0,10),Size=UDim2.new(0,300,1,-20),ZIndex=300})
        Cr("UIListLayout",{Parent=nc,FillDirection=Enum.FillDirection.Vertical,VerticalAlignment=Enum.VerticalAlignment.Bottom,SortOrder=Enum.SortOrder.LayoutOrder,Padding=UDim.new(0,3)})
    end

    local nOuter = Cr("Frame",{Parent=nc,BackgroundColor3=C.WmBorder,BorderSizePixel=0,Size=UDim2.new(1,0,0,30),BackgroundTransparency=1,ZIndex=301})
    local nInner = Cr("Frame",{Parent=nOuter,BackgroundColor3=C.WmInner,BorderSizePixel=0,Position=UDim2.new(0,1,0,1),Size=UDim2.new(1,-2,1,-2),BackgroundTransparency=1,ZIndex=302})
    local nAcc = Cr("Frame",{Parent=nInner,BackgroundColor3=C.Accent,BorderSizePixel=0,Size=UDim2.new(1,0,0,2),BackgroundTransparency=1,ZIndex=304})
    local nBdr2 = Cr("Frame",{Parent=nInner,BackgroundColor3=C.WmBorder,BorderSizePixel=0,Position=UDim2.new(0,1,0,2),Size=UDim2.new(1,-2,1,-3),BackgroundTransparency=1,ZIndex=303})
    local nBg = Cr("Frame",{Parent=nBdr2,BackgroundColor3=C.WmBg,BorderSizePixel=0,Position=UDim2.new(0,1,0,1),Size=UDim2.new(1,-2,1,-2),BackgroundTransparency=1,ZIndex=304})
    local nLbl = Cr("TextLabel",{Parent=nBg,BackgroundTransparency=1,Position=UDim2.new(0,8,0,0),Size=UDim2.new(1,-16,1,0),Font=Enum.Font.SourceSans,Text=txt,TextColor3=C.TextDim,TextSize=12,TextXAlignment=Enum.TextXAlignment.Left,TextTransparency=1,ZIndex=305})

    Tw(nOuter,{BackgroundTransparency=0},0.2)
    Tw(nInner,{BackgroundTransparency=0},0.2)
    Tw(nAcc,{BackgroundTransparency=0},0.2)
    Tw(nBdr2,{BackgroundTransparency=0},0.2)
    Tw(nBg,{BackgroundTransparency=0},0.2)
    Tw(nLbl,{TextTransparency=0},0.25)

    task.delay(dur, function()
        Tw(nOuter,{BackgroundTransparency=1},0.3)
        Tw(nInner,{BackgroundTransparency=1},0.3)
        Tw(nAcc,{BackgroundTransparency=1},0.3)
        Tw(nBdr2,{BackgroundTransparency=1},0.3)
        Tw(nBg,{BackgroundTransparency=1},0.3)
        Tw(nLbl,{TextTransparency=1},0.3)
        task.wait(0.35) nOuter:Destroy()
    end)
end

