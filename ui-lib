                })

                MBBox.FocusLost:Connect(function(enter)
                    currentText = MBBox.Text
                    ConfigState[mFlag] = currentText
                    mCallback(currentText, enter)
                end)

                ConfigCallbacks[mFlag] = function(val) currentText = val MBBox.Text = val mCallback(val) end

                local obj = {}
                function obj:Set(v) currentText = v MBBox.Text = v ConfigState[mFlag] = v mCallback(v) end
                function obj:Get() return currentText end
                return obj
            end

            function Sector:AddLabel(lOpts)
                local lText = lOpts.Text or "Label"

                Sector.ElementCount = Sector.ElementCount + 1

                local Frame = Create("Frame", {
                    Parent = SectorContent,
                    BackgroundTransparency = 1,
                    Size = UDim2.new(1, 0, 0, 14),
                    LayoutOrder = Sector.ElementCount,
                })

                local LabelObj = Create("TextLabel", {
                    Parent = Frame,
                    BackgroundTransparency = 1,
                    Size = UDim2.new(1, 0, 1, 0),
                    Font = Enum.Font.SourceSans,
                    Text = lText,
                    TextColor3 = Colors.TextDark,
                    TextSize = 13,
                    TextXAlignment = Enum.TextXAlignment.Left,
                })

                local obj = {}
                function obj:SetText(t) LabelObj.Text = t end
                return obj
            end

            function Sector:AddSeparator()
                Sector.ElementCount = Sector.ElementCount + 1
                local Sep = Create("Frame", {
                    Parent = SectorContent,
                    BackgroundColor3 = Colors.GroupBorder,
                    BorderSizePixel = 0,
                    Size = UDim2.new(1, 0, 0, 1),
                    LayoutOrder = Sector.ElementCount,
                })
                return Sep
            end

            return Sector
        end

        return Tab
    end

    UserInputService.InputBegan:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 then
            if ActiveDropdown and ActiveDropdown.Visible then
                local absPos = ActiveDropdown.AbsolutePosition
                local absSize = ActiveDropdown.AbsoluteSize
                local mousePos = UserInputService:GetMouseLocation()
                if mousePos.X < absPos.X or mousePos.X > absPos.X + absSize.X or mousePos.Y < absPos.Y or mousePos.Y > absPos.Y + absSize.Y then
                    ActiveDropdown.Visible = false
                    ActiveDropdown = nil
                end
            end
        end
    end)

    return Window
end

return GamesenseLib
