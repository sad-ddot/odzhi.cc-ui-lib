                local function RefreshItems()
                    for _, c in pairs(DropListInner:GetChildren()) do
                        if c:IsA("TextButton") then c:Destroy() end
                    end
                    for idx, item in ipairs(dItems) do
                        local isSel = dMulti and (selectedValue[item] == true) or (selectedValue == item)
                        local ItemBtn = Create("TextButton", {
