function Section:AddDropdown(cfg)
    cfg = cfg or {}
    local options = cfg.Options or {}
    local flag = cfg.Flag
    local callback = cfg.Callback or function() end
    local value = cfg.Default or options[1]

    local Holder, Box, Selected, Arrow = BuildDropdownShell(self, cfg, function()
        return tostring(value or "Select...")
    end)

    local ListFrame, Scroller = BuildFloatingList(#options)
    ListFrame.Parent = Box
    ListFrame.Position = UDim2.new(0, 0, 1, 4)

    local function rebuildOptions(newOptions)
        for _, c in ipairs(Scroller:GetChildren()) do
            if c:IsA("TextButton") then c:Destroy() end
        end
        for _, opt in ipairs(newOptions) do
            local OptBtn = Util.Create("TextButton", {
                Text = tostring(opt),
                Font = Library.Font,
                TextSize = 12,
                TextXAlignment = Enum.TextXAlignment.Left,
                BorderSizePixel = 0,
                Size = UDim2.new(1, 0, 0, 24),
                ZIndex = 101,
                AutoButtonColor = false,
                Parent = Scroller,
            }, { Util.Corner(4), Util.Pad(0, 0, 8, 8) })
            Library:_Bind(OptBtn, "BackgroundColor3", "Field")
            Library:_Bind(OptBtn, "TextColor3", "Text")
            Util.Hover(OptBtn, function() return Library.Theme.Field end, function() return Library.Theme.PanelHover end)

            OptBtn.MouseButton1Click:Connect(function()
                value = opt
                Selected.Text = tostring(opt)
                Library:_CloseOpenPopup()
                local ok, err = pcall(callback, value)
                if not ok then warn("[UILib] Dropdown callback error: " .. tostring(err)) end
                if flag then Library.Flags[flag] = value end
            end)
        end
    end

    rebuildOptions(options)

    Box.MouseButton1Click:Connect(function()
        if ListFrame.Visible then
            Library:_CloseOpenPopup()
        else
            OpenFloatingList(Box, ListFrame, Arrow)
        end
    end)

    local function setValue(v)
        value = v
        Selected.Text = tostring(v)
        local ok, err = pcall(callback, value)
        if not ok then warn("[UILib] Dropdown callback error: " .. tostring(err)) end
        if flag then Library.Flags[flag] = value end
    end

    if flag then
        Library.FlagObjects[flag] = { Set = setValue }
        Library.Flags[flag] = value
    end

    return {
        Set = setValue,
        Get = function() return value end,
        Refresh = function(_, newOptions)
            options = newOptions
            rebuildOptions(newOptions)
        end,
    }
end

function Section:AddMultiDropdown(cfg)
    cfg = cfg or {}
    local options = cfg.Options or {}
    local flag = cfg.Flag
    local callback = cfg.Callback or function() end

    local selected = {}
    local order = {}
    if cfg.Default then
        for _, v in ipairs(cfg.Default) do
            if not selected[v] then
                selected[v] = true
                table.insert(order, v)
            end
        end
    end

    local function summaryText()
        if #order == 0 then return "None selected" end
        return table.concat(order, ", ")
    end

    local Holder, Box, Selected, Arrow = BuildDropdownShell(self, cfg, summaryText)

    local ListFrame, Scroller = BuildFloatingList(#options)
    ListFrame.Parent = Box
    ListFrame.Position = UDim2.new(0, 0, 1, 4)

    local optionRows = {}

    local function fireChange()
        Selected.Text = summaryText()
        local ok, err = pcall(callback, order)
        if not ok then warn("[UILib] MultiDropdown callback error: " .. tostring(err)) end
        if flag then Library.Flags[flag] = order end
    end

    local function toggleOption(opt, checkFrame)
        local value = not selected[opt]
        if value then
            selected[opt] = true
            table.insert(order, opt)
        else
            selected[opt] = nil
            for i, v in ipairs(order) do
                if v == opt then table.remove(order, i) break end
            end
        end
        checkFrame.BackgroundColor3 = value and Library.Theme.Accent or Library.Theme.Field
        checkFrame.Visible = true
    end

    local function rebuildOptions(newOptions)
        for _, c in ipairs(Scroller:GetChildren()) do
            if c:IsA("TextButton") then c:Destroy() end
        end
        optionRows = {}

        for _, opt in ipairs(newOptions) do
            local OptBtn = Util.Create("TextButton", {
                Text = "",
                BorderSizePixel = 0,
                Size = UDim2.new(1, 0, 0, 24),
                ZIndex = 101,
                AutoButtonColor = false,
                Parent = Scroller,
            }, { Util.Corner(4) })
            Library:_Bind(OptBtn, "BackgroundColor3", "Field")
            Util.Hover(OptBtn, function() return Library.Theme.Field end, function() return Library.Theme.PanelHover end)

            local CheckFrame = Util.Create("Frame", {
                Size = UDim2.new(0, 14, 0, 14),
                Position = UDim2.new(0, 8, 0.5, -7),
                BackgroundColor3 = selected[opt] and Library.Theme.Accent or Library.Theme.Field,
                BorderSizePixel = 0,
                ZIndex = 102,
                Parent = OptBtn,
            }, { Util.Corner(3) })
            local checkStroke = Util.Stroke()
            checkStroke.ZIndex = 102
            checkStroke.Parent = CheckFrame
            Library:_Bind(checkStroke, "Color", "Border")

            local OptLabel = Util.Create("TextLabel", {
                Text = tostring(opt),
                Font = Library.Font,
                TextSize = 12,
                BackgroundTransparency = 1,
                Size = UDim2.new(1, -32, 1, 0),
                Position = UDim2.new(0, 28, 0, 0),
                TextXAlignment = Enum.TextXAlignment.Left,
                ZIndex = 101,
                Parent = OptBtn,
            })
            Library:_Bind(OptLabel, "TextColor3", "Text")

            optionRows[opt] = CheckFrame

            OptBtn.MouseButton1Click:Connect(function()
                toggleOption(opt, CheckFrame)
                fireChange()
            end)
        end
    end

    rebuildOptions(options)

    Box.MouseButton1Click:Connect(function()
        if ListFrame.Visible then
            Library:_CloseOpenPopup()
        else
            OpenFloatingList(Box, ListFrame, Arrow)
        end
    end)

    local function setValues(values)
        selected = {}
        order = {}
        for _, v in ipairs(values) do
            if not selected[v] then
                selected[v] = true
                table.insert(order, v)
            end
        end
        for opt, checkFrame in pairs(optionRows) do
            checkFrame.BackgroundColor3 = selected[opt] and Library.Theme.Accent or Library.Theme.Field
        end
        Selected.Text = summaryText()
        if flag then Library.Flags[flag] = order end
    end

    if flag then
        Library.FlagObjects[flag] = { Set = setValues }
        Library.Flags[flag] = order
    end

    return {
        Set = setValues,
        Get = function() return order end,
        Refresh = function(_, newOptions)
            options = newOptions
            rebuildOptions(newOptions)
        end,
    }
end

function Section:AddColorPicker(cfg)
    cfg = cfg or {}
    local palette = cfg.Palette or Library.AccentPalette
    local default = cfg.Default or palette[1]
    local flag = cfg.Flag
    local callback = cfg.Callback or function() end

    local Holder = Util.Create("Frame", {
        Size = UDim2.new(1, 0, 0, 26),
        BackgroundTransparency = 1,
        Parent = self.ElementsHolder,
    })

    local Label = Util.Create("TextLabel", {
        Text = cfg.Text or "Color",
        Font = Library.Font,
        TextSize = 13,
        BackgroundTransparency = 1,
        Size = UDim2.new(1, -50, 1, 0),
        TextXAlignment = Enum.TextXAlignment.Left,
        Parent = Holder,
    })
    Library:_Bind(Label, "TextColor3", "Text")

    local Swatch = Util.Create("TextButton", {
        Text = "",
        Size = UDim2.new(0, 38, 0, 20),
        Position = UDim2.new(1, -38, 0.5, -10),
        BackgroundColor3 = default,
        BorderSizePixel = 0,
        AutoButtonColor = false,
        Parent = Holder,
    }, { Util.Corner(5) })
    local swatchStroke = Util.Stroke()
    swatchStroke.Parent = Swatch
    Library:_Bind(swatchStroke, "Color", "Border")

    local color = default

    local perRow = 6
    local rows = math.ceil(#palette / perRow)
    local Popup = Util.Create("Frame", {
        Size = UDim2.new(0, perRow * 28 + 12, 0, rows * 28 + 12),
        BorderSizePixel = 0,
        Visible = false,
        ZIndex = 100,
        Parent = Holder,
    }, { Util.Corner(6), Util.Pad(6, 6, 6, 6) })
    Library:_Bind(Popup, "BackgroundColor3", "Panel")
    local popupStroke = Util.Stroke()
    popupStroke.Thickness = 1.2
    popupStroke.ZIndex = 100
    popupStroke.Parent = Popup
    Library:_Bind(popupStroke, "Color", "Border")

    Util.Create("UIGridLayout", {
        CellSize = UDim2.fromOffset(24, 24),
        CellPadding = UDim2.fromOffset(4, 4),
        SortOrder = Enum.SortOrder.LayoutOrder,
        Parent = Popup,
    })

    local swatchButtons = {}

    local function updateSwatch()
        Swatch.BackgroundColor3 = color
        for _, entry in ipairs(swatchButtons) do
            entry.ring.Visible = (entry.color == color)
        end
    end

    for _, preset in ipairs(palette) do
        local PresetBtn = Util.Create("TextButton", {
            Text = "",
            BackgroundColor3 = preset,
            BorderSizePixel = 0,
            AutoButtonColor = false,
            ZIndex = 101,
            Parent = Popup,
        }, { Util.Corner(4) })

        local Ring = Util.Create("UIStroke", {
            Color = Color3.new(1, 1, 1),
            Thickness = 2,
            Visible = (preset == color),
        })
        Ring.Parent = PresetBtn

        table.insert(swatchButtons, { color = preset, ring = Ring })

        PresetBtn.MouseButton1Click:Connect(function()
            color = preset
            updateSwatch()
            Library:_CloseOpenPopup()
            local ok, err = pcall(callback, color)
            if not ok then warn("[UILib] ColorPicker callback error: " .. tostring(err)) end
            if flag then Library.Flags[flag] = color end
        end)
    end

    Swatch.MouseButton1Click:Connect(function()
        if Popup.Visible then
            Library:_CloseOpenPopup()
        else
            Popup.Parent = Library.Overlay
            Popup.Position = UDim2.fromOffset(
                Swatch.AbsolutePosition.X + Swatch.AbsoluteSize.X - Popup.Size.X.Offset,
                Swatch.AbsolutePosition.Y + Swatch.AbsoluteSize.Y + 4
            )
            Popup.Visible = true
            Library:_OpenPopup(Popup, function()
                Popup.Visible = false
                Popup.Parent = Holder
            end)
        end
    end)

    local function setColor(v)
        color = v
        updateSwatch()
        if flag then Library.Flags[flag] = color end
    end

    if flag then
        Library.FlagObjects[flag] = { Set = setColor }
        Library.Flags[flag] = color
    end

    return { Set = setColor, Get = function() return color end }
end

