        local function SpawnJumpRing(position)
            EmitJumpSparks(position)
            local part, decal, light = BuildRingPart(position, JumpCfg.START_SCALE)
            local currentScale = JumpCfg.START_SCALE
            local currentAngle = math.random(0, 360)
            local timeElapsed = 0
            local reverseTimer = 0
            local hasReversed = false
            local conn
            conn = RunService.RenderStepped:Connect(function(dt)
                if not part or not part.Parent then
                    conn:Disconnect()
                    return
                end
                timeElapsed = timeElapsed + dt
                if timeElapsed >= JumpCfg.LIFETIME then
                    conn:Disconnect()
                    part:Destroy()
                    return
                end
                local progress = timeElapsed / JumpCfg.LIFETIME
                local sizeFactor = math.sin(progress * math.pi)
                currentScale = JumpCfg.START_SCALE + (JumpCfg.MAX_SCALE - JumpCfg.START_SCALE) * sizeFactor
                local rotSpeed = JumpCfg.BASE_ROT_SPEED
                if timeElapsed >= JumpCfg.REVERSE_START then
                    if not hasReversed then hasReversed = true end
                    reverseTimer = reverseTimer + dt
                    local reverseDuration = JumpCfg.LIFETIME - JumpCfg.REVERSE_START
                    local reverseProgress = math.clamp(reverseTimer / reverseDuration, 0, 1)
                    local speedModifier = math.cos(reverseProgress * math.pi)
                    rotSpeed = JumpCfg.BASE_ROT_SPEED * speedModifier
                end
                currentAngle = (currentAngle + (dt * rotSpeed)) % 360
                part.Orientation = Vector3.new(0, currentAngle, 0)
                part.Size = Vector3.new(currentScale, 0.05, currentScale)
                -- Smooth light fade in/out (sin envelope, never instant)
