        return btn
    end

    local CreateBtn = makeActionBtn(ButtonsRow1, "Create")
    local DeleteBtn = makeActionBtn(ButtonsRow1, "Delete")

    local ButtonsRow2 = Util.Create("Frame", {
        Size = UDim2.new(1, 0, 0, 28),
        BackgroundTransparency = 1,
        Parent = ConfigsSub.Page,
    }, {
        Util.Create("UIListLayout", {
            FillDirection = Enum.FillDirection.Horizontal,
            Padding = UDim.new(0, 8),
            SortOrder = Enum.SortOrder.LayoutOrder,
        }),
    })

    local LoadBtn = makeActionBtn(ButtonsRow2, "Load")
    local SaveBtn = makeActionBtn(ButtonsRow2, "Save")

    local selectedConfig = nil

    local function refreshList(filter)
        for _, c in ipairs(ListScroll:GetChildren()) do
            if c:IsA("TextButton") then c:Destroy() end
        end
        if not (isfolder and listfiles) then return end
        if not isfolder(folder) then return end
        for _, path in ipairs(listfiles(folder)) do
            local name = path:match("([^/\\]+)%.json$")
            if name and (not filter or filter == "" or name:lower():find(filter:lower(), 1, true)) then
                local Item = Util.Create("TextButton", {
                    Text = name,
                    Font = Library.Font,
                    TextSize = 12,
                    BorderSizePixel = 0,
                    Size = UDim2.new(1, 0, 0, 24),
                    AutoButtonColor = false,
                    Parent = ListScroll,
                }, { Util.Corner(4) })
                Library:_Bind(Item, "BackgroundColor3", "Panel")
                Library:_Bind(Item, "TextColor3", "Text")
                Util.Hover(Item, function() return Library.Theme.Panel end, function() return Library.Theme.PanelHover end)

                Item.MouseButton1Click:Connect(function()
                    selectedConfig = name
                    NameInput.Text = name
                    for _, c2 in ipairs(ListScroll:GetChildren()) do
                        if c2:IsA("TextButton") then c2.BackgroundColor3 = Library.Theme.Panel end
                    end
                    Item.BackgroundColor3 = Library.Theme.PanelHover
                end)
            end
        end
    end

    SearchInput:GetPropertyChangedSignal("Text"):Connect(function()
        refreshList(SearchInput.Text)
    end)

    local function encodeFlagValue(val)
        if typeof(val) == "EnumItem" then
            return { __enum = tostring(val.EnumType), __name = val.Name }
        elseif typeof(val) == "Color3" then
            return { __color3 = true, r = val.R, g = val.G, b = val.B }
        else
            return val
        end
    end

    local function decodeFlagValue(val)
        if typeof(val) == "table" and val.__enum then
            local ok, enumVal = pcall(function()
                return Enum[val.__enum:gsub("Enum%.", "")][val.__name]
            end)
            return ok and enumVal or nil
        elseif typeof(val) == "table" and val.__color3 then
            return Color3.new(val.r, val.g, val.b)
        else
            return val
        end
    end

    local function saveConfig(name)
        if not (writefile and isfolder and makefolder) then
            Library:_Notify("Executor doesn't support file saving")
            return
        end
        if not isfolder(folder) then makefolder(folder) end
        local data = {}
        for flagName, val in pairs(Library.Flags) do
            data[flagName] = encodeFlagValue(val)
        end
        local ok, encoded = pcall(HttpService.JSONEncode, HttpService, data)
        if ok then
            writefile(folder .. "/" .. name .. ".json", encoded)
            Library:_Notify("Config saved: " .. name)
            refreshList(SearchInput.Text)
        else
            Library:_Notify("Failed to encode config")
        end
    end

    local function loadConfig(name)
        if not (readfile and isfile) then
            Library:_Notify("Executor doesn't support file loading")
            return
        end
        local path = folder .. "/" .. name .. ".json"
        if not isfile(path) then
            Library:_Notify("Config not found")
            return
        end
        local ok, decoded = pcall(function()
            return HttpService:JSONDecode(readfile(path))
        end)
        if not ok then
            Library:_Notify("Failed to decode config")
            return
        end
        for flagName, val in pairs(decoded) do
            local obj = Library.FlagObjects[flagName]
            if obj then
                local decodedVal = decodeFlagValue(val)
                if decodedVal ~= nil then obj.Set(decodedVal) end
            end
        end
        Library:_Notify("Config loaded: " .. name)
    end

    CreateBtn.MouseButton1Click:Connect(function()
        local name = NameInput.Text
        if name == "" then
            Library:_Notify("Enter a config name first")
            return
        end
        saveConfig(name)
    end)

    SaveBtn.MouseButton1Click:Connect(function()
        local name = selectedConfig or NameInput.Text
        if name == "" then
            Library:_Notify("Enter a config name first")
            return
        end
        saveConfig(name)
    end)

    LoadBtn.MouseButton1Click:Connect(function()
        local name = selectedConfig or NameInput.Text
        if not name or name == "" then
            Library:_Notify("Select a config first")
            return
        end
        loadConfig(name)
    end)

    DeleteBtn.MouseButton1Click:Connect(function()
        local name = selectedConfig or NameInput.Text
        if not name or name == "" then
            Library:_Notify("Select a config first")
            return
        end
        if delfile and isfile and isfile(folder .. "/" .. name .. ".json") then
            delfile(folder .. "/" .. name .. ".json")
            Library:_Notify("Config deleted: " .. name)
            refreshList(SearchInput.Text)
        end
    end)

    refreshList()

    Util.Create("TextLabel", {
        Text = "Settings",
        Font = Library.FontBold,
        TextSize = 14,
        BackgroundTransparency = 1,
        Size = UDim2.new(1, 0, 0, 20),
