local function SaveConfig(configName)
    local saveData = {}

    for key, value in pairs(ConfigState) do
        if typeof(value) == "Color3" then
            saveData[key] = {
                Type = "Color3",
                R = value.R,
                G = value.G,
                B = value.B,
            }
        elseif typeof(value) == "EnumItem" then
            saveData[key] = {
                Type = "EnumItem",
                Value = tostring(value),
            }
        elseif type(value) == "table" then
            saveData[key] = {
                Type = "Table",
                Value = value,
            }
        else
            saveData[key] = value
        end
    end

    if not isfolder(ConfigFolder) then
        makefolder(ConfigFolder)
    end

    writefile(ConfigFolder .. "/" .. configName .. ".json", HttpService:JSONEncode(saveData))
end

local function LoadConfig(configName)
    local configPath = ConfigFolder .. "/" .. configName .. ".json"

    if not isfile(configPath) then
        return false
    end

    local rawData = readfile(configPath)
    local parsedData = HttpService:JSONDecode(rawData)

    for key, value in pairs(parsedData) do
        if type(value) == "table" then
            if value.Type == "Color3" then
                ConfigState[key] = Color3.new(value.R, value.G, value.B)
            elseif value.Type == "Table" then
                ConfigState[key] = value.Value
            else
                ConfigState[key] = value
            end
        else
            ConfigState[key] = value
        end

        if ConfigCallbacks[key] then
            ConfigCallbacks[key](ConfigState[key])
        end
    end

    return true
end

local function GetConfigList()
    local configs = {}
    if not isfolder(ConfigFolder) then
        return configs
    end
    for _, file in pairs(listfiles(ConfigFolder)) do
        local name = file:match("([^/\\]+)%.json$")
        if name then
            table.insert(configs, name)
        end
    end
    return configs
end

local function ColorToHex(color)
    return string.format(
        "#%02X%02X%02X",
        math.floor(color.R * 255 + 0.5),
        math.floor(color.G * 255 + 0.5),
        math.floor(color.B * 255 + 0.5)
    )
end

local function HexToColor(hexString)
    hexString = hexString:gsub("#", "")
    if #hexString ~= 6 then
        return nil
    end
    local r = tonumber(hexString:sub(1, 2), 16)
    local g = tonumber(hexString:sub(3, 4), 16)
    local b = tonumber(hexString:sub(5, 6), 16)
    if r and g and b then
        return Color3.fromRGB(r, g, b)
    end
    return nil
end

