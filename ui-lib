                local obj = {} function obj:Set(c) col = c cH, cS, cV = Color3.toHSV(c) ConfigState[fl] = c updC() end function obj:Get() return col end return obj
            end

            function S:AddKeybind(o) S.EC = S.EC + 1 local nm = o.Name or "Keybind" local def = o.Default or Enum.KeyCode.Unknown local fl = o.Flag or nm local cb = o.Callback or function() end local mode = o.Mode or "Toggle" local cur = def local listening = false local active = false ConfigState[fl] = cur.Name
                local f = Create("Frame", {Parent = sCont, BackgroundTransparency = 1, Size = UDim2.new(1, 0, 0, 15), LayoutOrder = S.EC})
                Create("TextLabel", {Parent = f, BackgroundTransparency = 1, Size = UDim2.new(1, -50, 1, 0), Font = Enum.Font.SourceSans, Text = nm, TextColor3 = C.TextDim, TextSize = 13, TextXAlignment = Enum.TextXAlignment.Left})
                local kO = Create("Frame", {Parent = f, BackgroundColor3 = C.DrpOuter, BorderSizePixel = 0, Position = UDim2.new(1, -48, 0, 2), Size = UDim2.new(0, 48, 0, 12)})
                local kB = Create("TextButton", {Parent = kO, BackgroundColor3 = C.DrpBg, BorderSizePixel = 0, Position = UDim2.new(0, 1, 0, 1), Size = UDim2.new(1, -2, 1, -2), Font = Enum.Font.SourceSans, Text = cur == Enum.KeyCode.Unknown and "[-]" or "[" .. cur.Name .. "]", TextColor3 = C.TextDark, TextSize = 10, AutoButtonColor = false, ZIndex = 6})
                local function updKB() if cur ~= Enum.KeyCode.Unknown then ActiveKeybinds[nm] = {Active = active, Mode = mode, Key = cur} else ActiveKeybinds[nm] = nil end UpdateKBList() end
                kB.MouseButton1Click:Connect(function() if listening then return end listening = true kB.Text = "[...]" kB.TextColor3 = C.TextDim end)
                UserInputService.InputBegan:Connect(function(inp, gpe) if listening then if inp.UserInputType == Enum.UserInputType.Keyboard then if inp.KeyCode == Enum.KeyCode.Escape then cur = Enum.KeyCode.Unknown kB.Text = "[-]" else cur = inp.KeyCode kB.Text = "[" .. cur.Name .. "]" end ConfigState[fl] = cur.Name listening = false kB.TextColor3 = C.TextDark active = false updKB() return end if inp.UserInputType == Enum.UserInputType.MouseButton1 or inp.UserInputType == Enum.UserInputType.MouseButton2 then listening = false kB.Text = cur == Enum.KeyCode.Unknown and "[-]" or "[" .. cur.Name .. "]" kB.TextColor3 = C.TextDark return end end if not listening and not gpe and inp.UserInputType == Enum.UserInputType.Keyboard and inp.KeyCode == cur and cur ~= Enum.KeyCode.Unknown then if mode == "Toggle" then active = not active else active = true end updKB() cb(cur) end end)
                if mode == "Hold" then UserInputService.InputEnded:Connect(function(inp) if not listening and inp.UserInputType == Enum.UserInputType.Keyboard and inp.KeyCode == cur and cur ~= Enum.KeyCode.Unknown then active = false updKB() end end) end
                ConfigCallbacks[fl] = function(v) local s, k = pcall(function() return Enum.KeyCode[v] end) if s and k then cur = k kB.Text = cur == Enum.KeyCode.Unknown and "[-]" or "[" .. cur.Name .. "]" end end
                local obj = {} function obj:Set(k) cur = k ConfigState[fl] = k.Name kB.Text = k == Enum.KeyCode.Unknown and "[-]" or "[" .. k.Name .. "]" updKB() end function obj:Get() return cur end return obj
            end

            function S:AddTextbox(o) S.EC = S.EC + 1 local nm = o.Name or "Textbox" local def = o.Default or "" local ph = o.Placeholder or "" local fl = o.Flag or nm local cb = o.Callback or function() end local cur = def ConfigState[fl] = cur
