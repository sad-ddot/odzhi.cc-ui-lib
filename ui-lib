local function Create(className, properties)
    local inst = Instance.new(className)
    for k, v in pairs(properties) do
        if k ~= "Parent" then
            inst[k] = v
        end
    end
    if properties.Parent then
        inst.Parent = properties.Parent
    end
    return inst
end

local function Tween(obj, props, duration, style, direction)
    local info = TweenInfo.new(duration or 0.15, style or Enum.EasingStyle.Quad, direction or Enum.EasingDirection.Out)
    local tw = TweenService:Create(obj, info, props)
    tw:Play()
    return tw
end

local function RippleClean(parent)
    for _, v in pairs(parent:GetChildren()) do
        if v.Name == "Ripple" then
            v:Destroy()
        end
    end
end

local function DeepCopy(t)
    if type(t) ~= "table" then return t end
    local copy = {}
    for k, v in pairs(t) do
        copy[k] = DeepCopy(v)
    end
    return copy
end

local function SaveConfig(name)
    local data = {}
    for key, val in pairs(ConfigState) do
        if type(val) == "table" and val.Color then
            data[key] = {Type = "Color3", R = val.Color.R, G = val.Color.G, B = val.Color.B}
        elseif typeof(val) == "Color3" then
            data[key] = {Type = "Color3", R = val.R, G = val.G, B = val.B}
        elseif typeof(val) == "EnumItem" then
            data[key] = {Type = "Enum", Value = tostring(val)}
        else
            data[key] = val
        end
    end
    local json = HttpService:JSONEncode(data)
    if not isfolder(ConfigFolder) then
        makefolder(ConfigFolder)
    end
    writefile(ConfigFolder .. "/" .. name .. ".json", json)
end

local function LoadConfig(name)
    local path = ConfigFolder .. "/" .. name .. ".json"
    if not isfile(path) then return false end
    local json = readfile(path)
    local data = HttpService:JSONDecode(json)
    for key, val in pairs(data) do
        if type(val) == "table" and val.Type == "Color3" then
            ConfigState[key] = Color3.new(val.R, val.G, val.B)
            if ConfigCallbacks[key] then
                ConfigCallbacks[key](ConfigState[key])
            end
        else
            ConfigState[key] = val
            if ConfigCallbacks[key] then
                ConfigCallbacks[key](val)
            end
        end
    end
    return true
end

