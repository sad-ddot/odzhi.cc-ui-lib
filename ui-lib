            function Sector:AddKeybind(kbOpts)
                Sector.ElementCount = Sector.ElementCount + 1
                local kbName = kbOpts.Name or "Keybind"
                local kbDefault = kbOpts.Default or Enum.KeyCode.Unknown
                local kbFlag = kbOpts.Flag or kbName
                local kbCallback = kbOpts.Callback or function() end
                local kbMode = kbOpts.Mode or "Toggle"
                local currentKey = kbDefault
                local isListening = false
                local isActive = false
                ConfigState[kbFlag] = currentKey.Name

                local kbFrame = Create("Frame", {Parent = sectorContent, BackgroundTransparency = 1, Size = UDim2.new(1, 0, 0, 15), LayoutOrder = Sector.ElementCount})
                Create("TextLabel", {Parent = kbFrame, BackgroundTransparency = 1, Size = UDim2.new(1, -50, 1, 0), Font = Enum.Font.SourceSans, Text = kbName, TextColor3 = C.TextDim, TextSize = 13, TextXAlignment = Enum.TextXAlignment.Left})
                local kbOuter = Create("Frame", {Parent = kbFrame, BackgroundColor3 = C.DrpOuter, BorderSizePixel = 0, Position = UDim2.new(1, -48, 0, 2), Size = UDim2.new(0, 48, 0, 12)})
                local kbBtn = Create("TextButton", {Parent = kbOuter, BackgroundColor3 = C.DrpBg, BorderSizePixel = 0, Position = UDim2.new(0, 1, 0, 1), Size = UDim2.new(1, -2, 1, -2), Font = Enum.Font.SourceSans, Text = currentKey == Enum.KeyCode.Unknown and "[-]" or "[" .. currentKey.Name .. "]", TextColor3 = C.TextDark, TextSize = 10, AutoButtonColor = false, ZIndex = 6})

                local function updateKBListEntry()
                    if currentKey ~= Enum.KeyCode.Unknown then
                        ActiveKeybinds[kbName] = {Active = isActive, Mode = kbMode, Key = currentKey}
                    else
                        ActiveKeybinds[kbName] = nil
                    end
                    UpdateKeybindList()
                end

                kbBtn.MouseButton1Click:Connect(function()
                    if isListening then return end
                    isListening = true
                    kbBtn.Text = "[...]"
                    kbBtn.TextColor3 = C.TextDim
                end)

                UserInputService.InputBegan:Connect(function(input, gpe)
                    if isListening then
                        if input.UserInputType == Enum.UserInputType.Keyboard then
                            if input.KeyCode == Enum.KeyCode.Escape then currentKey = Enum.KeyCode.Unknown kbBtn.Text = "[-]"
                            else currentKey = input.KeyCode kbBtn.Text = "[" .. currentKey.Name .. "]" end
                            ConfigState[kbFlag] = currentKey.Name
                            isListening = false
                            kbBtn.TextColor3 = C.TextDark
                            isActive = false
                            updateKBListEntry()
                            return
                        end
                        if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.MouseButton2 then
                            isListening = false
                            kbBtn.Text = currentKey == Enum.KeyCode.Unknown and "[-]" or "[" .. currentKey.Name .. "]"
                            kbBtn.TextColor3 = C.TextDark
                            return
                        end
                    end
                    if not isListening and not gpe and input.UserInputType == Enum.UserInputType.Keyboard and input.KeyCode == currentKey and currentKey ~= Enum.KeyCode.Unknown then
                        if kbMode == "Toggle" then isActive = not isActive else isActive = true end
                        updateKBListEntry()
                        kbCallback(currentKey)
                    end
                end)

                if kbMode == "Hold" then
                    UserInputService.InputEnded:Connect(function(input)
                        if not isListening and input.UserInputType == Enum.UserInputType.Keyboard and input.KeyCode == currentKey and currentKey ~= Enum.KeyCode.Unknown then
                            isActive = false
                            updateKBListEntry()
                        end
                    end)
                end

                ConfigCallbacks[kbFlag] = function(v) local s, k = pcall(function() return Enum.KeyCode[v] end) if s and k then currentKey = k kbBtn.Text = currentKey == Enum.KeyCode.Unknown and "[-]" or "[" .. currentKey.Name .. "]" end end

                local kbObj = {}
                function kbObj:Set(k) currentKey = k ConfigState[kbFlag] = k.Name kbBtn.Text = k == Enum.KeyCode.Unknown and "[-]" or "[" .. k.Name .. "]" updateKBListEntry() end
                function kbObj:Get() return currentKey end
                return kbObj
            end

