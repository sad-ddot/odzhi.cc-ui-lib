                Create("UIPadding", {Parent = tB, PaddingLeft = UDim.new(0, 5)})
                tB.Focused:Connect(function() Tween(tO, {BackgroundColor3 = C.InpFocus}, 0.1) end)
                tB.FocusLost:Connect(function(e) Tween(tO, {BackgroundColor3 = C.InpOuter}, 0.1) cur = tB.Text ConfigState[fl] = cur cb(cur, e) end)
                ConfigCallbacks[fl] = function(v) cur = v tB.Text = v cb(v) end
                local obj = {} function obj:Set(v) cur = v tB.Text = v ConfigState[fl] = v cb(v) end function obj:Get() return cur end return obj
            end

            function Sector:AddPlayerList(o) Sector.EC = Sector.EC + 1 local nm = o.Name or "Players" local cb = o.Callback or function() end local pH = o.Height or 100 local selP = {}
                local f = Create("Frame", {Parent = sectorContent, BackgroundTransparency = 1, Size = UDim2.new(1, 0, 0, 16 + pH), LayoutOrder = Sector.EC})
                Create("TextLabel", {Parent = f, BackgroundTransparency = 1, Size = UDim2.new(1, 0, 0, 14), Font = Enum.Font.SourceSans, Text = nm, TextColor3 = C.TextDim, TextSize = 13, TextXAlignment = Enum.TextXAlignment.Left})
                local plO = Create("Frame", {Parent = f, BackgroundColor3 = C.InpOuter, BorderSizePixel = 0, Position = UDim2.new(0, 0, 0, 16), Size = UDim2.new(1, 0, 0, pH)})
                local plS = Create("ScrollingFrame", {Parent = plO, BackgroundColor3 = C.InpBg, BorderSizePixel = 0, Position = UDim2.new(0, 1, 0, 1), Size = UDim2.new(1, -2, 1, -2), ScrollBarThickness = 2, ScrollBarImageColor3 = C.GroupInner, AutomaticCanvasSize = Enum.AutomaticSize.Y, ScrollingDirection = Enum.ScrollingDirection.Y, ClipsDescendants = true})
                Create("UIListLayout", {Parent = plS, SortOrder = Enum.SortOrder.LayoutOrder})
                local function ref() for _, c in pairs(plS:GetChildren()) do if c:IsA("TextButton") then c:Destroy() end end for i, p in ipairs(Players:GetPlayers()) do if p ~= LocalPlayer then local isSel = selP[p.Name] == true local pb = Create("TextButton", {Parent = plS, BackgroundColor3 = C.InpBg, BorderSizePixel = 0, Size = UDim2.new(1, 0, 0, 18), Font = Enum.Font.SourceSans, Text = "  " .. p.Name, TextColor3 = isSel and C.Accent or C.TextDim, TextSize = 12, TextXAlignment = Enum.TextXAlignment.Left, AutoButtonColor = false, LayoutOrder = i}) pb.MouseEnter:Connect(function() pb.BackgroundColor3 = C.DrpHover end) pb.MouseLeave:Connect(function() pb.BackgroundColor3 = C.InpBg end) pb.MouseButton1Click:Connect(function() if selP[p.Name] then selP[p.Name] = nil else selP[p.Name] = true end pb.TextColor3 = selP[p.Name] and C.Accent or C.TextDim cb(selP) end) end end end
                ref() Players.PlayerAdded:Connect(function() task.wait(0.5) ref() end) Players.PlayerRemoving:Connect(function(p) selP[p.Name] = nil task.wait(0.1) ref() end)
                local obj = {} function obj:Get() return selP end function obj:Refresh() ref() end return obj
            end

            function Sector:AddLabel(o) Sector.EC = Sector.EC + 1 local txt = o.Text or ""
                local f = Create("Frame", {Parent = sectorContent, BackgroundTransparency = 1, Size = UDim2.new(1, 0, 0, 14), LayoutOrder = Sector.EC})
                local l = Create("TextLabel", {Parent = f, BackgroundTransparency = 1, Size = UDim2.new(1, 0, 1, 0), Font = Enum.Font.SourceSans, Text = txt, TextColor3 = C.TextDark, TextSize = 13, TextXAlignment = Enum.TextXAlignment.Left})
                local obj = {} function obj:SetText(t) l.Text = t end return obj
            end

            function Sector:AddSeparator() Sector.EC = Sector.EC + 1
                Create("Frame", {Parent = sectorContent, BackgroundColor3 = C.GroupInner, BorderSizePixel = 0, Size = UDim2.new(1, 0, 0, 1), LayoutOrder = Sector.EC})
            end

            return Sector
        end

        return Tab
    end

    UserInputService.InputBegan:Connect(function(input, gameProcessed)
        if input.UserInputType == Enum.UserInputType.Keyboard and input.KeyCode == Enum.KeyCode.Insert and not gameProcessed then
            Window:Toggle()
            return
        end

        if input.UserInputType == Enum.UserInputType.MouseButton1 then
            task.defer(function()
                local mousePos = UserInputService:GetMouseLocation()

                if ActiveDropdown and ActiveDropdown.Visible then
                    local ap = ActiveDropdown.AbsolutePosition
                    local as = ActiveDropdown.AbsoluteSize
                    if mousePos.X < ap.X or mousePos.X > ap.X + as.X or mousePos.Y < ap.Y or mousePos.Y > ap.Y + as.Y then
                        ActiveDropdown.Visible = false
                        ActiveDropdown = nil
                    end
                end

                for _, cpEntry in pairs(AllColorPickers) do
                    if cpEntry.IsOpen and cpEntry.Panel and cpEntry.Panel.Visible then
                        local ap = cpEntry.Panel.AbsolutePosition
                        local as = cpEntry.Panel.AbsoluteSize
                        if mousePos.X < ap.X or mousePos.X > ap.X + as.X or mousePos.Y < ap.Y or mousePos.Y > ap.Y + as.Y then
                            cpEntry.Panel.Visible = false
                            cpEntry.IsOpen = false
                        end
                    end
                end
            end)
        end
    end)

    return Window
end

return GamesenseLib
