Library._bindings = {}
Library._restylers = {}

function Library:_Bind(inst, prop, key)
    table.insert(self._bindings, { inst, prop, key })
    inst[prop] = self.Theme[key]
    return inst
end

function Library:_Register(fn)
    table.insert(self._restylers, fn)
    return fn
end

function Library:_ApplyTheme()
    for _, b in ipairs(self._bindings) do
        local inst, prop, key = b[1], b[2], b[3]
        if inst and inst.Parent then
            Util.Tween(inst, { [prop] = self.Theme[key] }, 0.2)
        end
    end
    for _, fn in ipairs(self._restylers) do
        pcall(fn)
    end
end

function Library:SetTheme(nameOrTable)
    local preset = type(nameOrTable) == "string" and self.Presets[nameOrTable] or nameOrTable
    if not preset then return end
    for k, v in pairs(preset) do
        self.Theme[k] = v
    end
    if type(nameOrTable) == "string" then
        self.CurrentThemeName = nameOrTable
    end
    self:_ApplyTheme()
end

function Library:SetAccentColor(color)
    self.Theme.Accent = color
    self.Theme.ToggleOn = color
    self:_ApplyTheme()
end

function Library:GetFlag(name)
    return self.Flags[name]
end

function Library:SetFlag(name, value)
    local obj = self.FlagObjects[name]
    if obj then obj.Set(value) end
end

function Library:_CloseOpenPopup()
    if self._openPopup then
        local p = self._openPopup
        self._openPopup = nil
        if p.onClose then pcall(p.onClose) end
        if p.catcher then p.catcher:Destroy() end
    end
end

function Library:_OpenPopup(panel, onClose)
    self:_CloseOpenPopup()
    if not self.Overlay then return end

    local catcher = Util.Create("TextButton", {
        Text = "",
        AutoButtonColor = false,
        BackgroundTransparency = 1,
        Size = UDim2.fromScale(1, 1),
        ZIndex = panel.ZIndex - 1,
        Parent = self.Overlay,
    })

    catcher.MouseButton1Click:Connect(function()
        self:_CloseOpenPopup()
    end)

    self._openPopup = { catcher = catcher, onClose = onClose }
end

function Library:_Notify(text, duration)
    if not self._notifyHolder then return end

    local notif = Util.Create("Frame", {
        Size = UDim2.new(1, 0, 0, 44),
        BorderSizePixel = 0,
        BackgroundTransparency = 1,
        Position = UDim2.new(0, 30, 0, 0),
        Parent = self._notifyHolder,
    })
    self:_Bind(notif, "BackgroundColor3", "Panel")

    Util.Corner(6).Parent = notif
    local stroke = Util.Stroke()
    stroke.Transparency = 1
    stroke.Parent = notif
    self:_Bind(stroke, "Color", "Border")

    local label = Util.Create("TextLabel", {
        Text = text,
        Font = self.Font,
        TextSize = 13,
        BackgroundTransparency = 1,
        TextTransparency = 1,
        Size = UDim2.new(1, -16, 1, 0),
        Position = UDim2.new(0, 8, 0, 0),
        TextXAlignment = Enum.TextXAlignment.Left,
        TextWrapped = true,
        Parent = notif,
    })
    self:_Bind(label, "TextColor3", "Text")

    Util.Tween(notif, { BackgroundTransparency = 0, Position = UDim2.new(0, 0, 0, 0) }, 0.2)
    Util.Tween(stroke, { Transparency = 0 }, 0.2)
    Util.Tween(label, { TextTransparency = 0 }, 0.2)

    task.delay(duration or 3, function()
        if notif and notif.Parent then
            Util.Tween(notif, { BackgroundTransparency = 1, Position = UDim2.new(0, 30, 0, 0) }, 0.2)
            Util.Tween(stroke, { Transparency = 1 }, 0.2)
            Util.Tween(label, { TextTransparency = 1 }, 0.2)
            task.wait(0.2)
            notif:Destroy()
        end
    end)
end

function Library:Notify(text, duration)
    self:_Notify(text, duration)
end

