                    end
                end)

                ConfigCallbacks[fl]=function(v) if typeof(v)=="Color3" then col=v cH,cS,cV=Color3.toHSV(v) updC() end end
                cb(col)

                local obj={} function obj:Set(c) col=c cH,cS,cV=Color3.toHSV(c) ConfigState[fl]=c updC() end function obj:Get() return col end return obj
            end

            function S:AddKeybind(o)
                S.EC=S.EC+1
                local nm,def,fl,cb=o.Name or "Keybind",o.Default or Enum.KeyCode.Unknown,o.Flag or (o.Name or "Keybind"),o.Callback or function()end
                local mode=o.Mode or "Toggle"
                local cur=def local listening=false local active=false
                ConfigState[fl]=cur.Name

                local f=Cr("Frame",{Parent=sCont,BackgroundTransparency=1,Size=UDim2.new(1,0,0,14),LayoutOrder=S.EC})
                Cr("TextLabel",{Parent=f,BackgroundTransparency=1,Size=UDim2.new(1,-48,1,0),Font=Enum.Font.SourceSans,Text=nm,TextColor3=C.TextDim,TextSize=13,TextXAlignment=Enum.TextXAlignment.Left})
                local kO=Cr("Frame",{Parent=f,BackgroundColor3=C.DrpOuter,BorderSizePixel=0,Position=UDim2.new(1,-45,0,1),Size=UDim2.new(0,45,0,12)})
                local kB=Cr("TextButton",{Parent=kO,BackgroundColor3=C.DrpBg,BorderSizePixel=0,Position=UDim2.new(0,1,0,1),Size=UDim2.new(1,-2,1,-2),Font=Enum.Font.SourceSans,Text=cur==Enum.KeyCode.Unknown and "[-]" or "["..cur.Name.."]",TextColor3=C.TextDark,TextSize=11,AutoButtonColor=false,ZIndex=5})

                local function updateKBList()
                    if cur~=Enum.KeyCode.Unknown then
                        ActiveKeybinds[nm]={Active=active,Mode=mode,Key=cur}
                    else
                        ActiveKeybinds[nm]=nil
                    end
                    UpdateKeybindList()
                end

                kB.MouseButton1Click:Connect(function()
                    if listening then return end listening=true kB.Text="[...]"
                end)

                UserInputService.InputBegan:Connect(function(inp,gpe)
                    if listening then
                        if inp.UserInputType==Enum.UserInputType.Keyboard then
                            if inp.KeyCode==Enum.KeyCode.Escape then cur=Enum.KeyCode.Unknown kB.Text="[-]"
                            else cur=inp.KeyCode kB.Text="["..cur.Name.."]" end
                            ConfigState[fl]=cur.Name listening=false active=false updateKBList() return
                        end
                        if inp.UserInputType==Enum.UserInputType.MouseButton1 or inp.UserInputType==Enum.UserInputType.MouseButton2 then
                            listening=false kB.Text=cur==Enum.KeyCode.Unknown and "[-]" or "["..cur.Name.."]" return
                        end
                    end
                    if not listening and not gpe and inp.UserInputType==Enum.UserInputType.Keyboard and inp.KeyCode==cur and cur~=Enum.KeyCode.Unknown then
                        if mode=="Toggle" then active=not active updateKBList() end
                        cb(cur)
                    end
                end)

                ConfigCallbacks[fl]=function(v) local s,k=pcall(function() return Enum.KeyCode[v] end) if s and k then cur=k kB.Text=cur==Enum.KeyCode.Unknown and "[-]" or "["..cur.Name.."]" end end

                local obj={} function obj:Set(k) cur=k ConfigState[fl]=k.Name kB.Text=k==Enum.KeyCode.Unknown and "[-]" or "["..k.Name.."]" updateKBList() end function obj:Get() return cur end return obj
            end

            function S:AddTextbox(o)
                S.EC=S.EC+1
                local nm,def,ph,fl,cb=o.Name or "Textbox",o.Default or "",o.Placeholder or "",o.Flag or (o.Name or "Textbox"),o.Callback or function()end
                local cur=def ConfigState[fl]=cur

                local f=Cr("Frame",{Parent=sCont,BackgroundTransparency=1,Size=UDim2.new(1,0,0,30),LayoutOrder=S.EC})
                Cr("TextLabel",{Parent=f,BackgroundTransparency=1,Size=UDim2.new(1,0,0,13),Font=Enum.Font.SourceSans,Text=nm,TextColor3=C.TextDim,TextSize=13,TextXAlignment=Enum.TextXAlignment.Left})
                local tO=Cr("Frame",{Parent=f,BackgroundColor3=C.InpOuter,BorderSizePixel=0,Position=UDim2.new(0,0,0,14),Size=UDim2.new(1,0,0,16)})
                local tB=Cr("TextBox",{Parent=tO,BackgroundColor3=C.InpBg,BorderSizePixel=0,Position=UDim2.new(0,1,0,1),Size=UDim2.new(1,-2,1,-2),Font=Enum.Font.SourceSans,Text=cur,PlaceholderText=ph,PlaceholderColor3=C.TextDark,TextColor3=C.TextDim,TextSize=12,TextXAlignment=Enum.TextXAlignment.Left,ClearTextOnFocus=false,ClipsDescendants=true})
                Cr("UIPadding",{Parent=tB,PaddingLeft=UDim.new(0,4)})
                tB.FocusLost:Connect(function(e) cur=tB.Text ConfigState[fl]=cur cb(cur,e) end)
                ConfigCallbacks[fl]=function(v) cur=v tB.Text=v cb(v) end
                local obj={} function obj:Set(v) cur=v tB.Text=v ConfigState[fl]=v cb(v) end function obj:Get() return cur end return obj
            end

            function S:AddMultibox(o)
                S.EC=S.EC+1
                local nm,def,ph,fl,cb,lines=o.Name or "Multibox",o.Default or "",o.Placeholder or "",o.Flag or (o.Name or "Multibox"),o.Callback or function()end,o.Lines or 4
                local cur=def ConfigState[fl]=cur local bH=lines*14+4
                local f=Cr("Frame",{Parent=sCont,BackgroundTransparency=1,Size=UDim2.new(1,0,0,14+bH),LayoutOrder=S.EC})
                Cr("TextLabel",{Parent=f,BackgroundTransparency=1,Size=UDim2.new(1,0,0,13),Font=Enum.Font.SourceSans,Text=nm,TextColor3=C.TextDim,TextSize=13,TextXAlignment=Enum.TextXAlignment.Left})
                local mO=Cr("Frame",{Parent=f,BackgroundColor3=C.InpOuter,BorderSizePixel=0,Position=UDim2.new(0,0,0,14),Size=UDim2.new(1,0,0,bH)})
                local mB=Cr("TextBox",{Parent=mO,BackgroundColor3=C.InpBg,BorderSizePixel=0,Position=UDim2.new(0,1,0,1),Size=UDim2.new(1,-2,1,-2),Font=Enum.Font.SourceSans,Text=cur,PlaceholderText=ph,PlaceholderColor3=C.TextDark,TextColor3=C.TextDim,TextSize=12,TextXAlignment=Enum.TextXAlignment.Left,TextYAlignment=Enum.TextYAlignment.Top,MultiLine=true,ClearTextOnFocus=false,ClipsDescendants=true,TextWrapped=true})
                Cr("UIPadding",{Parent=mB,PaddingLeft=UDim.new(0,4),PaddingTop=UDim.new(0,3)})
                mB.FocusLost:Connect(function(e) cur=mB.Text ConfigState[fl]=cur cb(cur,e) end)
                ConfigCallbacks[fl]=function(v) cur=v mB.Text=v cb(v) end
                local obj={} function obj:Set(v) cur=v mB.Text=v ConfigState[fl]=v cb(v) end function obj:Get() return cur end return obj
            end

            function S:AddPlayerList(o)
                S.EC=S.EC+1
                local nm,fl,cb=o.Name or "Players",o.Flag or (o.Name or "Players"),o.Callback or function()end
                local sel={}

                local f=Cr("Frame",{Parent=sCont,BackgroundTransparency=1,Size=UDim2.new(1,0,0,100),LayoutOrder=S.EC})
                Cr("TextLabel",{Parent=f,BackgroundTransparency=1,Size=UDim2.new(1,0,0,13),Font=Enum.Font.SourceSans,Text=nm,TextColor3=C.TextDim,TextSize=13,TextXAlignment=Enum.TextXAlignment.Left})
                local plO=Cr("Frame",{Parent=f,BackgroundColor3=C.InpOuter,BorderSizePixel=0,Position=UDim2.new(0,0,0,14),Size=UDim2.new(1,0,0,84)})
                local plScroll=Cr("ScrollingFrame",{Parent=plO,BackgroundColor3=C.InpBg,BorderSizePixel=0,Position=UDim2.new(0,1,0,1),Size=UDim2.new(1,-2,1,-2),ScrollBarThickness=2,ScrollBarImageColor3=C.GrpInner,AutomaticCanvasSize=Enum.AutomaticSize.Y,ScrollingDirection=Enum.ScrollingDirection.Y,ClipsDescendants=true})
                Cr("UIListLayout",{Parent=plScroll,SortOrder=Enum.SortOrder.LayoutOrder})

                local function refresh()
                    for _,c in pairs(plScroll:GetChildren()) do if c:IsA("TextButton") then c:Destroy() end end
                    for i,p in ipairs(Players:GetPlayers()) do
                        if p~=LocalPlayer then
                            local isSel=sel[p.Name]==true
                            local pb=Cr("TextButton",{Parent=plScroll,BackgroundColor3=C.InpBg,BorderSizePixel=0,Size=UDim2.new(1,0,0,16),Font=Enum.Font.SourceSans,Text="  "..p.Name,TextColor3=isSel and C.Accent or C.TextDim,TextSize=12,TextXAlignment=Enum.TextXAlignment.Left,AutoButtonColor=false,LayoutOrder=i})
                            pb.MouseEnter:Connect(function() pb.BackgroundColor3=C.DrpHover end)
                            pb.MouseLeave:Connect(function() pb.BackgroundColor3=C.InpBg end)
                            pb.MouseButton1Click:Connect(function()
                                sel[p.Name]=not sel[p.Name] or nil
                                if sel[p.Name]==false then sel[p.Name]=nil end
                                pb.TextColor3=sel[p.Name] and C.Accent or C.TextDim
                                cb(sel)
                            end)
                        end
                    end
                end
                refresh()
                Players.PlayerAdded:Connect(function() task.wait(0.5) refresh() end)
                Players.PlayerRemoving:Connect(function(p) sel[p.Name]=nil task.wait(0.1) refresh() end)

                local obj={} function obj:Get() return sel end function obj:Refresh() refresh() end return obj
            end

            function S:AddLabel(o)
                S.EC=S.EC+1
                local txt=o.Text or ""
                local f=Cr("Frame",{Parent=sCont,BackgroundTransparency=1,Size=UDim2.new(1,0,0,13),LayoutOrder=S.EC})
                local l=Cr("TextLabel",{Parent=f,BackgroundTransparency=1,Size=UDim2.new(1,0,1,0),Font=Enum.Font.SourceSans,Text=txt,TextColor3=C.TextDark,TextSize=13,TextXAlignment=Enum.TextXAlignment.Left})
                local obj={} function obj:SetText(t) l.Text=t end return obj
            end

            function S:AddSeparator()
                S.EC=S.EC+1
                Cr("Frame",{Parent=sCont,BackgroundColor3=C.GrpInner,BorderSizePixel=0,Size=UDim2.new(1,0,0,1),LayoutOrder=S.EC})
            end

            return S
        end
        return T
    end

    UserInputService.InputBegan:Connect(function(inp)
        if inp.UserInputType==Enum.UserInputType.MouseButton1 then
            if ActiveDrop and ActiveDrop.Visible then
                local ap,as=ActiveDrop.AbsolutePosition,ActiveDrop.AbsoluteSize
                local mp=UserInputService:GetMouseLocation()
                if mp.X<ap.X or mp.X>ap.X+as.X or mp.Y<ap.Y or mp.Y>ap.Y+as.Y then
                    ActiveDrop.Visible=false ActiveDrop=nil
                end
            end
            task.defer(function()
                local mp=UserInputService:GetMouseLocation()
                for _,cpd in pairs(AllColorPickers) do
                    if cpd.Open and cpd.Panel and cpd.Panel.Visible then
                        local ap,as=cpd.Panel.AbsolutePosition,cpd.Panel.AbsoluteSize
                        if mp.X<ap.X or mp.X>ap.X+as.X or mp.Y<ap.Y or mp.Y>ap.Y+as.Y then
                            cpd.Panel.Visible=false cpd.Open=false
                        end
                    end
                end
            end)
        end
    end)

    return W
end

return GamesenseLib
