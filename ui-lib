function GamesenseLib:Notify(opts)
    if not NotifContainer then return end
    local txt = opts.Text or ""
    local dur = opts.Duration or 3

    local nf = Cr("Frame", {
        Parent = NotifContainer,
        BackgroundColor3 = C.WatermarkBg,
        BorderSizePixel = 0,
        Size = UDim2.new(0, 300, 0, 28),
        BackgroundTransparency = 1,
    })
    Cr("UIStroke", {Parent=nf, Color=C.WatermarkBorder, Thickness=1, ApplyStrokeMode=Enum.ApplyStrokeMode.Border})
    local nAcc = Cr("Frame", {Parent=nf, BackgroundColor3=C.Accent, BorderSizePixel=0, Size=UDim2.new(0,2,1,0), Position=UDim2.new(0,0,0,0)})
    local nLbl = Cr("TextLabel", {Parent=nf, BackgroundTransparency=1, Position=UDim2.new(0,10,0,0), Size=UDim2.new(1,-14,1,0), Font=Enum.Font.SourceSans, Text=txt, TextColor3=C.TextDim, TextSize=13, TextXAlignment=Enum.TextXAlignment.Left, TextTransparency=1})
    Tw(nf, {BackgroundTransparency=0}, 0.2)
    Tw(nLbl, {TextTransparency=0}, 0.2)
    task.delay(dur, function()
        Tw(nf, {BackgroundTransparency=1}, 0.25)
        Tw(nLbl, {TextTransparency=1}, 0.25)
        task.wait(0.3)
        nf:Destroy()
    end)
end

