                Create("UIPadding", {
                    Parent = TBBox,
                    PaddingLeft = UDim.new(0, 5),
                })

                TBBox.FocusLost:Connect(function(enter)
                    currentText = TBBox.Text
                    ConfigState[tFlag] = currentText
                    tCallback(currentText, enter)
                end)

                ConfigCallbacks[tFlag] = function(val) currentText = val TBBox.Text = val tCallback(val) end

                local obj = {}
                function obj:Set(v) currentText = v TBBox.Text = v ConfigState[tFlag] = v tCallback(v) end
                function obj:Get() return currentText end
                return obj
            end

            function Sector:AddMultibox(mOpts)
                local mName = mOpts.Name or "Multibox"
                local mDefault = mOpts.Default or ""
                local mPlaceholder = mOpts.Placeholder or "Type..."
