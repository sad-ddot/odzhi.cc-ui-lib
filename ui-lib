            function Sector:AddToggle(o)
                Sector.EC = Sector.EC + 1
                local nm = o.Name or "Toggle"
                local def = o.Default or false
                local fl = o.Flag or nm
                local cb = o.Callback or function() end
                local showBind = o.ShowBind or false
                local defBind = o.DefaultBind or Enum.KeyCode.Unknown
                local tog = def
                local bindKey = defBind
                local bindListening = false
                ConfigState[fl] = tog

                local frame = Create("Frame", {
                    Parent = sectorContent,
                    BackgroundTransparency = 1,
                    Size = UDim2.new(1, 0, 0, 15),
                    LayoutOrder = Sector.EC,
                })

                local chkOuter = Create("Frame", {
                    Parent = frame,
                    BackgroundColor3 = C.ChkOuter,
                    BorderSizePixel = 0,
                    Position = UDim2.new(0, 0, 0, 3),
                    Size = UDim2.new(0, 9, 0, 9),
                })

                local chkInner = Create("Frame", {
                    Parent = chkOuter,
                    BorderSizePixel = 0,
                    Position = UDim2.new(0, 1, 0, 1),
                    Size = UDim2.new(1, -2, 1, -2),
                })

                local chkGrad = Create("UIGradient", {
                    Parent = chkInner,
                    Rotation = 90,
                })

                local label = Create("TextLabel", {
                    Parent = frame,
                    BackgroundTransparency = 1,
                    Position = UDim2.new(0, 15, 0, 0),
                    Size = UDim2.new(1, showBind and -60 or -15, 1, 0),
                    Font = Enum.Font.SourceSans,
                    Text = nm,
                    TextSize = 13,
                    TextXAlignment = Enum.TextXAlignment.Left,
                })

                local clickBtn = Create("TextButton", {
                    Parent = frame,
                    BackgroundTransparency = 1,
                    Size = UDim2.new(1, showBind and -50 or 0, 1, 0),
                    Text = "",
                    ZIndex = 5,
                })

                local bindOuter = nil
                local bindBtn = nil

                if showBind then
                    bindOuter = Create("Frame", {
                        Parent = frame,
                        BackgroundColor3 = C.DrpOuter,
                        BorderSizePixel = 0,
                        Position = UDim2.new(1, -45, 0, 2),
                        Size = UDim2.new(0, 45, 0, 12),
                    })

                    bindBtn = Create("TextButton", {
                        Parent = bindOuter,
                        BackgroundColor3 = C.DrpBg,
                        BorderSizePixel = 0,
                        Position = UDim2.new(0, 1, 0, 1),
                        Size = UDim2.new(1, -2, 1, -2),
                        Font = Enum.Font.SourceSans,
                        Text = bindKey == Enum.KeyCode.Unknown and "[-]" or "[" .. bindKey.Name .. "]",
                        TextColor3 = C.TextDark,
                        TextSize = 10,
                        AutoButtonColor = false,
                        ZIndex = 6,
                    })
                end

                local function updateVisual()
                    if tog then
                        chkGrad.Color = ColorSequence.new(C.Accent, C.AccentDark)
                        label.TextColor3 = C.Text
                    else
                        chkGrad.Color = ColorSequence.new(C.ChkGradT, C.ChkGradB)
                        label.TextColor3 = C.TextDim
                    end
                end

                updateVisual()

                clickBtn.MouseEnter:Connect(function()
                    if not tog then
                        chkGrad.Color = ColorSequence.new(C.ChkHoverT, C.ChkHoverB)
                    end
                end)

                clickBtn.MouseLeave:Connect(function()
                    updateVisual()
                end)

                clickBtn.MouseButton1Click:Connect(function()
                    tog = not tog
                    ConfigState[fl] = tog
                    updateVisual()
                    cb(tog)
                    if showBind and bindKey ~= Enum.KeyCode.Unknown then
                        ActiveKeybinds[nm] = {Active = tog, Mode = "toggle", Key = bindKey}
                        UpdateKeybindList()
                    end
                end)

                if showBind and bindBtn then
                    bindBtn.MouseButton1Click:Connect(function()
                        if bindListening then return end
                        bindListening = true
                        bindBtn.Text = "[...]"
                    end)

                    UserInputService.InputBegan:Connect(function(inp, gpe)
                        if bindListening then
                            if inp.UserInputType == Enum.UserInputType.Keyboard then
                                if inp.KeyCode == Enum.KeyCode.Escape then
                                    bindKey = Enum.KeyCode.Unknown
                                    bindBtn.Text = "[-]"
                                else
                                    bindKey = inp.KeyCode
                                    bindBtn.Text = "[" .. bindKey.Name .. "]"
                                end
                                bindListening = false
                                if bindKey ~= Enum.KeyCode.Unknown then
                                    ActiveKeybinds[nm] = {Active = tog, Mode = "toggle", Key = bindKey}
                                else
                                    ActiveKeybinds[nm] = nil
                                end
                                UpdateKeybindList()
                                return
                            end
                            if inp.UserInputType == Enum.UserInputType.MouseButton1 or inp.UserInputType == Enum.UserInputType.MouseButton2 then
                                bindListening = false
                                bindBtn.Text = bindKey == Enum.KeyCode.Unknown and "[-]" or "[" .. bindKey.Name .. "]"
                                return
                            end
                        end

                        if not bindListening and not gpe and inp.UserInputType == Enum.UserInputType.Keyboard then
                            if inp.KeyCode == bindKey and bindKey ~= Enum.KeyCode.Unknown then
                                tog = not tog
                                ConfigState[fl] = tog
                                updateVisual()
                                cb(tog)
                                ActiveKeybinds[nm] = {Active = tog, Mode = "toggle", Key = bindKey}
                                UpdateKeybindList()
                            end
                        end
                    end)
                end

                ConfigCallbacks[fl] = function(v)
                    tog = v
                    updateVisual()
                    cb(v)
                end

                if def then cb(true) end

                local obj = {}
                function obj:Set(v) tog = v ConfigState[fl] = v updateVisual() cb(v) end
                function obj:Get() return tog end
                return obj
            end

