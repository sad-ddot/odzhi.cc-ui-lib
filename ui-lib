                local ckI = Create("Frame", {Parent = ckO, BorderSizePixel = 0, Position = UDim2.new(0, 1, 0, 1), Size = UDim2.new(1, -2, 1, -2)})
                local ckG = Create("UIGradient", {Parent = ckI, Rotation = 90})
                local lbl = Create("TextLabel", {Parent = f, BackgroundTransparency = 1, Position = UDim2.new(0, 15, 0, 0), Size = UDim2.new(1, showBind and -60 or -15, 1, 0), Font = Enum.Font.SourceSans, Text = nm, TextSize = 13, TextXAlignment = Enum.TextXAlignment.Left})
                local btn = Create("TextButton", {Parent = f, BackgroundTransparency = 1, Size = UDim2.new(1, showBind and -50 or 0, 1, 0), Text = "", ZIndex = 5})
                local bO, bB
                if showBind then bO = Create("Frame", {Parent = f, BackgroundColor3 = C.DrpOuter, BorderSizePixel = 0, Position = UDim2.new(1, -45, 0, 2), Size = UDim2.new(0, 45, 0, 12)}) bB = Create("TextButton", {Parent = bO, BackgroundColor3 = C.DrpBg, BorderSizePixel = 0, Position = UDim2.new(0, 1, 0, 1), Size = UDim2.new(1, -2, 1, -2), Font = Enum.Font.SourceSans, Text = bindKey == Enum.KeyCode.Unknown and "[-]" or "[" .. bindKey.Name .. "]", TextColor3 = C.TextDark, TextSize = 10, AutoButtonColor = false, ZIndex = 6}) end
                local function upd() if tog then ckG.Color = ColorSequence.new(C.Accent, C.AccentDark) lbl.TextColor3 = C.Text else ckG.Color = ColorSequence.new(C.ChkGradT, C.ChkGradB) lbl.TextColor3 = C.TextDim end end upd()
                btn.MouseEnter:Connect(function() if not tog then ckG.Color = ColorSequence.new(C.ChkHoverT, C.ChkHoverB) end end)
                btn.MouseLeave:Connect(function() upd() end)
                btn.MouseButton1Click:Connect(function() tog = not tog ConfigState[fl] = tog upd() cb(tog) if showBind and bindKey ~= Enum.KeyCode.Unknown then ActiveKeybinds[nm] = {Active = tog, Mode = "toggle", Key = bindKey} UpdateKBList() end end)
                if showBind and bB then bB.MouseButton1Click:Connect(function() if bListen then return end bListen = true bB.Text = "[...]" end) UserInputService.InputBegan:Connect(function(inp, gpe) if bListen then if inp.UserInputType == Enum.UserInputType.Keyboard then if inp.KeyCode == Enum.KeyCode.Escape then bindKey = Enum.KeyCode.Unknown bB.Text = "[-]" else bindKey = inp.KeyCode bB.Text = "[" .. bindKey.Name .. "]" end bListen = false if bindKey ~= Enum.KeyCode.Unknown then ActiveKeybinds[nm] = {Active = tog, Mode = "toggle", Key = bindKey} else ActiveKeybinds[nm] = nil end UpdateKBList() return end if inp.UserInputType == Enum.UserInputType.MouseButton1 or inp.UserInputType == Enum.UserInputType.MouseButton2 then bListen = false bB.Text = bindKey == Enum.KeyCode.Unknown and "[-]" or "[" .. bindKey.Name .. "]" return end end if not bListen and not gpe and inp.UserInputType == Enum.UserInputType.Keyboard and inp.KeyCode == bindKey and bindKey ~= Enum.KeyCode.Unknown then tog = not tog ConfigState[fl] = tog upd() cb(tog) ActiveKeybinds[nm] = {Active = tog, Mode = "toggle", Key = bindKey} UpdateKBList() end end) end
                ConfigCallbacks[fl] = function(v) tog = v upd() cb(v) end if def then cb(true) end
                local obj = {} function obj:Set(v) tog = v ConfigState[fl] = v upd() cb(v) end function obj:Get() return tog end return obj
            end

            function S:AddSlider(o) S.EC = S.EC + 1 local nm = o.Name or "Slider" local mn, mx = o.Min or 0, o.Max or 100 local def = o.Default or mn local fl = o.Flag or nm local cb = o.Callback or function() end local sfx = o.Suffix or "" local inc = o.Increment or 1 local cur = def ConfigState[fl] = cur
                local f = Create("Frame", {Parent = sCont, BackgroundTransparency = 1, Size = UDim2.new(1, 0, 0, 30), LayoutOrder = S.EC})
                Create("TextLabel", {Parent = f, BackgroundTransparency = 1, Size = UDim2.new(0.5, 0, 0, 13), Font = Enum.Font.SourceSans, Text = nm, TextColor3 = C.TextDim, TextSize = 13, TextXAlignment = Enum.TextXAlignment.Left})
                local slO = Create("Frame", {Parent = f, BackgroundColor3 = C.SlOuter, BorderSizePixel = 0, Position = UDim2.new(0, 0, 0, 14), Size = UDim2.new(1, 0, 0, 6)})
                local slBg = Create("Frame", {Parent = slO, BorderSizePixel = 0, Position = UDim2.new(0, 1, 0, 1), Size = UDim2.new(1, -2, 1, -2), ClipsDescendants = true})
                Create("UIGradient", {Parent = slBg, Rotation = 90, Color = ColorSequence.new(C.SlGradT, C.SlGradB)})
                local pct = math.clamp((cur - mn) / (mx - mn), 0, 1)
                local slFill = Create("Frame", {Parent = slBg, BorderSizePixel = 0, Size = UDim2.new(pct, 0, 1, 0)})
                Create("UIGradient", {Parent = slFill, Color = ColorSequence.new(C.AccentDark, C.Accent)})
                local vLbl = Create("TextLabel", {Parent = f, BackgroundTransparency = 1, Position = UDim2.new(pct, -18, 0, 20), Size = UDim2.new(0, 36, 0, 10), Font = Enum.Font.SourceSansSemibold, Text = tostring(cur) .. sfx, TextColor3 = C.Text, TextSize = 10, ZIndex = 3, TextXAlignment = Enum.TextXAlignment.Center})
                local slBtn = Create("TextButton", {Parent = slO, BackgroundTransparency = 1, Size = UDim2.new(1, 0, 1, 0), Text = "", ZIndex = 5})
                local sliding = false
                local function updS(inp) local aP, aS = slBg.AbsolutePosition.X, slBg.AbsoluteSize.X if aS == 0 then return end local r = math.clamp((inp.Position.X - aP) / aS, 0, 1) cur = math.clamp(math.floor((mn + (mx - mn) * r) / inc + 0.5) * inc, mn, mx) ConfigState[fl] = cur local p = (cur - mn) / (mx - mn) slFill.Size = UDim2.new(p, 0, 1, 0) vLbl.Text = tostring(cur) .. sfx vLbl.Position = UDim2.new(p, -18, 0, 20) cb(cur) end
                slBtn.InputBegan:Connect(function(inp) if inp.UserInputType == Enum.UserInputType.MouseButton1 then sliding = true updS(inp) end end)
                slBtn.InputEnded:Connect(function(inp) if inp.UserInputType == Enum.UserInputType.MouseButton1 then sliding = false end end)
                UserInputService.InputChanged:Connect(function(inp) if sliding and inp.UserInputType == Enum.UserInputType.MouseMovement then updS(inp) end end)
                ConfigCallbacks[fl] = function(v) cur = v local p = (v - mn) / (mx - mn) slFill.Size = UDim2.new(p, 0, 1, 0) vLbl.Text = tostring(v) .. sfx vLbl.Position = UDim2.new(p, -18, 0, 20) cb(v) end cb(cur)
                local obj = {} function obj:Set(v) cur = math.clamp(v, mn, mx) ConfigState[fl] = cur local p = (cur - mn) / (mx - mn) slFill.Size = UDim2.new(p, 0, 1, 0) vLbl.Text = tostring(cur) .. sfx vLbl.Position = UDim2.new(p, -18, 0, 20) cb(cur) end function obj:Get() return cur end return obj
            end

            function S:AddDropdown(o) S.EC = S.EC + 1 local nm = o.Name or "Dropdown" local items = o.Items or {} local def = o.Default or (items[1] or "") local fl = o.Flag or nm local cb = o.Callback or function() end local sel = def local isOpen = false ConfigState[fl] = sel
