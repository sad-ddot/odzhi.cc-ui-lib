-- Resolves effective state of a feature: (toggle on) AND (keybind inactive/none OR keybind active)
cheat.is_active = function(toggle_state, keybind_flag)
    if not toggle_state then return false end
    if not keybind_flag then return true end
    local kb = cheat.Keybinds[keybind_flag]
    if not kb then return true end
    if not kb.Key or kb.Key == "" or kb.Key == "None" then return true end
    if kb.Mode == "Always" then return true end
    return kb.Toggled == true
end
