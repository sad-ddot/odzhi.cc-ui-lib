                    SatValFrame.BackgroundColor3 = Color3.fromHSV(math.clamp(currentH, 0, 0.999), 1, 1)
                    SatValSelector.Position = UDim2.new(currentS, 0, 1 - currentV, 0)
                    HueSelector.Position = UDim2.new(0, -1, currentH, -1)
                    HexBox.Text = ColorToHex(currentColor)
                    ConfigState[cFlag] = currentColor
                    cCallback(currentColor)
                end

                local draggingSV = false
                local draggingH = false

                local svBtn = Create("TextButton", {
                    Parent = SatValFrame,
                    BackgroundTransparency = 1,
                    Size = UDim2.new(1, 0, 1, 0),
                    Text = "",
                    ZIndex = 117,
                })

                local hueBtn = Create("TextButton", {
                    Parent = HueInner,
                    BackgroundTransparency = 1,
                    Size = UDim2.new(1, 0, 1, 0),
                    Text = "",
                    ZIndex = 116,
                })

                svBtn.InputBegan:Connect(function(input)
                    if input.UserInputType == Enum.UserInputType.MouseButton1 then
                        draggingSV = true
                        local absPos = SatValFrame.AbsolutePosition
                        local absSize = SatValFrame.AbsoluteSize
                        currentS = math.clamp((input.Position.X - absPos.X) / absSize.X, 0, 1)
                        currentV = math.clamp(1 - (input.Position.Y - absPos.Y) / absSize.Y, 0, 1)
                        UpdateColorDisplay()
                    end
                end)

                svBtn.InputEnded:Connect(function(input)
                    if input.UserInputType == Enum.UserInputType.MouseButton1 then
                        draggingSV = false
                    end
                end)

                hueBtn.InputBegan:Connect(function(input)
                    if input.UserInputType == Enum.UserInputType.MouseButton1 then
                        draggingH = true
                        local absPos = HueInner.AbsolutePosition
                        local absSize = HueInner.AbsoluteSize
                        currentH = math.clamp((input.Position.Y - absPos.Y) / absSize.Y, 0, 0.999)
                        UpdateColorDisplay()
                    end
                end)

                hueBtn.InputEnded:Connect(function(input)
                    if input.UserInputType == Enum.UserInputType.MouseButton1 then
                        draggingH = false
                    end
                end)

                UserInputService.InputChanged:Connect(function(input)
                    if input.UserInputType == Enum.UserInputType.MouseMovement then
                        if draggingSV then
                            local absPos = SatValFrame.AbsolutePosition
                            local absSize = SatValFrame.AbsoluteSize
                            currentS = math.clamp((input.Position.X - absPos.X) / absSize.X, 0, 1)
                            currentV = math.clamp(1 - (input.Position.Y - absPos.Y) / absSize.Y, 0, 1)
                            UpdateColorDisplay()
                        elseif draggingH then
                            local absPos = HueInner.AbsolutePosition
                            local absSize = HueInner.AbsoluteSize
                            currentH = math.clamp((input.Position.Y - absPos.Y) / absSize.Y, 0, 0.999)
                            UpdateColorDisplay()
                        end
                    end
                end)

                HexBox.FocusLost:Connect(function()
                    local hex = HexBox.Text:gsub("#", "")
                    if #hex == 6 then
                        local r = tonumber(hex:sub(1, 2), 16)
                        local g = tonumber(hex:sub(3, 4), 16)
                        local b = tonumber(hex:sub(5, 6), 16)
                        if r and g and b then
                            currentColor = Color3.fromRGB(r, g, b)
                            currentH, currentS, currentV = Color3.toHSV(currentColor)
                            UpdateColorDisplay()
                        end
                    end
                end)

                Preview.MouseButton1Click:Connect(function()
                    cpOpen = not cpOpen
                    if cpOpen then
                        local absPos = PreviewOuter.AbsolutePosition
                        PanelOuter.Position = UDim2.new(0, absPos.X - 170, 0, absPos.Y + 16)
                        PanelOuter.Visible = true
                        UpdateColorDisplay()
                    else
                        PanelOuter.Visible = false
                    end
                end)

                ConfigCallbacks[cFlag] = function(val)
                    if typeof(val) == "Color3" then
                        currentColor = val
                        currentH, currentS, currentV = Color3.toHSV(val)
                        UpdateColorDisplay()
                    end
                end

                cCallback(currentColor)

                local obj = {}
                function obj:Set(c) currentColor = c currentH, currentS, currentV = Color3.toHSV(c) ConfigState[cFlag] = c UpdateColorDisplay() end
                function obj:Get() return currentColor end
                return obj
            end

            function Sector:AddKeybind(kOpts)
                local kName = kOpts.Name or "Keybind"
                local kDefault = kOpts.Default or Enum.KeyCode.Unknown
                local kFlag = kOpts.Flag or kName
                local kCallback = kOpts.Callback or function() end

                Sector.ElementCount = Sector.ElementCount + 1

                local currentKey = kDefault
                local listening = false
                ConfigState[kFlag] = currentKey.Name

                local Frame = Create("Frame", {
                    Parent = SectorContent,
                    BackgroundTransparency = 1,
                    Size = UDim2.new(1, 0, 0, 15),
                    LayoutOrder = Sector.ElementCount,
                })

                local Label = Create("TextLabel", {
                    Parent = Frame,
                    BackgroundTransparency = 1,
                    Position = UDim2.new(0, 0, 0, 0),
                    Size = UDim2.new(1, -58, 1, 0),
                    Font = Enum.Font.SourceSans,
                    Text = kName,
                    TextColor3 = Colors.TextDim,
                    TextSize = 13,
                    TextXAlignment = Enum.TextXAlignment.Left,
                })

                local KBOuter = Create("Frame", {
                    Parent = Frame,
                    BackgroundColor3 = Colors.Border,
                    BorderSizePixel = 0,
                    Position = UDim2.new(1, -55, 0, 1),
                    Size = UDim2.new(0, 55, 0, 13),
                })

                local KBBtn = Create("TextButton", {
                    Parent = KBOuter,
                    BackgroundColor3 = Colors.DropBg,
                    BorderSizePixel = 0,
                    Position = UDim2.new(0, 1, 0, 1),
                    Size = UDim2.new(1, -2, 1, -2),
                    Font = Enum.Font.SourceSans,
                    Text = currentKey == Enum.KeyCode.Unknown and "None" or currentKey.Name,
                    TextColor3 = Colors.TextDim,
                    TextSize = 11,
                    AutoButtonColor = false,
                    ZIndex = 5,
                })

                KBBtn.MouseButton1Click:Connect(function()
                    if listening then return end
                    listening = true
                    KBBtn.Text = "..."
                end)

                UserInputService.InputBegan:Connect(function(input, gpe)
                    if listening then
                        if input.UserInputType == Enum.UserInputType.Keyboard then
                            if input.KeyCode == Enum.KeyCode.Escape then
                                currentKey = Enum.KeyCode.Unknown
                                KBBtn.Text = "None"
                            else
                                currentKey = input.KeyCode
                                KBBtn.Text = currentKey.Name
                            end
                            ConfigState[kFlag] = currentKey.Name
                            listening = false
                            return
                        end
                        if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.MouseButton2 then
                            listening = false
                            KBBtn.Text = currentKey == Enum.KeyCode.Unknown and "None" or currentKey.Name
                            return
                        end
                    end
                    if not listening and not gpe and input.UserInputType == Enum.UserInputType.Keyboard then
                        if input.KeyCode == currentKey and currentKey ~= Enum.KeyCode.Unknown then
                            kCallback(currentKey)
                        end
                    end
                end)

                ConfigCallbacks[kFlag] = function(val)
                    local s, k = pcall(function() return Enum.KeyCode[val] end)
                    if s and k then currentKey = k KBBtn.Text = k.Name end
                end

                local obj = {}
                function obj:Set(k) currentKey = k ConfigState[kFlag] = k.Name KBBtn.Text = k == Enum.KeyCode.Unknown and "None" or k.Name end
                function obj:Get() return currentKey end
                return obj
            end

            function Sector:AddTextbox(tOpts)
                local tName = tOpts.Name or "Textbox"
                local tDefault = tOpts.Default or ""
                local tPlaceholder = tOpts.Placeholder or "Type..."
                local tFlag = tOpts.Flag or tName
                local tCallback = tOpts.Callback or function() end

                Sector.ElementCount = Sector.ElementCount + 1
                local currentText = tDefault
                ConfigState[tFlag] = currentText

                local Frame = Create("Frame", {
                    Parent = SectorContent,
                    BackgroundTransparency = 1,
                    Size = UDim2.new(1, 0, 0, 32),
                    LayoutOrder = Sector.ElementCount,
                })

                local Label = Create("TextLabel", {
                    Parent = Frame,
                    BackgroundTransparency = 1,
                    Position = UDim2.new(0, 0, 0, 0),
                    Size = UDim2.new(1, 0, 0, 13),
                    Font = Enum.Font.SourceSans,
                    Text = tName,
                    TextColor3 = Colors.TextDim,
                    TextSize = 13,
                    TextXAlignment = Enum.TextXAlignment.Left,
                })

                local TBOuter = Create("Frame", {
                    Parent = Frame,
                    BackgroundColor3 = Colors.Border,
                    BorderSizePixel = 0,
                    Position = UDim2.new(0, 0, 0, 15),
                    Size = UDim2.new(1, 0, 0, 17),
                })

                local TBBox = Create("TextBox", {
                    Parent = TBOuter,
                    BackgroundColor3 = Colors.DropBg,
                    BorderSizePixel = 0,
                    Position = UDim2.new(0, 1, 0, 1),
                    Size = UDim2.new(1, -2, 1, -2),
                    Font = Enum.Font.SourceSans,
                    Text = currentText,
                    PlaceholderText = tPlaceholder,
                    PlaceholderColor3 = Colors.TextDark,
                    TextColor3 = Colors.TextDim,
                    TextSize = 12,
                    TextXAlignment = Enum.TextXAlignment.Left,
                    ClearTextOnFocus = false,
                    ClipsDescendants = true,
