        if not v then pcall(function() InvViewer:Clear() InvViewer:SetTarget("") end) end
    end})
    SecInv1:Toggle({ Name = "show full inventory", Default = false, Callback = function(v) inv_full   = v end})
    SecInv1:Toggle({ Name = "include corpse",      Default = false, Callback = function(v) inv_corpse = v end})
    SecInv1:Toggle({ Name = "include NPC",         Default = false, Callback = function(v) inv_npc    = v end})
    SecInv1:Slider({ Name = "refresh delay", Default = 0.2, Min = 0.05, Max = 2, Decimals = 1.01, Callback = function(v) inv_delay = v end})

    local function formatMoney(n)
        local s = tostring(math.floor(n or 0))
        while true do local k; s, k = s:gsub("^(-?%%d+)(%%d%%d%%d)", "%%1,%%2"); if k==0 then break end end
        return "$" .. s
    end

    local function get_inventory(char)
        local plr = Players:GetPlayerFromCharacter(char)
        local inv = char:FindFirstChild("Inventory")
        if not inv and plr then
            local rp  = ReplicatedStorage:FindFirstChild("Players")
            local rpp = rp and rp:FindFirstChild(plr.Name)
            inv = rpp and rpp:FindFirstChild("Inventory")
        end
        return inv
    end

    local function read_and_price(inv)
        if not inv then return {}, 0 end
        local il  = ReplicatedStorage:FindFirstChild("ItemsList")
        local items = {}
        local total = 0
        local function proc(slot, hidden)
            local n = slot.Name:lower()
            if n:find("dagr") or n:find("lighter") or n:find("compass") then return end
            local ir = il and il:FindFirstChild(slot.Name)
            if not ir then return end
            local props = ir:FindFirstChild("ItemProperties")
            if not props then return end
            local itype = props:GetAttribute("ItemType") or "Other"
            if itype == "Melee" or itype == "MeleeWeapon" then return end
            local price = props:GetAttribute("Price") or 1
            local amt_attr = tonumber(slot:GetAttribute("Amount")) or 1
            if price >= 10 then
                if     itype == "Extra"    then price = price * 0.4
                elseif itype == "Ammo"     then price = price * amt_attr * 0.7
                elseif itype == "Clothing" then price = price * 0.35
                elseif itype == "Medical"  then price = price * 0.75
                elseif itype == "Barter"   then price = price * 0.4 end
            end
            if slot.Name == "Rubles" then total = total + amt_attr
            else total = total + price end
            if hidden then return end
            local amt = 1
            for _, a in ipairs({"Amount","Count","Quantity"}) do
                local v = tonumber(slot:GetAttribute(a))
                if v and v > 1 then amt = math.floor(v+0.5) end
            end
            local img = nil
            pcall(function() img = props.ItemIcon.Image end)
            items[#items+1] = { Name = slot.Name, Image = img or "", Count = amt, Type = itype }
        end
        for _, slot in pairs(inv:GetChildren()) do
            proc(slot, false)
            if inv_full and slot:FindFirstChild("Inventory") then
                for _, sub in pairs(slot.Inventory:GetChildren()) do proc(sub, false) end
            end
            if slot:FindFirstChild("Attachments") then
                for _, att in pairs(slot.Attachments:GetChildren()) do proc(att, true) end
            end
        end
        return items, total
    end

    local function find_closest()
        if silent_aim and silent_aim.target_part and pcall(function() return silent_aim.target_part.Parent end) and silent_aim.target_part.Parent then
            local char = silent_aim.target_part.Parent
            local head = char:FindFirstChild("Head")
            if head then
                local ok, sp, ov = pcall(function() return Camera:WorldToViewportPoint(head.Position) end)
                if ok and ov then
                    local mousepos = _Vector2new(Mouse.X, Mouse.Y)
                    local dist_to_crosshair = (Vector2.new(sp.X, sp.Y) - mousepos).Magnitude
                    if dist_to_crosshair <= 250 then
                        return char
                    end
                end
            end
        end
        local mousepos = _Vector2new(Mouse.X, Mouse.Y)
        local best_dist = math.huge
        local best = nil
        for _, p in ipairs(Players:GetPlayers()) do
            if p ~= LocalPlayer and p.Character then
                local head = p.Character:FindFirstChild("Head")
                if head then
                    local ok, sp, ov = pcall(function() return Camera:WorldToViewportPoint(head.Position) end)
                    if ok and ov then
                        local mag = (Vector2.new(sp.X, sp.Y) - mousepos).Magnitude
                        if mag < best_dist and mag <= 250 then best_dist = mag; best = p.Character end
                    end
                end
            end
        end
        if inv_corpse then
            local dropped = workspace:FindFirstChild("DroppedItems")
            if dropped then
                for _, item in pairs(dropped:GetChildren()) do
                    local head = item:FindFirstChild("Head")
                    if head then
                        local ok, sp, ov = pcall(function() return Camera:WorldToViewportPoint(head.Position) end)
                        if ok and ov then
                            local mag = (Vector2.new(sp.X, sp.Y) - mousepos).Magnitude
                            if mag < best_dist and mag <= 250 then best_dist = mag; best = item end
                        end
                    end
                end
            end
        end
        if inv_npc then
            local ai = workspace:FindFirstChild("AiZones")
            if ai then
                for _, zone in pairs(ai:GetChildren()) do
                    for _, npc in pairs(zone:GetChildren()) do
                        local head = npc:FindFirstChild("Head")
                        if head then
                            local ok, sp, ov = pcall(function() return Camera:WorldToViewportPoint(head.Position) end)
                            if ok and ov then
                                local mag = (Vector2.new(sp.X, sp.Y) - mousepos).Magnitude
                                if mag < best_dist and mag <= 250 then best_dist = mag; best = npc end
                            end
                        end
                    end
                end
            end
        end
        return best
    end

    cheat.utility.new_renderstepped(function()
        if not inv_on then return end
        if tick() - inv_timer < inv_delay then return end
        inv_timer = tick()

        local target = find_closest()
        if not target then
            if inv_last then
                inv_last = nil
                pcall(function()
                    InvViewer:Clear()
                    InvViewer:SetTarget("")
                    InvViewer:SetSummary("")
                end)
            end
            return
        end

        if target == inv_last then return end
        inv_last = target

        local plr  = Players:GetPlayerFromCharacter(target)
        local name = plr and plr.Name or target.Name

        local inv = get_inventory(target)
        local all, total_val = read_and_price(inv)

        local summary = #all .. " items | " .. formatMoney(math.floor(total_val))

        local cats = { Weapons={}, Ammo={}, Medical={}, Armor={}, Other={} }
        local cmap = {
            Ranged="Weapons", Weapon="Weapons", Pistol="Weapons", SMG="Weapons",
            Ammo="Ammo", Medical="Medical", Consumable="Medical",
            Clothing="Armor", Armor="Armor",
        }
        for _, e in ipairs(all) do
            local c = cmap[e.Type] or "Other"
            cats[c][#cats[c]+1] = e
        end
        local secs = {}
        for _, k in ipairs({"Weapons","Ammo","Medical","Armor","Other"}) do
            if #cats[k] > 0 then secs[#secs+1] = { Name=k, Entries=cats[k] } end
        end

        pcall(function()
            InvViewer:SetTarget(name)
            InvViewer:SetSummary(summary)
            if #secs > 0 then
                InvViewer:SetSections(secs)
            else
                InvViewer:Clear()
                InvViewer:SetSummary("no items")
            end
        end)
    end)
end



