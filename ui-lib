function GamesenseLib:Notify(options)
    if not NotificationContainer then return end
    local text = options.Text or "Notification"
    local duration = options.Duration or 3

    local NotifFrame = Create("Frame", {
        Name = "Notification",
        Parent = NotificationContainer,
        BackgroundColor3 = Colors.NotifBg,
        BorderSizePixel = 0,
        Size = UDim2.new(0, 280, 0, 32),
        ClipsDescendants = true,
        BackgroundTransparency = 1,
    })

    local NotifAccent = Create("Frame", {
        Name = "Accent",
        Parent = NotifFrame,
        BackgroundColor3 = Colors.Accent,
        BorderSizePixel = 0,
        Position = UDim2.new(0, 0, 0, 0),
        Size = UDim2.new(0, 2, 1, 0),
    })

    Create("UIStroke", {
        Parent = NotifFrame,
        Color = Colors.Border,
        Thickness = 1,
        ApplyStrokeMode = Enum.ApplyStrokeMode.Border,
    })

    local NotifLabel = Create("TextLabel", {
        Parent = NotifFrame,
        BackgroundTransparency = 1,
        Position = UDim2.new(0, 10, 0, 0),
        Size = UDim2.new(1, -14, 1, 0),
        Font = Enum.Font.SourceSans,
        Text = text,
        TextColor3 = Colors.TextDim,
        TextSize = 13,
        TextXAlignment = Enum.TextXAlignment.Left,
        TextTransparency = 1,
    })

    Tween(NotifFrame, {BackgroundTransparency = 0}, 0.25)
    Tween(NotifLabel, {TextTransparency = 0}, 0.25)

    task.delay(duration, function()
        Tween(NotifFrame, {BackgroundTransparency = 1}, 0.3)
        Tween(NotifLabel, {TextTransparency = 1}, 0.3)
        task.wait(0.35)
        NotifFrame:Destroy()
    end)
end

