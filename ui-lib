                CPPreview.MouseButton1Click:Connect(function()
                    cpOpen = not cpOpen
                    if cpOpen then
                        local absPos = CPPreview.AbsolutePosition
                        CPPanel.Position = UDim2.new(0, absPos.X - 160, 0, absPos.Y + 18)
                        CPPanel.Visible = true
                        UpdateColorDisplay()
                    else
                        CPPanel.Visible = false
                    end
                end)

                ConfigCallbacks[cFlag] = function(val)
                    if typeof(val) == "Color3" then
                        currentColor = val
                        currentH, currentS, currentV = Color3.toHSV(val)
                        UpdateColorDisplay()
                    end
                end

                cCallback(currentColor)

                local CPObj = {}

                function CPObj:Set(color)
                    currentColor = color
                    currentH, currentS, currentV = Color3.toHSV(color)
                    ConfigState[cFlag] = currentColor
                    UpdateColorDisplay()
                end

                function CPObj:Get()
                    return currentColor
                end

                return CPObj
            end

            function Sector:AddKeybind(kbOptions)
                local kName = kbOptions.Name or "Keybind"
                local kDefault = kbOptions.Default or Enum.KeyCode.Unknown
                local kFlag = kbOptions.Flag or kName
                local kCallback = kbOptions.Callback or function() end
                local kMode = kbOptions.Mode or "Toggle"

                Sector.ElementCount = Sector.ElementCount + 1

                local currentKey = kDefault
                local listening = false

                ConfigState[kFlag] = currentKey.Name

                local KBFrame = Create("Frame", {
                    Name = "Keybind_" .. kName,
                    Parent = SectorContent,
                    BackgroundTransparency = 1,
                    Size = UDim2.new(1, 0, 0, 18),
                    LayoutOrder = Sector.ElementCount,
                })

                local KBLabel = Create("TextLabel", {
                    Name = "Label",
                    Parent = KBFrame,
                    BackgroundTransparency = 1,
                    Position = UDim2.new(0, 0, 0, 0),
                    Size = UDim2.new(1, -60, 1, 0),
                    Font = Enum.Font.SourceSans,
                    Text = kName,
                    TextColor3 = Colors.TextDim,
                    TextSize = 13,
                    TextXAlignment = Enum.TextXAlignment.Left,
                })

                local KBButton = Create("TextButton", {
                    Name = "KBButton",
                    Parent = KBFrame,
                    BackgroundColor3 = Colors.SliderBg,
                    BorderSizePixel = 0,
                    Position = UDim2.new(1, -55, 0, 1),
                    Size = UDim2.new(0, 55, 0, 16),
                    Font = Enum.Font.SourceSans,
                    Text = currentKey == Enum.KeyCode.Unknown and "None" or currentKey.Name,
                    TextColor3 = Colors.TextDim,
                    TextSize = 11,
                    AutoButtonColor = false,
                    ZIndex = 5,
                })

                local KBButtonStroke = Create("UIStroke", {
                    Parent = KBButton,
                    Color = Colors.Border,
                    Thickness = 1,
                    ApplyStrokeMode = Enum.ApplyStrokeMode.Border,
                })

                KBButton.MouseButton1Click:Connect(function()
                    if listening then return end
                    listening = true
                    KBButton.Text = "..."
                    Tween(KBButton, {BackgroundColor3 = Colors.LightBackground}, 0.1)
                end)

                UserInputService.InputBegan:Connect(function(input, gpe)
                    if listening then
                        if input.UserInputType == Enum.UserInputType.Keyboard then
                            if input.KeyCode == Enum.KeyCode.Escape then
                                currentKey = Enum.KeyCode.Unknown
                                KBButton.Text = "None"
                            else
                                currentKey = input.KeyCode
                                KBButton.Text = currentKey.Name
                            end
                            ConfigState[kFlag] = currentKey.Name
                            listening = false
                            Tween(KBButton, {BackgroundColor3 = Colors.SliderBg}, 0.1)
                            return
                        elseif input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.MouseButton2 then
                            listening = false
                            KBButton.Text = currentKey == Enum.KeyCode.Unknown and "None" or currentKey.Name
                            Tween(KBButton, {BackgroundColor3 = Colors.SliderBg}, 0.1)
                            return
                        end
                    end

                    if not listening and not gpe then
                        if input.UserInputType == Enum.UserInputType.Keyboard then
                            if input.KeyCode == currentKey and currentKey ~= Enum.KeyCode.Unknown then
                                kCallback(currentKey)
                            end
                        end
                    end
                end)

                ConfigCallbacks[kFlag] = function(val)
                    local success, key = pcall(function()
                        return Enum.KeyCode[val]
                    end)
                    if success and key then
                        currentKey = key
                        KBButton.Text = key.Name
                    end
                end

                local KBObj = {}

                function KBObj:Set(key)
                    currentKey = key
                    ConfigState[kFlag] = currentKey.Name
                    KBButton.Text = key == Enum.KeyCode.Unknown and "None" or key.Name
                end

                function KBObj:Get()
                    return currentKey
                end

                return KBObj
            end

            function Sector:AddLabel(labelOptions)
                local lText = labelOptions.Text or "Label"

                Sector.ElementCount = Sector.ElementCount + 1

                local LabelFrame = Create("Frame", {
                    Name = "Label",
                    Parent = SectorContent,
                    BackgroundTransparency = 1,
                    Size = UDim2.new(1, 0, 0, 16),
                    LayoutOrder = Sector.ElementCount,
                })

                local LabelText = Create("TextLabel", {
                    Name = "Text",
                    Parent = LabelFrame,
                    BackgroundTransparency = 1,
                    Size = UDim2.new(1, 0, 1, 0),
                    Font = Enum.Font.SourceSans,
                    Text = lText,
                    TextColor3 = Colors.TextDark,
                    TextSize = 13,
                    TextXAlignment = Enum.TextXAlignment.Left,
                })

                local LabelObj = {}

                function LabelObj:SetText(txt)
                    LabelText.Text = txt
                end

                return LabelObj
            end

            return Sector
        end

        return Tab
    end

    UserInputService.InputBegan:Connect(function(input, gpe)
        if input.UserInputType == Enum.UserInputType.MouseButton1 then
            if ActiveDropdown and ActiveDropdown.Visible then
                local absPos = ActiveDropdown.AbsolutePosition
                local absSize = ActiveDropdown.AbsoluteSize
                local mousePos = UserInputService:GetMouseLocation()
                if mousePos.X < absPos.X or mousePos.X > absPos.X + absSize.X or
                    mousePos.Y < absPos.Y or mousePos.Y > absPos.Y + absSize.Y then
                    ActiveDropdown.Visible = false
                    ActiveDropdown = nil
                end
            end
        end
    end)

    return Window
end

return GamesenseLib
