            function Sector:AddPlayerList(plOptions)
                Sector.ElementCount = Sector.ElementCount + 1

                local plName = plOptions.Name or "Players"
                local plFlag = plOptions.Flag or plName
                local plCallback = plOptions.Callback or function() end
                local plHeight = plOptions.Height or 100

                local selectedPlayers = {}

                local plFrame = Create("Frame", {
                    Name = "PlayerList_" .. plName,
                    Parent = sectorContent,
                    BackgroundTransparency = 1,
                    Size = UDim2.new(1, 0, 0, 14 + plHeight),
                    LayoutOrder = Sector.ElementCount,
                })

                Create("TextLabel", {
                    Parent = plFrame,
                    BackgroundTransparency = 1,
                    Position = UDim2.new(0, 0, 0, 0),
                    Size = UDim2.new(1, 0, 0, 14),
                    Font = Enum.Font.SourceSans,
                    Text = plName,
                    TextColor3 = C.TextDim,
                    TextSize = 13,
                    TextXAlignment = Enum.TextXAlignment.Left,
                })

                local plOuter = Create("Frame", {
                    Parent = plFrame,
                    BackgroundColor3 = C.InputOuter,
                    BorderSizePixel = 0,
                    Position = UDim2.new(0, 0, 0, 15),
                    Size = UDim2.new(1, 0, 0, plHeight),
                })

                local plScroll = Create("ScrollingFrame", {
                    Parent = plOuter,
                    BackgroundColor3 = C.InputBg,
                    BorderSizePixel = 0,
                    Position = UDim2.new(0, 1, 0, 1),
                    Size = UDim2.new(1, -2, 1, -2),
                    ScrollBarThickness = 2,
                    ScrollBarImageColor3 = C.GroupInner,
                    AutomaticCanvasSize = Enum.AutomaticSize.Y,
                    ScrollingDirection = Enum.ScrollingDirection.Y,
                    ClipsDescendants = true,
                })

                Create("UIListLayout", {
                    Parent = plScroll,
                    SortOrder = Enum.SortOrder.LayoutOrder,
                    Padding = UDim.new(0, 0),
                })

                local function refreshPlayerList()
                    for _, child in pairs(plScroll:GetChildren()) do
                        if child:IsA("TextButton") then
                            child:Destroy()
                        end
                    end

                    for index, player in ipairs(Players:GetPlayers()) do
                        if player ~= LocalPlayer then
                            local isSelected = selectedPlayers[player.Name] == true

                            local playerButton = Create("TextButton", {
                                Parent = plScroll,
                                BackgroundColor3 = C.InputBg,
                                BorderSizePixel = 0,
                                Size = UDim2.new(1, 0, 0, 18),
                                Font = Enum.Font.SourceSans,
                                Text = "  " .. player.Name,
                                TextColor3 = isSelected and C.Accent or C.TextDim,
                                TextSize = 12,
                                TextXAlignment = Enum.TextXAlignment.Left,
                                AutoButtonColor = false,
                                LayoutOrder = index,
                            })

                            playerButton.MouseEnter:Connect(function()
                                playerButton.BackgroundColor3 = C.DropdownHover
                            end)

                            playerButton.MouseLeave:Connect(function()
                                playerButton.BackgroundColor3 = C.InputBg
                            end)

                            playerButton.MouseButton1Click:Connect(function()
                                if selectedPlayers[player.Name] then
                                    selectedPlayers[player.Name] = nil
                                else
                                    selectedPlayers[player.Name] = true
                                end
                                playerButton.TextColor3 = selectedPlayers[player.Name] and C.Accent or C.TextDim
                                plCallback(selectedPlayers)
                            end)
                        end
                    end
                end

                refreshPlayerList()

                Players.PlayerAdded:Connect(function()
                    task.wait(0.5)
                    refreshPlayerList()
                end)

                Players.PlayerRemoving:Connect(function(player)
                    selectedPlayers[player.Name] = nil
                    task.wait(0.1)
                    refreshPlayerList()
                end)

                local plObject = {}

                function plObject:Get()
                    return selectedPlayers
                end

                function plObject:Refresh()
                    refreshPlayerList()
                end

                return plObject
            end

