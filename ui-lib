local function SaveCfg(n)
    local d = {}
    for k, v in pairs(ConfigState) do
        if typeof(v) == "Color3" then d[k] = {T = "C3", R = v.R, G = v.G, B = v.B}
        elseif typeof(v) == "EnumItem" then d[k] = {T = "EI", V = tostring(v)}
        elseif type(v) == "table" then d[k] = {T = "TBL", V = v}
        else d[k] = v end
    end
    if not isfolder(ConfigFolder) then makefolder(ConfigFolder) end
    writefile(ConfigFolder .. "/" .. n .. ".json", HttpService:JSONEncode(d))
end

local function LoadCfg(n)
    local p = ConfigFolder .. "/" .. n .. ".json"
    if not isfile(p) then return false end
    local d = HttpService:JSONDecode(readfile(p))
    for k, v in pairs(d) do
        if type(v) == "table" then
            if v.T == "C3" then ConfigState[k] = Color3.new(v.R, v.G, v.B)
            elseif v.T == "TBL" then ConfigState[k] = v.V
            else ConfigState[k] = v end
        else ConfigState[k] = v end
        if ConfigCallbacks[k] then ConfigCallbacks[k](ConfigState[k]) end
    end
    return true
end

local function C2H(c) return string.format("#%02X%02X%02X", math.floor(c.R * 255 + .5), math.floor(c.G * 255 + .5), math.floor(c.B * 255 + .5)) end
local function H2C(h) h = h:gsub("#", "") if #h ~= 6 then return nil end local r, g, b = tonumber(h:sub(1, 2), 16), tonumber(h:sub(3, 4), 16), tonumber(h:sub(5, 6), 16) if r and g and b then return Color3.fromRGB(r, g, b) end return nil end

local function MakeBBox(parent, pos, sz, zi)
    zi = zi or 1
    local o = Create("Frame", {Parent = parent, BackgroundColor3 = C.WmBorder, BorderSizePixel = 0, Position = pos, Size = sz, ZIndex = zi})
    local i = Create("Frame", {Parent = o, BackgroundColor3 = C.WmInner, BorderSizePixel = 0, Position = UDim2.new(0, 1, 0, 1), Size = UDim2.new(1, -2, 1, -2), ZIndex = zi + 1})
    local a = Create("Frame", {Parent = i, BackgroundColor3 = C.Accent, BorderSizePixel = 0, Size = UDim2.new(1, 0, 0, 2), ZIndex = zi + 3})
    Create("UIGradient", {Parent = a, Color = ColorSequence.new({ColorSequenceKeypoint.new(0, C.AccentDark), ColorSequenceKeypoint.new(0.5, C.Accent), ColorSequenceKeypoint.new(1, C.AccentGlow)})})
    local d = Create("Frame", {Parent = i, BackgroundColor3 = C.WmBorder, BorderSizePixel = 0, Position = UDim2.new(0, 1, 0, 2), Size = UDim2.new(1, -2, 1, -3), ZIndex = zi + 2})
    local bg = Create("Frame", {Parent = d, BackgroundColor3 = C.WmBg, BorderSizePixel = 0, Position = UDim2.new(0, 1, 0, 1), Size = UDim2.new(1, -2, 1, -2), ZIndex = zi + 3})
    return o, bg, a
end

