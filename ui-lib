function GamesenseLib:Notify(options)
    if not ScreenGui then return end

    local text = options.Text or "Notification"
    local duration = options.Duration or 3
    local notifType = options.Type or "info"

    local notifContainer = ScreenGui:FindFirstChild("NotificationContainer")
    if not notifContainer then
        notifContainer = Create("Frame", {
            Name = "NotificationContainer",
            Parent = ScreenGui,
            BackgroundTransparency = 1,
            Position = UDim2.new(1, -320, 0, 10),
            Size = UDim2.new(0, 310, 1, -20),
            ZIndex = 500,
        })
        Create("UIListLayout", {
            Parent = notifContainer,
            FillDirection = Enum.FillDirection.Vertical,
            VerticalAlignment = Enum.VerticalAlignment.Bottom,
            SortOrder = Enum.SortOrder.LayoutOrder,
            Padding = UDim.new(0, 4),
        })
    end

    local notifOuter, notifBg, notifAccent = CreateDoubleBorederedFrame(
        notifContainer,
        UDim2.new(0, 0, 0, 0),
        UDim2.new(1, 0, 0, 28),
        500
    )

    notifOuter.BackgroundTransparency = 1
    for _, desc in pairs(notifOuter:GetDescendants()) do
        if desc:IsA("Frame") then
            desc.BackgroundTransparency = 1
        end
    end

    local notifLabel = Create("TextLabel", {
        Parent = notifBg,
        BackgroundTransparency = 1,
        Position = UDim2.new(0, 8, 0, 0),
        Size = UDim2.new(1, -16, 1, 0),
        Font = Enum.Font.SourceSans,
        Text = text,
        TextColor3 = C.TextDim,
        TextSize = 12,
        TextXAlignment = Enum.TextXAlignment.Left,
        TextTransparency = 1,
        ZIndex = 506,
    })

    for _, desc in pairs(notifOuter:GetDescendants()) do
        if desc:IsA("Frame") then
            Tween(desc, {BackgroundTransparency = 0}, 0.25)
        end
    end
    Tween(notifLabel, {TextTransparency = 0}, 0.3)

    task.delay(duration, function()
        for _, desc in pairs(notifOuter:GetDescendants()) do
            if desc:IsA("Frame") then
                Tween(desc, {BackgroundTransparency = 1}, 0.3)
            end
        end
        Tween(notifLabel, {TextTransparency = 1}, 0.3)
        task.wait(0.35)
        if notifOuter and notifOuter.Parent then
            notifOuter:Destroy()
        end
    end)
end

