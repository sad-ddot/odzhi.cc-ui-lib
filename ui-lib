            end

            function S:AddMultiDropdown(o) S.EC = S.EC + 1 local nm = o.Name or "Multi" local items = o.Items or {} local def = o.Default or {} local fl = o.Flag or nm local cb = o.Callback or function() end local sel = {} for _, v in ipairs(def) do sel[v] = true end local isOpen = false ConfigState[fl] = sel
