    })

    local thHpFill = Create("Frame", {
        Parent = thHpBg,
        BackgroundColor3 = Color3.fromRGB(80, 200, 80),
        BorderSizePixel = 0,
        Size = UDim2.new(1, 0, 1, 0),
        ZIndex = 186,
    })

    Create("UIGradient", {
        Parent = thHpFill,
        Color = ColorSequence.new(
            Color3.fromRGB(60, 180, 60),
            Color3.fromRGB(100, 220, 100)
        ),
    })

    local thHpText = Create("TextLabel", {
        Parent = thHpBg,
        BackgroundTransparency = 1,
        Size = UDim2.new(1, -6, 1, 0),
        Position = UDim2.new(0, 3, 0, 0),
        Font = Enum.Font.SourceSansBold,
        Text = "100/100",
        TextColor3 = C.White,
        TextSize = 12,
        TextXAlignment = Enum.TextXAlignment.Right,
        ZIndex = 187,
    })

    local currentTarget = nil

    local function updateTargetHud()
        if not currentTarget then
            if thOuter.Visible then
                Tween(thOuter, {BackgroundTransparency = 1}, 0.2)
                for _, desc in pairs(thOuter:GetDescendants()) do
                    if desc:IsA("Frame") then
                        Tween(desc, {BackgroundTransparency = 1}, 0.2)
                    end
                    if desc:IsA("TextLabel") then
                        Tween(desc, {TextTransparency = 1}, 0.2)
                    end
                    if desc:IsA("ImageLabel") then
                        Tween(desc, {ImageTransparency = 1}, 0.2)
                    end
                end
                task.delay(0.25, function()
                    thOuter.Visible = false
                end)
            end
            return
        end

        if not currentTarget.Character then
            currentTarget = nil
            return
        end

        local humanoid = currentTarget.Character:FindFirstChild("Humanoid")
        local rootPart = currentTarget.Character:FindFirstChild("HumanoidRootPart")

        if not humanoid or not rootPart or humanoid.Health <= 0 then
            currentTarget = nil
            return
        end

        local myRoot = LocalPlayer.Character and LocalPlayer.Character:FindFirstChild("HumanoidRootPart")

        if not thOuter.Visible then
            thOuter.Visible = true
            thOuter.BackgroundTransparency = 1
            for _, desc in pairs(thOuter:GetDescendants()) do
                if desc:IsA("Frame") then
                    desc.BackgroundTransparency = 1
                end
                if desc:IsA("TextLabel") then
                    desc.TextTransparency = 1
                end
                if desc:IsA("ImageLabel") then
                    desc.ImageTransparency = 1
                end
            end
            Tween(thOuter, {BackgroundTransparency = 0}, 0.2)
            for _, desc in pairs(thOuter:GetDescendants()) do
                if desc:IsA("Frame") then
                    Tween(desc, {BackgroundTransparency = 0}, 0.2)
                end
                if desc:IsA("TextLabel") then
                    Tween(desc, {TextTransparency = 0}, 0.2)
                end
                if desc:IsA("ImageLabel") then
                    Tween(desc, {ImageTransparency = 0}, 0.2)
                end
            end
        end

        thName.Text = currentTarget.Name
        thIcon.Image = "https://www.roblox.com/headshot-thumbnail/image?userId=" .. currentTarget.UserId .. "&width=150&height=150&format=png"

        local distance = 0
        if myRoot then
            distance = math.floor((myRoot.Position - rootPart.Position).Magnitude)
        end
        thDist.Text = distance .. "m away"

        local hp = math.floor(humanoid.Health)
        local maxHp = math.floor(humanoid.MaxHealth)
        local hpPct = math.clamp(humanoid.Health / humanoid.MaxHealth, 0, 1)

        thHpFill.Size = UDim2.new(hpPct, 0, 1, 0)
        thHpText.Text = hp .. "/" .. maxHp

        if hpPct > 0.5 then
            thHpFill.BackgroundColor3 = Color3.fromRGB(80, 200, 80)
        elseif hpPct > 0.25 then
            thHpFill.BackgroundColor3 = Color3.fromRGB(220, 180, 50)
        else
            thHpFill.BackgroundColor3 = Color3.fromRGB(220, 50, 50)
        end

        local isVisible = false
        if myRoot and rootPart then
            local ray = Ray.new(myRoot.Position, (rootPart.Position - myRoot.Position).Unit * 1000)
            local hit = workspace:FindPartOnRayWithIgnoreList(ray, {LocalPlayer.Character})
            if hit and hit:IsDescendantOf(currentTarget.Character) then
                isVisible = true
            end
        end

        thInfo.Text = (isVisible and "VISIBLE" or "HIDDEN") .. " - HEAD"
        thInfo.TextColor3 = isVisible and Color3.fromRGB(100, 220, 100) or Color3.fromRGB(220, 80, 80)
    end

    RunService.Heartbeat:Connect(function()
        if ConfigState["TargetHUD"] then
            local closestPlayer = nil
            local closestDist = 500

            for _, player in ipairs(Players:GetPlayers()) do
                if player ~= LocalPlayer and player.Character then
                    local hrp = player.Character:FindFirstChild("HumanoidRootPart")
                    local hum = player.Character:FindFirstChild("Humanoid")

                    if hrp and hum and hum.Health > 0 then
                        local screenPos, onScreen = Camera:WorldToViewportPoint(hrp.Position)

                        if onScreen then
                            local center = Vector2.new(
                                Camera.ViewportSize.X / 2,
                                Camera.ViewportSize.Y / 2
                            )
                            local playerPos = Vector2.new(screenPos.X, screenPos.Y)
                            local screenDist = (center - playerPos).Magnitude

                            if screenDist < closestDist and screenDist < 200 then
                                closestDist = screenDist
                                closestPlayer = player
                            end
                        end
                    end
                end
            end

            currentTarget = closestPlayer
            updateTargetHud()
        else
            if thOuter.Visible then
                thOuter.Visible = false
            end
            currentTarget = nil
        end
    end)

    return thOuter
end

function GamesenseLib:Notify(options)
    if not ScreenGui then
        return
    end

    local notifText = options.Text or ""
    local notifDuration = options.Duration or 3

    local notifContainer = ScreenGui:FindFirstChild("NotifContainer")
    if not notifContainer then
        notifContainer = Create("Frame", {
            Name = "NotifContainer",
            Parent = ScreenGui,
            BackgroundTransparency = 1,
            Position = UDim2.new(1, -325, 0, 10),
            Size = UDim2.new(0, 315, 1, -20),
            ZIndex = 500,
        })

        Create("UIListLayout", {
            Parent = notifContainer,
            FillDirection = Enum.FillDirection.Vertical,
            VerticalAlignment = Enum.VerticalAlignment.Bottom,
            SortOrder = Enum.SortOrder.LayoutOrder,
            Padding = UDim.new(0, 4),
        })
    end

    local notifOuter, notifBg = CreateBorderedBox(
        notifContainer,
        UDim2.new(0, 0, 0, 0),
        UDim2.new(1, 0, 0, 30),
        500
    )

    notifOuter.BackgroundTransparency = 1
    for _, desc in pairs(notifOuter:GetDescendants()) do
        if desc:IsA("Frame") then
            desc.BackgroundTransparency = 1
        end
    end

    local notifLabel = Create("TextLabel", {
        Parent = notifBg,
        BackgroundTransparency = 1,
        Position = UDim2.new(0, 8, 0, 0),
        Size = UDim2.new(1, -16, 1, 0),
        Font = Enum.Font.SourceSans,
        Text = notifText,
        TextColor3 = C.TextDim,
        TextSize = 12,
        TextXAlignment = Enum.TextXAlignment.Left,
        TextTransparency = 1,
        ZIndex = 506,
    })

    for _, desc in pairs(notifOuter:GetDescendants()) do
        if desc:IsA("Frame") then
            Tween(desc, {BackgroundTransparency = 0}, 0.25)
        end
    end
    Tween(notifLabel, {TextTransparency = 0}, 0.3)

    task.delay(notifDuration, function()
        for _, desc in pairs(notifOuter:GetDescendants()) do
            if desc:IsA("Frame") then
                Tween(desc, {BackgroundTransparency = 1}, 0.3)
            end
        end
        Tween(notifLabel, {TextTransparency = 1}, 0.3)
        task.wait(0.35)
        if notifOuter and notifOuter.Parent then
            notifOuter:Destroy()
        end
    end)
end

