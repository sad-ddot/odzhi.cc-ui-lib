function GamesenseLib:Notify(options)
    if not ScreenGui then
        return
    end

    if not WindowRef or not WindowRef.Visible then
        return
    end

    local notifText = options.Text or "Notification"
    local notifDuration = options.Duration or 3

    local notifContainer = ScreenGui:FindFirstChild("NotificationContainer")
    if not notifContainer then
        notifContainer = Create("Frame", {
            Name = "NotificationContainer",
            Parent = ScreenGui,
            BackgroundTransparency = 1,
            Position = UDim2.new(1, -325, 0, 10),
            Size = UDim2.new(0, 315, 1, -20),
            ZIndex = 500,
        })

        Create("UIListLayout", {
            Parent = notifContainer,
            FillDirection = Enum.FillDirection.Vertical,
            VerticalAlignment = Enum.VerticalAlignment.Bottom,
            SortOrder = Enum.SortOrder.LayoutOrder,
            Padding = UDim.new(0, 4),
        })
    end

    local notifOuterFrame, notifBackground, notifAccent = CreateBorderedBox(
        notifContainer,
        UDim2.new(0, 0, 0, 0),
        UDim2.new(1, 0, 0, 30),
        500
    )

    notifOuterFrame.BackgroundTransparency = 1
    for _, descendant in pairs(notifOuterFrame:GetDescendants()) do
        if descendant:IsA("Frame") then
            descendant.BackgroundTransparency = 1
        end
    end

    local notifLabel = Create("TextLabel", {
        Parent = notifBackground,
        BackgroundTransparency = 1,
        Position = UDim2.new(0, 8, 0, 0),
        Size = UDim2.new(1, -16, 1, 0),
        Font = Enum.Font.SourceSans,
        Text = notifText,
        TextColor3 = C.TextDim,
        TextSize = 12,
        TextXAlignment = Enum.TextXAlignment.Left,
        TextTransparency = 1,
        ZIndex = 506,
    })

    for _, descendant in pairs(notifOuterFrame:GetDescendants()) do
        if descendant:IsA("Frame") then
            Tween(descendant, {BackgroundTransparency = 0}, 0.25)
        end
    end
    Tween(notifLabel, {TextTransparency = 0}, 0.3)

    task.delay(notifDuration, function()
        for _, descendant in pairs(notifOuterFrame:GetDescendants()) do
            if descendant:IsA("Frame") then
                Tween(descendant, {BackgroundTransparency = 1}, 0.3)
            end
        end
        Tween(notifLabel, {TextTransparency = 1}, 0.3)

        task.wait(0.35)
        if notifOuterFrame and notifOuterFrame.Parent then
            notifOuterFrame:Destroy()
        end
    end)
end

