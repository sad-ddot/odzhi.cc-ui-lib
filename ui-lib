        ClearTextOnFocus = false,
        Parent = Box,
    })
    Library:_Bind(Input, "PlaceholderColor3", "SubText")
    Library:_Bind(Input, "TextColor3", "Text")

    Input.Focused:Connect(function()
        Util.Tween(boxStroke, { Color = Library.Theme.Accent }, 0.12)
    end)

    Input.FocusLost:Connect(function(enterPressed)
        Util.Tween(boxStroke, { Color = Library.Theme.Border }, 0.12)
        local ok, err = pcall(callback, Input.Text, enterPressed)
        if not ok then warn("[UILib] Textbox callback error: " .. tostring(err)) end
        if flag then Library.Flags[flag] = Input.Text end
    end)
    Library:_Register(function()
        if not Input:IsFocused() then
            boxStroke.Color = Library.Theme.Border
        end
    end)
    boxStroke.Color = Library.Theme.Border

    local function setValue(v)
        Input.Text = tostring(v)
        if flag then Library.Flags[flag] = Input.Text end
    end

    if flag then
        Library.FlagObjects[flag] = { Set = setValue }
        Library.Flags[flag] = ""
    end

    return { Set = setValue, Get = function() return Input.Text end }
end

function Section:AddKeybind(cfg)
    cfg = cfg or {}
