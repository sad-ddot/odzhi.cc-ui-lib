function Window:AddTab(name, icon, layoutOrder)
    if type(icon) == "number" then
        layoutOrder = icon
        icon = nil
    end

    local hasIcon = icon ~= nil
    local textLeft = hasIcon and 38 or 14

    local Btn = Util.Create("TextButton", {
        Name = name,
        Text = name,
        Font = Library.Font,
        TextSize = 14,
        TextXAlignment = Enum.TextXAlignment.Left,
        Size = UDim2.new(1, 0, 0, 34),
        BorderSizePixel = 0,
        AutoButtonColor = false,
        LayoutOrder = layoutOrder or (#self.Tabs + 1),
        Parent = self.TabListHolder,
    }, {
        Util.Corner(5),
        Util.Pad(0, 0, textLeft, 0),
    })

    local IconObj
    if hasIcon then
        IconObj = Util.Create("ImageLabel", {
            Image = icon,
            Size = UDim2.new(0, 16, 0, 16),
            Position = UDim2.new(0, 12, 0.5, -8),
            BackgroundTransparency = 1,
            Parent = Btn,
        })
    end

    local AccentBar = Util.Create("Frame", {
        Size = UDim2.new(0, 3, 0.6, 0),
        Position = UDim2.new(0, 0, 0.2, 0),
        BorderSizePixel = 0,
        Visible = false,
        Parent = Btn,
    }, { Util.Corner(2) })
    Library:_Bind(AccentBar, "BackgroundColor3", "Accent")

    local Wrapper = Util.Create("Frame", {
        Name = name .. "_Wrapper",
        Size = UDim2.new(1, 0, 1, 0),
        BackgroundTransparency = 1,
        Visible = false,
        Parent = self.PageHolder,
    })

    local Page = BuildPage(Wrapper)

    local self_ = setmetatable({}, Tab)
    self_.Name = name
    self_.Button = Btn
    self_.AccentBar = AccentBar
    self_.Wrapper = Wrapper
    self_.Page = Page
    self_.Window = self
    self_.Selected = false
    self_.Icon = IconObj

    table.insert(self.Tabs, self_)

    local function restyle()
        if self_.Selected then
            Btn.BackgroundColor3 = Library.Theme.Sidebar
            Btn.TextColor3 = Library.Theme.Accent
            if IconObj then IconObj.ImageColor3 = Library.Theme.Accent end
        else
            Btn.BackgroundColor3 = Library.Theme.Panel
            Btn.TextColor3 = Library.Theme.Text
            if IconObj then IconObj.ImageColor3 = Library.Theme.Text end
        end
    end
    restyle()
    Library:_Register(restyle)

    Btn.MouseEnter:Connect(function()
        if not self_.Selected then
            Util.Tween(Btn, { BackgroundColor3 = Library.Theme.PanelHover }, 0.12)
        end
    end)
    Btn.MouseLeave:Connect(function()
        if not self_.Selected then
            Util.Tween(Btn, { BackgroundColor3 = Library.Theme.Panel }, 0.12)
        end
    end)

    local function selectTab()
        Library:_CloseOpenPopup()
        for _, t in ipairs(self.Tabs) do
            t.Selected = false
            t.Wrapper.Visible = false
            t.AccentBar.Visible = false
            Util.Tween(t.Button, { BackgroundColor3 = Library.Theme.Panel, TextColor3 = Library.Theme.Text }, 0.12)
            if t.Icon then
                Util.Tween(t.Icon, { ImageColor3 = Library.Theme.Text }, 0.12)
            end
        end

        self_.Selected = true
        self_.Wrapper.Visible = true

        self_.AccentBar.Visible = true
        Util.Tween(self_.Button, { BackgroundColor3 = Library.Theme.Sidebar, TextColor3 = Library.Theme.Accent }, 0.12)
        if self_.Icon then
            Util.Tween(self_.Icon, { ImageColor3 = Library.Theme.Accent }, 0.12)
        end
        self.CurrentTab = self_
    end

    Btn.MouseButton1Click:Connect(selectTab)

    if #self.Tabs == 1 then
        selectTab()
    end

    return self_
end

