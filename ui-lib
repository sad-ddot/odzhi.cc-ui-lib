                local kbName = kbOptions.Name or "Keybind"
                local kbDefault = kbOptions.Default or Enum.KeyCode.Unknown
                local kbFlag = kbOptions.Flag or kbName
                local kbCallback = kbOptions.Callback or function() end
                local kbMode = kbOptions.Mode or "Toggle"

                local currentKey = kbDefault
                local isListening = false
                local isActive = false
                ConfigState[kbFlag] = currentKey.Name

                local kbFrame = Create("Frame", {
