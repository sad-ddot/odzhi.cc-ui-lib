                local obj = {}
                function obj:Set(v) tog=v ConfigState[fl]=v upd() cb(v) end
                function obj:Get() return tog end
                return obj
            end

            function S:AddSlider(o)
                S.EC = S.EC + 1
                local nm=o.Name or "Slider" local mn=o.Min or 0 local mx=o.Max or 100
                local def=o.Default or mn local fl=o.Flag or nm local cb=o.Callback or function()end
                local sfx=o.Suffix or "" local inc=o.Increment or 1
                local cur = def
                ConfigState[fl] = cur

                local f = Cr("Frame", {Parent=sContent, BackgroundTransparency=1, Size=UDim2.new(1,0,0,24), LayoutOrder=S.EC})
                local lbl = Cr("TextLabel", {Parent=f, BackgroundTransparency=1, Size=UDim2.new(1,0,0,13), Font=Enum.Font.SourceSans, Text=nm, TextColor3=C.TextDim, TextSize=13, TextXAlignment=Enum.TextXAlignment.Left})
                local vlbl = Cr("TextLabel", {Parent=f, BackgroundTransparency=1, Size=UDim2.new(1,0,0,13), Font=Enum.Font.SourceSans, Text=tostring(cur)..sfx, TextColor3=C.TextDim, TextSize=13, TextXAlignment=Enum.TextXAlignment.Right})

                local slOuter = Cr("Frame", {Parent=f, BackgroundColor3=C.SliderOuter, BorderSizePixel=0, Position=UDim2.new(0,0,0,15), Size=UDim2.new(1,0,0,6)})
                local slBg = Cr("Frame", {Parent=slOuter, BackgroundColor3=C.SliderBg, BorderSizePixel=0, Position=UDim2.new(0,1,0,1), Size=UDim2.new(1,-2,1,-2)})
                local pct = math.clamp((cur-mn)/(mx-mn),0,1)
                local slFill = Cr("Frame", {Parent=slBg, BorderSizePixel=0, Position=UDim2.new(0,0,0,0), Size=UDim2.new(pct,0,1,0)})
                Cr("UIGradient", {Parent=slFill, Color=ColorSequence.new(C.AccentDark, C.Accent)})
                local slBtn = Cr("TextButton", {Parent=slOuter, BackgroundTransparency=1, Size=UDim2.new(1,0,1,0), Text="", ZIndex=5})

                local sliding = false

                local function updS(inp)
                    local aP = slBg.AbsolutePosition.X
                    local aS = slBg.AbsoluteSize.X
                    if aS==0 then return end
                    local r = math.clamp((inp.Position.X-aP)/aS,0,1)
                    local rv = mn + (mx-mn)*r
                    cur = math.clamp(math.floor(rv/inc+0.5)*inc, mn, mx)
                    ConfigState[fl] = cur
                    slFill.Size = UDim2.new((cur-mn)/(mx-mn),0,1,0)
                    vlbl.Text = tostring(cur)..sfx
                    cb(cur)
                end

                slBtn.InputBegan:Connect(function(inp) if inp.UserInputType==Enum.UserInputType.MouseButton1 then sliding=true updS(inp) end end)
                slBtn.InputEnded:Connect(function(inp) if inp.UserInputType==Enum.UserInputType.MouseButton1 then sliding=false end end)
                UserInputService.InputChanged:Connect(function(inp) if sliding and inp.UserInputType==Enum.UserInputType.MouseMovement then updS(inp) end end)

                ConfigCallbacks[fl] = function(v) cur=v slFill.Size=UDim2.new((v-mn)/(mx-mn),0,1,0) vlbl.Text=tostring(v)..sfx cb(v) end
                cb(cur)

                local obj = {}
                function obj:Set(v) cur=math.clamp(v,mn,mx) ConfigState[fl]=cur slFill.Size=UDim2.new((cur-mn)/(mx-mn),0,1,0) vlbl.Text=tostring(cur)..sfx cb(cur) end
                function obj:Get() return cur end
                return obj
            end

            function S:AddDropdown(o)
                S.EC = S.EC + 1
                local nm=o.Name or "Dropdown" local items=o.Items or {} local def=o.Default or (items[1] or "")
                local fl=o.Flag or nm local cb=o.Callback or function()end local multi=o.Multi or false
                local sel = def local isOpen = false
                if multi and type(def)~="table" then sel={} end
                ConfigState[fl] = sel

                local f = Cr("Frame", {Parent=sContent, BackgroundTransparency=1, Size=UDim2.new(1,0,0,30), LayoutOrder=S.EC, ClipsDescendants=false})
