        TextColor3 = Library.Theme.Text,
        Parent = SettingsSub.Page,
    })

    local AppearanceSection = SettingsSub:AddSection("Appearance")

    local themeNames = {}
    for name in pairs(Library.Presets) do
        table.insert(themeNames, name)
    end
    table.sort(themeNames)

    AppearanceSection:AddDropdown({
        Text = "Theme",
        Options = themeNames,
        Default = Library.CurrentThemeName,
        Flag = "UILib_Theme",
        Callback = function(value)
            Library:SetTheme(value)
        end,
    })

    AppearanceSection:AddColorPicker({
        Text = "Accent Color",
        Default = Library.Theme.Accent,
        Flag = "UILib_Accent",
        Callback = function(value)
            Library:SetAccentColor(value)
        end,
    })

    local BehaviorSection = SettingsSub:AddSection("Behavior")

    BehaviorSection:AddKeybind({
        Text = "Menu Toggle Key",
        Default = self.ToggleKey,
        OnBind = function(key)
            self:SetToggleKey(key)
        end,
    })

    return SettingsTab
end

