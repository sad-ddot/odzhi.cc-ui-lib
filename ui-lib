            function Sector:AddSlider(sOpts)
                local sName = sOpts.Name or "Slider"
                local sMin = sOpts.Min or 0
                local sMax = sOpts.Max or 100
                local sDefault = sOpts.Default or sMin
                local sFlag = sOpts.Flag or sName
                local sCallback = sOpts.Callback or function() end
                local sSuffix = sOpts.Suffix or ""
                local sIncrement = sOpts.Increment or 1

                Sector.ElementCount = Sector.ElementCount + 1
                local currentValue = sDefault
                ConfigState[sFlag] = currentValue

                local Frame = Create("Frame", {
                    Parent = SectorContent,
                    BackgroundTransparency = 1,
                    Size = UDim2.new(1, 0, 0, 26),
                    LayoutOrder = Sector.ElementCount,
                })

                local Label = Create("TextLabel", {
                    Parent = Frame,
                    BackgroundTransparency = 1,
                    Position = UDim2.new(0, 0, 0, 0),
                    Size = UDim2.new(1, 0, 0, 13),
                    Font = Enum.Font.SourceSans,
                    Text = sName,
                    TextColor3 = Colors.TextDim,
                    TextSize = 13,
                    TextXAlignment = Enum.TextXAlignment.Left,
                })

                local ValLabel = Create("TextLabel", {
                    Parent = Frame,
                    BackgroundTransparency = 1,
                    Position = UDim2.new(0, 0, 0, 0),
                    Size = UDim2.new(1, 0, 0, 13),
                    Font = Enum.Font.SourceSans,
                    Text = tostring(currentValue) .. sSuffix,
                    TextColor3 = Colors.TextDim,
                    TextSize = 13,
                    TextXAlignment = Enum.TextXAlignment.Right,
                })

                local SliderOuter = Create("Frame", {
                    Parent = Frame,
                    BackgroundColor3 = Colors.Border,
                    BorderSizePixel = 0,
                    Position = UDim2.new(0, 0, 0, 16),
                    Size = UDim2.new(1, 0, 0, 7),
                })

                local SliderBg = Create("Frame", {
                    Parent = SliderOuter,
                    BackgroundColor3 = Colors.SliderBg,
                    BorderSizePixel = 0,
                    Position = UDim2.new(0, 1, 0, 1),
                    Size = UDim2.new(1, -2, 1, -2),
                })

                local fillPct = math.clamp((currentValue - sMin) / (sMax - sMin), 0, 1)

                local SliderFill = Create("Frame", {
                    Parent = SliderBg,
                    BackgroundColor3 = Colors.SliderFill,
                    BorderSizePixel = 0,
                    Position = UDim2.new(0, 0, 0, 0),
                    Size = UDim2.new(fillPct, 0, 1, 0),
                })

                local FillGrad = Create("UIGradient", {
                    Parent = SliderFill,
                    Color = ColorSequence.new(Colors.AccentDark, Colors.Accent),
                })

                local SliderBtn = Create("TextButton", {
                    Parent = SliderOuter,
                    BackgroundTransparency = 1,
                    Size = UDim2.new(1, 0, 1, 0),
                    Text = "",
                    ZIndex = 5,
                })

                local sliding = false

                local function UpdateSlider(input)
                    local absPos = SliderBg.AbsolutePosition.X
                    local absSize = SliderBg.AbsoluteSize.X
                    if absSize == 0 then return end
                    local relX = math.clamp((input.Position.X - absPos) / absSize, 0, 1)
                    local rawVal = sMin + (sMax - sMin) * relX
                    local stepped = math.floor(rawVal / sIncrement + 0.5) * sIncrement
                    stepped = math.clamp(stepped, sMin, sMax)
                    currentValue = stepped
                    ConfigState[sFlag] = currentValue
                    local pct = (currentValue - sMin) / (sMax - sMin)
                    SliderFill.Size = UDim2.new(pct, 0, 1, 0)
                    ValLabel.Text = tostring(currentValue) .. sSuffix
                    sCallback(currentValue)
                end

                SliderBtn.InputBegan:Connect(function(input)
                    if input.UserInputType == Enum.UserInputType.MouseButton1 then
                        sliding = true
                        UpdateSlider(input)
                    end
                end)

                SliderBtn.InputEnded:Connect(function(input)
                    if input.UserInputType == Enum.UserInputType.MouseButton1 then
                        sliding = false
                    end
                end)

                UserInputService.InputChanged:Connect(function(input)
                    if sliding and input.UserInputType == Enum.UserInputType.MouseMovement then
                        UpdateSlider(input)
                    end
                end)

                ConfigCallbacks[sFlag] = function(val)
                    currentValue = val
                    local pct = (val - sMin) / (sMax - sMin)
                    SliderFill.Size = UDim2.new(pct, 0, 1, 0)
                    ValLabel.Text = tostring(val) .. sSuffix
                    sCallback(val)
                end

                sCallback(currentValue)

                local obj = {}
                function obj:Set(v) currentValue = math.clamp(v, sMin, sMax) ConfigState[sFlag] = currentValue local p = (currentValue - sMin)/(sMax - sMin) SliderFill.Size = UDim2.new(p,0,1,0) ValLabel.Text = tostring(currentValue)..sSuffix sCallback(currentValue) end
                function obj:Get() return currentValue end
                return obj
            end

