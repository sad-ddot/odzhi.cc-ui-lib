            Padding = UDim.new(0, 8),
            SortOrder = Enum.SortOrder.LayoutOrder,
        }),
    })

    local function makeActionBtn(parent, text)
        local btn = Util.Create("TextButton", {
            Text = text,
            Font = Library.Font,
            TextSize = 12,
            BorderSizePixel = 0,
            Size = UDim2.new(0.5, -4, 1, 0),
