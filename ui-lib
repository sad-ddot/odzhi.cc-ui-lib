function Util.Create(class, props, children)
    local inst = Instance.new(class)
    if inst:IsA("GuiBase2d") then
        inst.AutoLocalize = false
    end
    for k, v in pairs(props or {}) do
        inst[k] = v
    end
    for _, child in ipairs(children or {}) do
        child.Parent = inst
    end
    return inst
end

function Util.Corner(radius)
    return Util.Create("UICorner", { CornerRadius = UDim.new(0, radius or 5) })
end

function Util.Stroke(color, thickness, transparency)
    return Util.Create("UIStroke", {
        Color = color or Color3.fromRGB(46, 46, 52),
        Thickness = thickness or 1,
        Transparency = transparency or 0,
        ApplyStrokeMode = Enum.ApplyStrokeMode.Border,
    })
end

function Util.Pad(top, bottom, left, right)
    return Util.Create("UIPadding", {
        PaddingTop = UDim.new(0, top or 0),
        PaddingBottom = UDim.new(0, bottom or 0),
        PaddingLeft = UDim.new(0, left or 0),
        PaddingRight = UDim.new(0, right or 0),
    })
end

function Util.Tween(inst, props, time, style, dir)
    local tw = TweenService:Create(
        inst,
        TweenInfo.new(time or 0.18, style or Enum.EasingStyle.Quad, dir or Enum.EasingDirection.Out),
        props
    )
    tw:Play()
    return tw
end

function Util.Hover(obj, getBase, getHover, time)
    time = time or 0.12
    obj.Active = true
    obj.MouseEnter:Connect(function()
        Util.Tween(obj, { BackgroundColor3 = getHover() }, time)
    end)
    obj.MouseLeave:Connect(function()
        Util.Tween(obj, { BackgroundColor3 = getBase() }, time)
    end)
end

function Util.MakeDraggable(handle, target)
    local dragging, dragInput, dragStart, startPos

    handle.InputBegan:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1
            or input.UserInputType == Enum.UserInputType.Touch then
            dragging = true
            dragStart = input.Position
            startPos = target.Position

            input.Changed:Connect(function()
                if input.UserInputState == Enum.UserInputState.End then
                    dragging = false
                end
            end)
        end
    end)

    handle.InputChanged:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseMovement
            or input.UserInputType == Enum.UserInputType.Touch then
            dragInput = input
        end
    end)

    UserInputService.InputChanged:Connect(function(input)
        if input == dragInput and dragging then
            local delta = input.Position - dragStart
            target.Position = UDim2.new(
                startPos.X.Scale, startPos.X.Offset + delta.X,
                startPos.Y.Scale, startPos.Y.Offset + delta.Y
            )
        end
    end)
end

function Util.SearchIcon(parent, size, color)
    size = size or 12
    local holder = Util.Create("Frame", {
        Size = UDim2.fromOffset(size, size),
        BackgroundTransparency = 1,
        Parent = parent,
    })

    local ring = Util.Create("Frame", {
        Size = UDim2.fromOffset(size * 0.62, size * 0.62),
        Position = UDim2.fromOffset(0, 0),
        BackgroundTransparency = 1,
        Parent = holder,
    }, {
        Util.Create("UICorner", { CornerRadius = UDim.new(1, 0) }),
        Util.Create("UIStroke", { Thickness = 1.4, Color = color }),
    })

    local handle = Util.Create("Frame", {
        Size = UDim2.fromOffset(size * 0.4, 1.4),
        Position = UDim2.fromOffset(size * 0.42, size * 0.62),
        Rotation = 45,
        BackgroundColor3 = color,
        BorderSizePixel = 0,
        Parent = holder,
    })

    return holder, ring, handle
end

