            function S:AddLabel(o) S.EC = S.EC + 1 local txt = o.Text or "" local f = Create("Frame", {Parent = sCont, BackgroundTransparency = 1, Size = UDim2.new(1, 0, 0, 14), LayoutOrder = S.EC}) local l = Create("TextLabel", {Parent = f, BackgroundTransparency = 1, Size = UDim2.new(1, 0, 1, 0), Font = Enum.Font.SourceSans, Text = txt, TextColor3 = C.TextDark, TextSize = 13, TextXAlignment = Enum.TextXAlignment.Left}) local obj = {} function obj:SetText(t) l.Text = t end return obj end

            function S:AddSeparator() S.EC = S.EC + 1 Create("Frame", {Parent = sCont, BackgroundColor3 = C.GroupInner, BorderSizePixel = 0, Size = UDim2.new(1, 0, 0, 1), LayoutOrder = S.EC}) end

            return S
        end
        return T
    end

    UserInputService.InputBegan:Connect(function(input, gpe)
        if input.UserInputType == Enum.UserInputType.Keyboard and input.KeyCode == Enum.KeyCode.Insert and not gpe then W:Toggle() return end
        if input.UserInputType == Enum.UserInputType.MouseButton1 then
            task.defer(function()
                local mp = UserInputService:GetMouseLocation()
                if ActiveDropdown and ActiveDropdown.Visible then local ap, as = ActiveDropdown.AbsolutePosition, ActiveDropdown.AbsoluteSize if mp.X < ap.X or mp.X > ap.X + as.X or mp.Y < ap.Y or mp.Y > ap.Y + as.Y then ActiveDropdown.Visible = false ActiveDropdown = nil end end
                for _, cpE in pairs(AllColorPickers) do if cpE.IsOpen and cpE.Panel and cpE.Panel.Visible then local ap, as = cpE.Panel.AbsolutePosition, cpE.Panel.AbsoluteSize if mp.X < ap.X or mp.X > ap.X + as.X or mp.Y < ap.Y or mp.Y > ap.Y + as.Y then cpE.Panel.Visible = false cpE.IsOpen = false end end end
            end)
        end
    end)

    return W
end

