    local function restyle()
        if sub.Selected then
            Pill.BackgroundColor3 = Library.Theme.PanelHover
            Pill.TextColor3 = Library.Theme.Accent
        else
            Pill.BackgroundColor3 = Library.Theme.Panel
            Pill.TextColor3 = Library.Theme.Text
        end
    end
    restyle()
    Library:_Register(restyle)

    local function select()
        Library:_CloseOpenPopup()
        for _, t in ipairs(self.Tabs) do
            t.Selected = false
            t.Page.Visible = false
        end
        sub.Selected = true
        PageFrame.Visible = true
        for _, t in ipairs(self.Tabs) do
            local btn = t.Button
            if t == sub then
                Util.Tween(btn, { BackgroundColor3 = Library.Theme.PanelHover, TextColor3 = Library.Theme.Accent }, 0.12)
