        Parent = thBg, BackgroundColor3 = C.GroupOuter, BorderSizePixel = 0,
        Position = UDim2.new(0, 62, 0, 40), Size = UDim2.new(1, -68, 0, 8), ZIndex = 184,
    })
    local thHpBg = Create("Frame", {
        Parent = thHpOuter, BackgroundColor3 = C.GroupBg, BorderSizePixel = 0,
        Position = UDim2.new(0, 1, 0, 1), Size = UDim2.new(1, -2, 1, -2), ZIndex = 185, ClipsDescendants = true,
    })
    local thHpFill = Create("Frame", {
        Parent = thHpBg, BackgroundColor3 = Color3.fromRGB(80, 200, 80), BorderSizePixel = 0,
        Size = UDim2.new(1, 0, 1, 0), ZIndex = 186,
    })
    Create("UIGradient", {Parent = thHpFill, Color = ColorSequence.new(Color3.fromRGB(60, 180, 60), Color3.fromRGB(100, 220, 100))})

    local thHpText = Create("TextLabel", {
        Parent = thHpBg, BackgroundTransparency = 1,
        Size = UDim2.new(1, -4, 1, 0), Position = UDim2.new(0, 2, 0, 0),
        Font = Enum.Font.SourceSansSemibold, Text = "100",
        TextColor3 = C.White, TextSize = 8, TextXAlignment = Enum.TextXAlignment.Right, ZIndex = 187,
    })

    local currentTarget = nil

    local function updateTH()
        if not currentTarget or not currentTarget.Character or not currentTarget.Character:FindFirstChild("Humanoid") or not currentTarget.Character:FindFirstChild("HumanoidRootPart") then
            if thO.Visible then
                Tween(thO, {BackgroundTransparency = 1}, 0.2)
                for _, desc in pairs(thO:GetDescendants()) do
                    if desc:IsA("Frame") then Tween(desc, {BackgroundTransparency = 1}, 0.2) end
                    if desc:IsA("TextLabel") then Tween(desc, {TextTransparency = 1}, 0.2) end
                    if desc:IsA("ImageLabel") then Tween(desc, {ImageTransparency = 1}, 0.2) end
                end
                task.delay(0.25, function() thO.Visible = false end)
            end
            return
        end

        local hum = currentTarget.Character:FindFirstChild("Humanoid")
        local hrp = currentTarget.Character:FindFirstChild("HumanoidRootPart")
        local myHrp = LocalPlayer.Character and LocalPlayer.Character:FindFirstChild("HumanoidRootPart")

        if not hum or not hrp or hum.Health <= 0 then
            currentTarget = nil
            return
        end

        if not thO.Visible then
            thO.Visible = true
            thO.BackgroundTransparency = 1
            for _, desc in pairs(thO:GetDescendants()) do
                if desc:IsA("Frame") then desc.BackgroundTransparency = 1 end
                if desc:IsA("TextLabel") then desc.TextTransparency = 1 end
                if desc:IsA("ImageLabel") then desc.ImageTransparency = 1 end
            end
            Tween(thO, {BackgroundTransparency = 0}, 0.2)
            for _, desc in pairs(thO:GetDescendants()) do
                if desc:IsA("Frame") then Tween(desc, {BackgroundTransparency = 0}, 0.2) end
                if desc:IsA("TextLabel") then Tween(desc, {TextTransparency = 0}, 0.2) end
                if desc:IsA("ImageLabel") then Tween(desc, {ImageTransparency = 0}, 0.2) end
            end
        end

        thName.Text = currentTarget.Name
        local userId = currentTarget.UserId
        thIcon.Image = "https://www.roblox.com/headshot-thumbnail/image?userId=" .. userId .. "&width=150&height=150&format=png"

        local dist = 0
        if myHrp then
            dist = math.floor((myHrp.Position - hrp.Position).Magnitude)
        end
        thDist.Text = dist .. "m away"

        local hp = math.floor(hum.Health)
        local maxHp = math.floor(hum.MaxHealth)
        local hpPct = math.clamp(hum.Health / hum.MaxHealth, 0, 1)
        thHpFill.Size = UDim2.new(hpPct, 0, 1, 0)
        thHpText.Text = hp .. "/" .. maxHp

        if hpPct > 0.5 then
            thHpFill.BackgroundColor3 = Color3.fromRGB(80, 200, 80)
        elseif hpPct > 0.25 then
            thHpFill.BackgroundColor3 = Color3.fromRGB(220, 180, 50)
        else
            thHpFill.BackgroundColor3 = Color3.fromRGB(220, 50, 50)
        end
    end

    RunService.Heartbeat:Connect(function()
        if ConfigState["TargetHUD"] then
            local ray = Camera:ViewportPointToRay(Camera.ViewportSize.X / 2, Camera.ViewportSize.Y / 2)
            local closestPlayer = nil
            local closestDist = 500

            for _, player in ipairs(Players:GetPlayers()) do
                if player ~= LocalPlayer and player.Character and player.Character:FindFirstChild("HumanoidRootPart") and player.Character:FindFirstChild("Humanoid") and player.Character.Humanoid.Health > 0 then
                    local hrp = player.Character.HumanoidRootPart
                    local screenPos, onScreen = Camera:WorldToViewportPoint(hrp.Position)
                    if onScreen then
                        local screenCenter = Vector2.new(Camera.ViewportSize.X / 2, Camera.ViewportSize.Y / 2)
                        local playerScreen = Vector2.new(screenPos.X, screenPos.Y)
                        local screenDist = (screenCenter - playerScreen).Magnitude
                        if screenDist < closestDist and screenDist < 200 then
                            closestDist = screenDist
                            closestPlayer = player
                        end
                    end
                end
            end

            currentTarget = closestPlayer
            updateTH()
        else
            if thO.Visible then
                thO.Visible = false
            end
            currentTarget = nil
        end
    end)

    return thO
end

function GamesenseLib:Notify(opts)
    if not ScreenGui then return end
    local txt = opts.Text or ""
    local dur = opts.Duration or 3
    local nc = ScreenGui:FindFirstChild("NC")
    if not nc then
        nc = Create("Frame", {Name = "NC", Parent = ScreenGui, BackgroundTransparency = 1, Position = UDim2.new(1, -325, 0, 10), Size = UDim2.new(0, 315, 1, -20), ZIndex = 500})
        Create("UIListLayout", {Parent = nc, FillDirection = Enum.FillDirection.Vertical, VerticalAlignment = Enum.VerticalAlignment.Bottom, SortOrder = Enum.SortOrder.LayoutOrder, Padding = UDim.new(0, 4)})
    end
    local nO, nBg = MakeBBox(nc, UDim2.new(0, 0, 0, 0), UDim2.new(1, 0, 0, 30), 500)
    nO.BackgroundTransparency = 1
    for _, d in pairs(nO:GetDescendants()) do if d:IsA("Frame") then d.BackgroundTransparency = 1 end end
    local nL = Create("TextLabel", {Parent = nBg, BackgroundTransparency = 1, Position = UDim2.new(0, 8, 0, 0), Size = UDim2.new(1, -16, 1, 0), Font = Enum.Font.SourceSans, Text = txt, TextColor3 = C.TextDim, TextSize = 12, TextXAlignment = Enum.TextXAlignment.Left, TextTransparency = 1, ZIndex = 506})
    for _, d in pairs(nO:GetDescendants()) do if d:IsA("Frame") then Tween(d, {BackgroundTransparency = 0}, 0.25) end end
    Tween(nL, {TextTransparency = 0}, 0.3)
    task.delay(dur, function()
        for _, d in pairs(nO:GetDescendants()) do if d:IsA("Frame") then Tween(d, {BackgroundTransparency = 1}, 0.3) end end
        Tween(nL, {TextTransparency = 1}, 0.3)
        task.wait(0.35)
        if nO and nO.Parent then nO:Destroy() end
    end)
end

