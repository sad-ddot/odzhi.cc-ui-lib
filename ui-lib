                })

                local SliderBg = Create("Frame", {
                    Name = "SliderBg",
                    Parent = SliderFrame,
                    BackgroundColor3 = Colors.SliderBg,
                    BorderSizePixel = 0,
                    Position = UDim2.new(0, 0, 0, 17),
                    Size = UDim2.new(1, 0, 0, 8),
                })

                local SliderBgStroke = Create("UIStroke", {
                    Parent = SliderBg,
                    Color = Colors.Border,
                    Thickness = 1,
                    ApplyStrokeMode = Enum.ApplyStrokeMode.Border,
                })

                local fillPct = (currentValue - sMin) / (sMax - sMin)

                local SliderFill = Create("Frame", {
                    Name = "Fill",
                    Parent = SliderBg,
                    BackgroundColor3 = Colors.Accent,
                    BorderSizePixel = 0,
                    Position = UDim2.new(0, 0, 0, 0),
                    Size = UDim2.new(fillPct, 0, 1, 0),
                })

                local SliderButton = Create("TextButton", {
                    Name = "SliderButton",
                    Parent = SliderBg,
                    BackgroundTransparency = 1,
                    Size = UDim2.new(1, 0, 1, 0),
                    Text = "",
                    ZIndex = 5,
                })

                local sliding = false

                local function UpdateSlider(input)
                    local absPos = SliderBg.AbsolutePosition.X
                    local absSize = SliderBg.AbsoluteSize.X
                    local relX = math.clamp((input.Position.X - absPos) / absSize, 0, 1)
                    local rawVal = sMin + (sMax - sMin) * relX
                    local stepped = math.floor(rawVal / sIncrement + 0.5) * sIncrement
                    stepped = math.clamp(stepped, sMin, sMax)
                    currentValue = stepped
                    ConfigState[sFlag] = currentValue
                    local pct = (currentValue - sMin) / (sMax - sMin)
                    Tween(SliderFill, {Size = UDim2.new(pct, 0, 1, 0)}, 0.05)
                    SliderValueLabel.Text = tostring(currentValue) .. sSuffix
                    sCallback(currentValue)
                end

                SliderButton.InputBegan:Connect(function(input)
                    if input.UserInputType == Enum.UserInputType.MouseButton1 then
                        sliding = true
                        UpdateSlider(input)
                    end
                end)

                SliderButton.InputEnded:Connect(function(input)
                    if input.UserInputType == Enum.UserInputType.MouseButton1 then
                        sliding = false
                    end
                end)

                UserInputService.InputChanged:Connect(function(input)
                    if sliding and input.UserInputType == Enum.UserInputType.MouseMovement then
                        UpdateSlider(input)
                    end
                end)

                ConfigCallbacks[sFlag] = function(val)
                    currentValue = val
                    local pct = (val - sMin) / (sMax - sMin)
                    Tween(SliderFill, {Size = UDim2.new(pct, 0, 1, 0)}, 0.1)
                    SliderValueLabel.Text = tostring(val) .. sSuffix
                    sCallback(val)
                end

                sCallback(currentValue)

                local SliderObj = {}

                function SliderObj:Set(val)
                    currentValue = math.clamp(val, sMin, sMax)
                    ConfigState[sFlag] = currentValue
                    local pct = (currentValue - sMin) / (sMax - sMin)
                    Tween(SliderFill, {Size = UDim2.new(pct, 0, 1, 0)}, 0.1)
                    SliderValueLabel.Text = tostring(currentValue) .. sSuffix
                    sCallback(currentValue)
                end

                function SliderObj:Get()
                    return currentValue
                end

                return SliderObj
            end

