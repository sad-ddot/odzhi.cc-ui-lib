                })

                local kbOuter = Create("Frame", {
                    Parent = kbFrame,
                    BackgroundColor3 = C.DropdownOuter,
                    BorderSizePixel = 0,
                    Position = UDim2.new(1, -48, 0, 1),
                    Size = UDim2.new(0, 48, 0, 12),
                })

                local kbButton = Create("TextButton", {
                    Parent = kbOuter,
                    BackgroundColor3 = C.DropdownBg,
                    BorderSizePixel = 0,
                    Position = UDim2.new(0, 1, 0, 1),
                    Size = UDim2.new(1, -2, 1, -2),
                    Font = Enum.Font.SourceSans,
                    Text = currentKey == Enum.KeyCode.Unknown and "[-]" or "[" .. currentKey.Name .. "]",
                    TextColor3 = C.TextDark,
                    TextSize = 10,
                    AutoButtonColor = false,
                    ZIndex = 5,
                })

                local function updateKeybindListEntry()
                    if currentKey ~= Enum.KeyCode.Unknown then
                        ActiveKeybinds[kbName] = {Active = isActive, Mode = kbMode, Key = currentKey}
                    else
                        ActiveKeybinds[kbName] = nil
                    end
                    UpdateKeybindList()
                end

                kbButton.MouseButton1Click:Connect(function()
                    if isListening then return end
                    isListening = true
                    kbButton.Text = "[...]"
                    kbButton.TextColor3 = C.TextDim
                end)

                UserInputService.InputBegan:Connect(function(input, gameProcessed)
                    if isListening then
                        if input.UserInputType == Enum.UserInputType.Keyboard then
                            if input.KeyCode == Enum.KeyCode.Escape then
                                currentKey = Enum.KeyCode.Unknown
                                kbButton.Text = "[-]"
                            else
                                currentKey = input.KeyCode
                                kbButton.Text = "[" .. currentKey.Name .. "]"
                            end
                            ConfigState[kbFlag] = currentKey.Name
                            isListening = false
                            kbButton.TextColor3 = C.TextDark
                            isActive = false
                            updateKeybindListEntry()
                            return
                        end

                        if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.MouseButton2 then
                            isListening = false
                            kbButton.Text = currentKey == Enum.KeyCode.Unknown and "[-]" or "[" .. currentKey.Name .. "]"
                            kbButton.TextColor3 = C.TextDark
                            return
                        end
                    end

                    if not isListening and not gameProcessed and input.UserInputType == Enum.UserInputType.Keyboard then
                        if input.KeyCode == currentKey and currentKey ~= Enum.KeyCode.Unknown then
                            if kbMode == "Toggle" then
                                isActive = not isActive
                            else
                                isActive = true
                            end
                            updateKeybindListEntry()
                            kbCallback(currentKey)
                        end
                    end
                end)

                if kbMode == "Hold" then
                    UserInputService.InputEnded:Connect(function(input)
                        if not isListening and input.UserInputType == Enum.UserInputType.Keyboard then
                            if input.KeyCode == currentKey and currentKey ~= Enum.KeyCode.Unknown then
                                isActive = false
                                updateKeybindListEntry()
                            end
                        end
                    end)
                end

                ConfigCallbacks[kbFlag] = function(value)
                    local success, key = pcall(function()
                        return Enum.KeyCode[value]
                    end)
                    if success and key then
                        currentKey = key
                        kbButton.Text = key == Enum.KeyCode.Unknown and "[-]" or "[" .. key.Name .. "]"
                    end
                end

                local kbObject = {}

                function kbObject:Set(key)
                    currentKey = key
                    ConfigState[kbFlag] = key.Name
                    kbButton.Text = key == Enum.KeyCode.Unknown and "[-]" or "[" .. key.Name .. "]"
                    updateKeybindListEntry()
                end

                function kbObject:Get()
                    return currentKey
                end

                return kbObject
            end

