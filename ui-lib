            function Sector:AddSlider(sliderOptions)
                Sector.ElementCount = Sector.ElementCount + 1

                local sliderName = sliderOptions.Name or "Slider"
                local sliderMin = sliderOptions.Min or 0
                local sliderMax = sliderOptions.Max or 100
                local sliderDefault = sliderOptions.Default or sliderMin
                local sliderFlag = sliderOptions.Flag or sliderName
                local sliderCallback = sliderOptions.Callback or function() end
                local sliderSuffix = sliderOptions.Suffix or ""
                local sliderIncrement = sliderOptions.Increment or 1

                local currentValue = sliderDefault
                ConfigState[sliderFlag] = currentValue

                local sliderFrame = Create("Frame", {
                    Name = "Slider_" .. sliderName,
                    Parent = sectorContent,
                    BackgroundTransparency = 1,
                    Size = UDim2.new(1, 0, 0, 28),
                    LayoutOrder = Sector.ElementCount,
                })

                local sliderLabel = Create("TextLabel", {
                    Parent = sliderFrame,
                    BackgroundTransparency = 1,
                    Position = UDim2.new(0, 0, 0, 0),
                    Size = UDim2.new(1, 0, 0, 14),
                    Font = Enum.Font.SourceSans,
                    Text = sliderName,
                    TextColor3 = C.TextDim,
                    TextSize = 13,
                    TextXAlignment = Enum.TextXAlignment.Left,
                })

                local sliderOuterFrame = Create("Frame", {
                    Parent = sliderFrame,
                    BackgroundColor3 = C.SliderOuter,
                    BorderSizePixel = 0,
                    Position = UDim2.new(0, 0, 0, 16),
                    Size = UDim2.new(1, 0, 0, 10),
                })

                local sliderBackground = Create("Frame", {
                    Parent = sliderOuterFrame,
                    BackgroundColor3 = C.SliderBg,
                    BorderSizePixel = 0,
                    Position = UDim2.new(0, 1, 0, 1),
                    Size = UDim2.new(1, -2, 1, -2),
                    ClipsDescendants = true,
                })

                local fillPercent = math.clamp((currentValue - sliderMin) / (sliderMax - sliderMin), 0, 1)

                local sliderFill = Create("Frame", {
                    Parent = sliderBackground,
                    BorderSizePixel = 0,
                    Position = UDim2.new(0, 0, 0, 0),
                    Size = UDim2.new(fillPercent, 0, 1, 0),
                })

                Create("UIGradient", {
                    Parent = sliderFill,
                    Color = ColorSequence.new(C.AccentDark, C.Accent),
                })

                local sliderValueLabel = Create("TextLabel", {
                    Parent = sliderBackground,
                    BackgroundTransparency = 1,
                    Position = UDim2.new(0, 2, 0, 0),
                    Size = UDim2.new(1, -4, 1, 0),
                    Font = Enum.Font.SourceSansSemibold,
                    Text = tostring(currentValue) .. sliderSuffix,
                    TextColor3 = C.White,
                    TextSize = 10,
                    TextXAlignment = Enum.TextXAlignment.Right,
                    TextYAlignment = Enum.TextYAlignment.Center,
                    ZIndex = 3,
                })

                local sliderInteractButton = Create("TextButton", {
                    Parent = sliderOuterFrame,
                    BackgroundTransparency = 1,
                    Size = UDim2.new(1, 0, 1, 0),
                    Text = "",
                    ZIndex = 5,
                })

                local isSliding = false

                local function updateSliderFromInput(input)
                    local absPosition = sliderBackground.AbsolutePosition.X
                    local absSize = sliderBackground.AbsoluteSize.X
                    if absSize == 0 then return end

                    local relative = math.clamp((input.Position.X - absPosition) / absSize, 0, 1)
                    local rawValue = sliderMin + (sliderMax - sliderMin) * relative
                    local steppedValue = math.floor(rawValue / sliderIncrement + 0.5) * sliderIncrement
                    steppedValue = math.clamp(steppedValue, sliderMin, sliderMax)

                    currentValue = steppedValue
                    ConfigState[sliderFlag] = currentValue

                    local newFillPercent = (currentValue - sliderMin) / (sliderMax - sliderMin)
                    sliderFill.Size = UDim2.new(newFillPercent, 0, 1, 0)
                    sliderValueLabel.Text = tostring(currentValue) .. sliderSuffix
                    sliderCallback(currentValue)
                end

                sliderInteractButton.InputBegan:Connect(function(input)
                    if input.UserInputType == Enum.UserInputType.MouseButton1 then
                        isSliding = true
                        updateSliderFromInput(input)
                    end
                end)

                sliderInteractButton.InputEnded:Connect(function(input)
                    if input.UserInputType == Enum.UserInputType.MouseButton1 then
                        isSliding = false
                    end
                end)

                UserInputService.InputChanged:Connect(function(input)
                    if isSliding and input.UserInputType == Enum.UserInputType.MouseMovement then
                        updateSliderFromInput(input)
                    end
                end)

                ConfigCallbacks[sliderFlag] = function(value)
                    currentValue = value
                    local pct = (value - sliderMin) / (sliderMax - sliderMin)
                    sliderFill.Size = UDim2.new(pct, 0, 1, 0)
                    sliderValueLabel.Text = tostring(value) .. sliderSuffix
                    sliderCallback(value)
                end

                sliderCallback(currentValue)

                local sliderObject = {}

                function sliderObject:Set(value)
                    currentValue = math.clamp(value, sliderMin, sliderMax)
                    ConfigState[sliderFlag] = currentValue
                    local pct = (currentValue - sliderMin) / (sliderMax - sliderMin)
                    sliderFill.Size = UDim2.new(pct, 0, 1, 0)
                    sliderValueLabel.Text = tostring(currentValue) .. sliderSuffix
                    sliderCallback(currentValue)
                end

                function sliderObject:Get()
                    return currentValue
                end

                return sliderObject
            end

