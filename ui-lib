do
    -- Skin Changer: dropdown per weapon, fires ChangeSkin remote
    local skins_folder = ReplicatedStorage:FindFirstChild("Skins")
    local ranged_weapons = ReplicatedStorage:FindFirstChild("RangedWeapons")
    local ChangeSkinRemote = nil
    pcall(function()
        ChangeSkinRemote = ReplicatedStorage:WaitForChild("Remotes"):WaitForChild("ChangeSkin")
    end)

    local function get_weapon_in_inventory(weapon_name)
        local rep = ReplicatedStorage
        local p_inv = rep:FindFirstChild("Players")
            and rep.Players:FindFirstChild(LocalPlayer.Name)
            and rep.Players[LocalPlayer.Name]:FindFirstChild("Inventory")
        if not p_inv then return nil end
        for _, item in ipairs(p_inv:GetChildren()) do
            if item:IsA("ObjectValue") and item.Value and item.Value.Name == weapon_name then
                return item
            end
        end
        return nil
    end

    if ranged_weapons and skins_folder then
        for _, weapon in ipairs(ranged_weapons:GetChildren()) do
            local weapon_name = weapon.Name
            local weapon_skins = skins_folder:FindFirstChild(weapon_name)
            local skin_list = { "Default" }
            if weapon_skins then
                for _, s in ipairs(weapon_skins:GetChildren()) do
                    table.insert(skin_list, s.Name)
                end
            end
            SecSkin1:Dropdown({
                Name = weapon_name .. " skin",
                Default = "Default" or "",
                Items = skin_list,
                Callback = function(skin_name)
                    local inv_item = get_weapon_in_inventory(weapon_name)
                    if not inv_item then return end
                    pcall(function() inv_item:SetAttribute("SpoofedSkin", skin_name == "Default" and "" or tostring(skin_name)) end)
                    if ChangeSkinRemote then
                        pcall(function() ChangeSkinRemote:InvokeServer(inv_item, skin_name) end)
                    end
                end
            })
        end
    end
end

