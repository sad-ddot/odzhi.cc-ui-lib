                    Visible = toggleOpts.Bind ~= nil or toggleOpts.ShowBind == true,
                })

                local bindKey = toggleOpts.DefaultBind or Enum.KeyCode.Unknown
                local bindListening = false

                local bindButton = Create("TextButton", {
                    Parent = bindOuter,
                    BackgroundColor3 = C.DrpBg,
                    BorderSizePixel = 0,
                    Position = UDim2.new(0, 1, 0, 1),
                    Size = UDim2.new(1, -2, 1, -2),
                    Font = Enum.Font.SourceSans,
                    Text = bindKey == Enum.KeyCode.Unknown and "[-]" or "[" .. bindKey.Name .. "]",
                    TextColor3 = C.TextDark,
                    TextSize = 10,
                    AutoButtonColor = false,
                    ZIndex = 6,
                })

                local function updateToggleVisual()
                    if isToggled then
                        checkboxGradient.Color = ColorSequence.new(C.Accent, C.AccentDark)
                        toggleLabel.TextColor3 = C.Text
                    else
                        checkboxGradient.Color = ColorSequence.new(C.ChkGradT, C.ChkGradB)
                        toggleLabel.TextColor3 = C.TextDim
                    end
                end

                updateToggleVisual()

                toggleClickButton.MouseEnter:Connect(function()
                    if not isToggled then
                        checkboxGradient.Color = ColorSequence.new(C.ChkHoverT, C.ChkHoverB)
                    end
                end)

                toggleClickButton.MouseLeave:Connect(function()
                    updateToggleVisual()
                end)

                toggleClickButton.MouseButton1Click:Connect(function()
                    isToggled = not isToggled
                    ConfigState[toggleFlag] = isToggled
                    updateToggleVisual()
                    toggleCallback(isToggled)
                    if bindKey ~= Enum.KeyCode.Unknown then
                        ActiveKeybinds[toggleName] = {Active = isToggled, Mode = "toggle", Key = bindKey}
                        UpdateKeybindList()
                    end
                end)

                if toggleOpts.ShowBind or toggleOpts.Bind then
                    bindButton.MouseButton1Click:Connect(function()
                        if bindListening then return end
                        bindListening = true
                        bindButton.Text = "[...]"
                        bindButton.TextColor3 = C.TextDim
                    end)

                    UserInputService.InputBegan:Connect(function(input, gameProcessed)
                        if bindListening then
                            if input.UserInputType == Enum.UserInputType.Keyboard then
                                if input.KeyCode == Enum.KeyCode.Escape then
                                    bindKey = Enum.KeyCode.Unknown
                                    bindButton.Text = "[-]"
                                else
                                    bindKey = input.KeyCode
                                    bindButton.Text = "[" .. bindKey.Name .. "]"
                                end
                                bindListening = false
                                bindButton.TextColor3 = C.TextDark
                                if bindKey ~= Enum.KeyCode.Unknown then
                                    ActiveKeybinds[toggleName] = {Active = isToggled, Mode = "toggle", Key = bindKey}
                                else
                                    ActiveKeybinds[toggleName] = nil
                                end
                                UpdateKeybindList()
                                return
                            end
                            if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.MouseButton2 then
                                bindListening = false
                                bindButton.Text = bindKey == Enum.KeyCode.Unknown and "[-]" or "[" .. bindKey.Name .. "]"
                                bindButton.TextColor3 = C.TextDark
                                return
                            end
                        end
                        if not bindListening and not gameProcessed and input.UserInputType == Enum.UserInputType.Keyboard then
                            if input.KeyCode == bindKey and bindKey ~= Enum.KeyCode.Unknown then
                                isToggled = not isToggled
                                ConfigState[toggleFlag] = isToggled
                                updateToggleVisual()
                                toggleCallback(isToggled)
                                ActiveKeybinds[toggleName] = {Active = isToggled, Mode = "toggle", Key = bindKey}
                                UpdateKeybindList()
                            end
                        end
                    end)
                end

                ConfigCallbacks[toggleFlag] = function(value)
                    isToggled = value
                    updateToggleVisual()
                    toggleCallback(value)
                end

                if toggleDefault then
                    toggleCallback(true)
                end

                local toggleObj = {}
                function toggleObj:Set(value)
                    isToggled = value
                    ConfigState[toggleFlag] = value
                    updateToggleVisual()
                    toggleCallback(value)
                end
                function toggleObj:Get()
                    return isToggled
                end
                return toggleObj
            end

            function Sector:AddSlider(sliderOpts)
                Sector.ElementCount = Sector.ElementCount + 1
                local sliderName = sliderOpts.Name or "Slider"
                local sliderMin = sliderOpts.Min or 0
                local sliderMax = sliderOpts.Max or 100
                local sliderDefault = sliderOpts.Default or sliderMin
                local sliderFlag = sliderOpts.Flag or sliderName
                local sliderCallback = sliderOpts.Callback or function() end
                local sliderSuffix = sliderOpts.Suffix or ""
                local sliderIncrement = sliderOpts.Increment or 1
                local currentSliderValue = sliderDefault
                ConfigState[sliderFlag] = currentSliderValue

                local sliderFrame = Create("Frame", {
                    Name = "Slider_" .. sliderName,
                    Parent = sectorContent,
                    BackgroundTransparency = 1,
                    Size = UDim2.new(1, 0, 0, 30),
                    LayoutOrder = Sector.ElementCount,
                })

                Create("TextLabel", {
                    Parent = sliderFrame,
                    BackgroundTransparency = 1,
                    Position = UDim2.new(0, 0, 0, 0),
                    Size = UDim2.new(1, 0, 0, 14),
                    Font = Enum.Font.SourceSans,
                    Text = sliderName,
                    TextColor3 = C.TextDim,
                    TextSize = 13,
                    TextXAlignment = Enum.TextXAlignment.Left,
                })

                local sliderOuterFrame = Create("Frame", {
                    Parent = sliderFrame,
                    BackgroundColor3 = C.SlOuter,
                    BorderSizePixel = 0,
                    Position = UDim2.new(0, 0, 0, 17),
                    Size = UDim2.new(1, 0, 0, 11),
                })

                local sliderBgFrame = Create("Frame", {
                    Parent = sliderOuterFrame,
                    BackgroundColor3 = C.SlBg,
                    BorderSizePixel = 0,
                    Position = UDim2.new(0, 1, 0, 1),
                    Size = UDim2.new(1, -2, 1, -2),
                    ClipsDescendants = true,
                })

                local fillPercentage = math.clamp((currentSliderValue - sliderMin) / (sliderMax - sliderMin), 0, 1)

                local sliderFillFrame = Create("Frame", {
                    Parent = sliderBgFrame,
                    BorderSizePixel = 0,
                    Position = UDim2.new(0, 0, 0, 0),
                    Size = UDim2.new(fillPercentage, 0, 1, 0),
                })

                Create("UIGradient", {
                    Parent = sliderFillFrame,
                    Color = ColorSequence.new(C.AccentDark, C.Accent),
                })

                local sliderKnobLabel = Create("TextLabel", {
                    Parent = sliderFrame,
                    BackgroundTransparency = 1,
                    Position = UDim2.new(fillPercentage, -15, 0, 0),
                    Size = UDim2.new(0, 30, 0, 16),
                    Font = Enum.Font.SourceSansSemibold,
                    Text = tostring(currentSliderValue) .. sliderSuffix,
                    TextColor3 = C.Text,
                    TextSize = 10,
                    ZIndex = 3,
                    TextXAlignment = Enum.TextXAlignment.Center,
                })

                local sliderInteractButton = Create("TextButton", {
                    Parent = sliderOuterFrame,
                    BackgroundTransparency = 1,
                    Size = UDim2.new(1, 0, 1, 0),
                    Text = "",
                    ZIndex = 5,
                })

                local isCurrentlySliding = false

                local function updateSliderFromInput(input)
                    local absolutePosition = sliderBgFrame.AbsolutePosition.X
                    local absoluteSize = sliderBgFrame.AbsoluteSize.X
                    if absoluteSize == 0 then
                        return
                    end

                    local relativeX = math.clamp((input.Position.X - absolutePosition) / absoluteSize, 0, 1)
                    local rawValue = sliderMin + (sliderMax - sliderMin) * relativeX
                    local steppedValue = math.floor(rawValue / sliderIncrement + 0.5) * sliderIncrement
                    steppedValue = math.clamp(steppedValue, sliderMin, sliderMax)

                    currentSliderValue = steppedValue
                    ConfigState[sliderFlag] = currentSliderValue

                    local newFillPct = (currentSliderValue - sliderMin) / (sliderMax - sliderMin)
                    sliderFillFrame.Size = UDim2.new(newFillPct, 0, 1, 0)
                    sliderKnobLabel.Text = tostring(currentSliderValue) .. sliderSuffix
                    sliderKnobLabel.Position = UDim2.new(newFillPct, -15, 0, 0)
                    sliderCallback(currentSliderValue)
                end

                sliderInteractButton.InputBegan:Connect(function(input)
                    if input.UserInputType == Enum.UserInputType.MouseButton1 then
                        isCurrentlySliding = true
                        updateSliderFromInput(input)
                    end
                end)

                sliderInteractButton.InputEnded:Connect(function(input)
                    if input.UserInputType == Enum.UserInputType.MouseButton1 then
                        isCurrentlySliding = false
                    end
                end)

                UserInputService.InputChanged:Connect(function(input)
                    if isCurrentlySliding and input.UserInputType == Enum.UserInputType.MouseMovement then
                        updateSliderFromInput(input)
                    end
                end)

                ConfigCallbacks[sliderFlag] = function(value)
                    currentSliderValue = value
                    local pct = (value - sliderMin) / (sliderMax - sliderMin)
                    sliderFillFrame.Size = UDim2.new(pct, 0, 1, 0)
                    sliderKnobLabel.Text = tostring(value) .. sliderSuffix
                    sliderKnobLabel.Position = UDim2.new(pct, -15, 0, 0)
                    sliderCallback(value)
                end

                sliderCallback(currentSliderValue)

                local sliderObj = {}
                function sliderObj:Set(value)
                    currentSliderValue = math.clamp(value, sliderMin, sliderMax)
                    ConfigState[sliderFlag] = currentSliderValue
                    local pct = (currentSliderValue - sliderMin) / (sliderMax - sliderMin)
                    sliderFillFrame.Size = UDim2.new(pct, 0, 1, 0)
                    sliderKnobLabel.Text = tostring(currentSliderValue) .. sliderSuffix
                    sliderKnobLabel.Position = UDim2.new(pct, -15, 0, 0)
                    sliderCallback(currentSliderValue)
                end
                function sliderObj:Get()
                    return currentSliderValue
                end
                return sliderObj
            end

