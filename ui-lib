                            ItemBtn.BackgroundColor3 = Colors.DropItemHover
                        end)
                        ItemBtn.MouseLeave:Connect(function()
                            ItemBtn.BackgroundColor3 = Colors.DropBg
                        end)
                        ItemBtn.MouseButton1Click:Connect(function()
                            if dMulti then
                                selectedValue[item] = not selectedValue[item] or nil
                                if selectedValue[item] == false then selectedValue[item] = nil end
                                ConfigState[dFlag] = selectedValue
                                SelLabel.Text = GetDisplayText()
                                ItemBtn.TextColor3 = selectedValue[item] and Colors.Accent or Colors.TextDim
                                dCallback(selectedValue)
                            else
                                selectedValue = item
                                ConfigState[dFlag] = selectedValue
                                SelLabel.Text = GetDisplayText()
                                isOpen = false
                                DropList.Visible = false
                                ActiveDropdown = nil
                                dCallback(selectedValue)
                            end
                        end)
                    end
                end

                local function ToggleDrop()
                    if ActiveDropdown and ActiveDropdown ~= DropList then
                        ActiveDropdown.Visible = false
                    end
                    isOpen = not isOpen
                    if isOpen then
                        RefreshItems()
                        local absPos = DropOuter.AbsolutePosition
                        local absSize = DropOuter.AbsoluteSize
                        local listH = math.min(#dItems * 16 + 2, 200)
                        DropList.Position = UDim2.new(0, absPos.X, 0, absPos.Y + absSize.Y)
                        DropList.Size = UDim2.new(0, absSize.X, 0, listH)
                        DropList.Visible = true
                        ActiveDropdown = DropList
                    else
                        DropList.Visible = false
                        ActiveDropdown = nil
                    end
                end

                DropInner.MouseButton1Click:Connect(ToggleDrop)

                SelLabel.Text = GetDisplayText()
                dCallback(selectedValue)

                ConfigCallbacks[dFlag] = function(val) selectedValue = val SelLabel.Text = GetDisplayText() dCallback(val) end

                local obj = {}
                function obj:Set(v) selectedValue = v ConfigState[dFlag] = v SelLabel.Text = GetDisplayText() dCallback(v) end
                function obj:Get() return selectedValue end
                function obj:UpdateItems(ni) dItems = ni if isOpen then RefreshItems() end end
                return obj
            end

