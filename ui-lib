                    end
                end

                updateToggleVisual()

                toggleButton.MouseEnter:Connect(function()
                    if not isToggled then
                        checkboxGradient.Color = ColorSequence.new(C.CheckGradHoverTop, C.CheckGradHoverBot)
                    end
                end)

                toggleButton.MouseLeave:Connect(function()
                    updateToggleVisual()
